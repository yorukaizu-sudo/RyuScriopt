local function getClosestInFOV()
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)
	if not myHrp then return nil end
	local closest,cd=nil,math.huge local sc=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)
	for _,p in ipairs(Players:GetPlayers()) do
		if p~=player then
			if CFG.aimlockTeamCheck and isTeammate(p) then continue end
			local char = getCharacterModel(p)
