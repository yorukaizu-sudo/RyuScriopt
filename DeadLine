local function getAimAssistTargetPart(char)
	local now = tick()
	if CFG.aimAssistLastChosenPart and getBodyPart(char, CFG.aimAssistLastChosenPart) and now-CFG.aimAssistLastPartSwitch < CFG.aimAssistPartSwitchRate then
		return getBodyPart(char, CFG.aimAssistLastChosenPart)
	end
	CFG.aimAssistLastPartSwitch = now
	local pn = "HumanoidRootPart"
	if CFG.aimAssistTargetPart == "Dynamic" then
		if math.random(1,100) <= CFG.aimAssistHeadshotRate then
			pn="Head"
		else
			for _, n in ipairs({"HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do
				if getBodyPart(char, n) then pn=n break end
			end
		end
	elseif CFG.aimAssistTargetPart == "Head" then pn="Head"
	elseif CFG.aimAssistTargetPart == "Body" then
		for _, n in ipairs({"HumanoidRootPart","UpperTorso","Torso"}) do
			if getBodyPart(char, n) then pn=n break end
		end
	end
	CFG.aimAssistLastChosenPart = pn
	return getBodyPart(char, pn) or getRootPart(char)
end

local function getAimAssistTarget()
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)
	if not myHrp then return nil, math.huge end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local closest, cd = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			local char = getCharacterModel(p)
			if char then
				local hrp = getRootPart(char)
				if hrp and isAlive(char) then
					if CFG.aimAssistTeamCheck and isTeammate(p) then continue end
					if (myHrp.Position-hrp.Position).Magnitude > CFG.aimAssistDistance then continue end
					local sp, onS = camera:WorldToViewportPoint(hrp.Position)
					if onS then
						local sd = (Vector2.new(sp.X,sp.Y)-cs).Magnitude
						if sd <= CFG.aimAssistFOV and sd < cd then cd=sd closest=p end
					end
				end
			end
		end
	end
	return closest, cd
end

local function isAimAssistTargetValid(p)
	if not p or not p.Parent then return false end
	local char = getCharacterModel(p)
	if not char then return false end
	local hrp = getRootPart(char)
	if not hrp or not isAlive(char) then return false end
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)
	if not myHrp or (myHrp.Position-hrp.Position).Magnitude > CFG.aimAssistDistance then return false end
	local _, onS = camera:WorldToViewportPoint(hrp.Position)
	return onS
end

local function applyAimAssist(dt)
	if not CFG.aimAssistEnabled then return end
	local myChar = getCharacterModel(player)
	if not myChar or not getRootPart(myChar) then return end
	if CFG.aimAssistOnlyWhileAiming then
		local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
		if not isAiming then CFG.aimAssistStickyTarget=nil CFG.aimAssistCurrentTarget=nil CFG.aimAssistFirstLock=false return end
	end
	local now = tick()
	local target = nil
	if CFG.aimAssistStickyAim and CFG.aimAssistStickyTarget then
		if isAimAssistTargetValid(CFG.aimAssistStickyTarget) then
			local char = getCharacterModel(CFG.aimAssistStickyTarget)
			local hrp = char and getRootPart(char)
			if hrp then
				local sp, onS = camera:WorldToViewportPoint(hrp.Position)
				if onS and (Vector2.new(sp.X,sp.Y)-Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)).Magnitude <= CFG.aimAssistFOV*1.8 then
					target = CFG.aimAssistStickyTarget
				end
			end
		end
		if not target and now-CFG.lastStickyTime < CFG.aimAssistReattachDelay then return end
	end
	if not target then
		target = getAimAssistTarget()
		if target then CFG.aimAssistFirstLock=true CFG.aimAssistLastTargetSwitch=now end
	end
	if not target then
		CFG.aimAssistCurrentTarget=nil CFG.aimAssistStickyTarget=nil CFG.aimAssistFirstLock=false return
	end
	local char = getCharacterModel(target)
	if not char then CFG.aimAssistCurrentTarget=nil CFG.aimAssistStickyTarget=nil CFG.aimAssistFirstLock=false return end
	local isNew = (CFG.aimAssistStickyTarget ~= target)
	CFG.aimAssistStickyTarget=target CFG.aimAssistCurrentTarget=target CFG.lastStickyTime=now
	local tp = getAimAssistTargetPart(char)
	if not tp then return end
	local tPos = tp.Position
	if CFG.aimAssistPrediction then
		local hrp = getRootPart(char)
		if hrp then
			local vel = Vector3.zero
			pcall(function() vel = hrp.AssemblyLinearVelocity end)
			tPos = tPos + Vector3.new(vel.X, 0, vel.Z)*CFG.aimAssistPredictionAmount
		end
	end
	local tsp, onS = camera:WorldToViewportPoint(tPos)
	if not onS then return end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local offMag = (Vector2.new(tsp.X,tsp.Y)-cs).Magnitude
	if offMag <= CFG.aimAssistInnerDeadzone then camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tPos),0.95) return end
	local ms
	if offMag <= CFG.aimAssistSlowdownZone then
		local zf = 1-(offMag/CFG.aimAssistSlowdownZone)
		ms = CFG.aimAssistStrength*(0.6+zf*0.4)+CFG.aimAssistMagnetism*zf*0.5
	else
		local ff = 1-math.clamp((offMag-CFG.aimAssistSlowdownZone)/(CFG.aimAssistFOV-CFG.aimAssistSlowdownZone),0,1)
		ms = CFG.aimAssistStrength*(0.2+ff*0.4)
	end
	if CFG.aimAssistFirstLock and isNew then ms=math.min(ms+CFG.aimAssistSnapStrength*0.3,1) CFG.aimAssistFirstLock=false end
	local ts = CFG.aimAssistTrackingSmooth
	if CFG.aimAssistSmoothing and offMag < 30 then ts=ts*0.5 end
	ms = math.clamp(ms, 0.01, 0.95)
	local fl = math.clamp(ms*(1-ts)+ts, 0.02, 0.9)
	camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, tPos), fl)
end

