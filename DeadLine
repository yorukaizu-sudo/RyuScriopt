-- Detect if we're in Deadline
local function detectDeadline()
	-- Check game name/PlaceId
	local placeId = game.PlaceId
	-- Deadline PlaceIds (add more as needed)
	local deadlinePlaces = {
		16596091208, -- Main Deadline
		-- Add test place IDs here if needed
	}

	for _, id in ipairs(deadlinePlaces) do
		if placeId == id then
			DEADLINE.isDeadline = true
			break
		end
	end

	-- Also detect by workspace structure
	if not DEADLINE.isDeadline then
		for _, name in ipairs(DEADLINE.possibleCharFolders) do
			if workspace:FindFirstChild(name) then
				DEADLINE.isDeadline = true
				DEADLINE.characterFolder = workspace:FindFirstChild(name)
				break
			end
		end
	end

	-- Deadline specific: check for common Deadline folders
	if workspace:FindFirstChild("Map") or workspace:FindFirstChild("Gamemode") then
		DEADLINE.isDeadline = true
	end

	-- Search for character container
	if DEADLINE.isDeadline and not DEADLINE.characterFolder then
		-- In Deadline, characters are often directly in workspace
		-- or in a specific folder
		for _, child in ipairs(workspace:GetChildren()) do
			if child:IsA("Folder") then
				-- Check if folder contains player models
				for _, sub in ipairs(child:GetChildren()) do
					if sub:IsA("Model") then
						for _, p in ipairs(Players:GetPlayers()) do
							if sub.Name == p.Name or sub.Name == p.DisplayName then
								DEADLINE.characterFolder = child
								break
							end
						end
					end
					if DEADLINE.characterFolder then break end
				end
			end
			if DEADLINE.characterFolder then break end
		end
	end
end

-- Get character model for a player (Deadline compatible)
local function getCharacterModel(p)
	if not p then return nil end

	-- Standard Roblox character
	if p.Character and p.Character.Parent then
		local hum = p.Character:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			return p.Character
		end
	end

	if not DEADLINE.isDeadline then return p.Character end

	-- Deadline: search in character folder
	if DEADLINE.characterFolder then
		local model = DEADLINE.characterFolder:FindFirstChild(p.Name)
			or DEADLINE.characterFolder:FindFirstChild(p.DisplayName)
		if model then return model end

		-- Search deeper
		for _, child in ipairs(DEADLINE.characterFolder:GetDescendants()) do
			if child:IsA("Model") and (child.Name == p.Name or child.Name == p.DisplayName) then
				return child
			end
		end
	end

	-- Search entire workspace for player model
	for _, child in ipairs(workspace:GetChildren()) do
		if child:IsA("Model") and (child.Name == p.Name or child.Name == p.DisplayName) then
			return child
		end
	end

	-- Search in common Deadline locations
	local searchLocations = {
		workspace:FindFirstChild("Characters"),
		workspace:FindFirstChild("Ignore"),
		workspace:FindFirstChild("Game"),
		workspace:FindFirstChild("Players"),
	}

	for _, loc in ipairs(searchLocations) do
		if loc then
			local found = loc:FindFirstChild(p.Name) or loc:FindFirstChild(p.DisplayName)
			if found then return found end
		end
	end

	return p.Character
end

-- Get root part of character (Deadline compatible)
local function getRootPart(char)
	if not char then return nil end

	-- Standard
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if hrp then return hrp end

	-- Deadline alternatives
	local alternatives = {
		"HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso",
		"pelvis", "Pelvis", "Root", "root", "spine", "Spine",
		"chest", "Chest", "Body", "body", "Center"
	}

	for _, name in ipairs(alternatives) do
		local part = char:FindFirstChild(name)
		if part and part:IsA("BasePart") then return part end
	end

	-- Search descendants
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("BasePart") and not desc:IsA("Terrain") then
			local n = desc.Name:lower()
			if n:find("root") or n:find("torso") or n:find("pelvis")
				or n:find("spine") or n:find("chest") then
				return desc
			end
		end
	end

	-- Last resort: find primary part or any BasePart
	if char:IsA("Model") and char.PrimaryPart then
		return char.PrimaryPart
	end

	for _, desc in ipairs(char:GetChildren()) do
		if desc:IsA("BasePart") then return desc end
	end

	return nil
end

-- Get head part (Deadline compatible)
local function getHeadPart(char)
	if not char then return nil end

	local head = char:FindFirstChild("Head")
	if head and head:IsA("BasePart") then return head end

	local alternatives = {
		"Head", "head", "HeadHB", "Neck", "neck",
		"HeadHitbox", "head_hitbox"
	}

	for _, name in ipairs(alternatives) do
		local part = char:FindFirstChild(name)
		if part and part:IsA("BasePart") then return part end
	end

	-- Search descendants
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("BasePart") and desc.Name:lower():find("head") then
			return desc
		end
	end

	return getRootPart(char) -- Fallback to root
end

-- Get specific body part (Deadline compatible)
local function getBodyPart(char, partName)
	if not char then return nil end

	-- Direct search
	local part = char:FindFirstChild(partName)
	if part and part:IsA("BasePart") then return part end

	-- Map standard names to Deadline alternatives
	local nameMap = {
		["Head"] = {"Head", "head", "HeadHB", "Neck"},
		["HumanoidRootPart"] = {"HumanoidRootPart", "Torso", "pelvis", "Root", "spine"},
		["Torso"] = {"Torso", "UpperTorso", "chest", "Chest", "Spine1"},
		["UpperTorso"] = {"UpperTorso", "chest", "Chest", "Spine2"},
		["LowerTorso"] = {"LowerTorso", "pelvis", "Pelvis", "Spine"},
	}

	local alts = nameMap[partName]
	if alts then
		for _, alt in ipairs(alts) do
			local p = char:FindFirstChild(alt)
			if p and p:IsA("BasePart") then return p end
		end
	end

	-- Search descendants
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("BasePart") and desc.Name:lower() == partName:lower() then
			return desc
		end
	end

	return getRootPart(char)
end

-- Get humanoid or health info (Deadline compatible)
local function getHealthInfo(char)
	if not char then return nil, 0, 100 end

	-- Standard Humanoid
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then return hum, hum.Health, hum.MaxHealth end

	-- Deadline: health might be stored differently
	-- Check attributes
	local health = 100
	local maxHealth = 100

	pcall(function()
		local h = char:GetAttribute("Health") or char:GetAttribute("health")
		local mh = char:GetAttribute("MaxHealth") or char:GetAttribute("maxHealth")
			or char:GetAttribute("MaxHP") or char:GetAttribute("maxHP")
		if h then health = h end
		if mh then maxHealth = mh end
	end)

	-- Check for health value objects
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("NumberValue") or desc:IsA("IntValue") then
			local n = desc.Name:lower()
			if n == "health" or n == "hp" then
				health = desc.Value
			elseif n == "maxhealth" or n == "maxhp" then
				maxHealth = desc.Value
			end
		end
	end

	-- Search for Humanoid in descendants (Deadline sometimes nests it)
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("Humanoid") then
			return desc, desc.Health, desc.MaxHealth
		end
	end

	return nil, health, maxHealth
end

-- Check if character is alive
local function isAlive(char)
	if not char or not char.Parent then return false end

	local hum, health, _ = getHealthInfo(char)

	if hum then return hum.Health > 0 end
	return health > 0
end

-- Deadline team check
local function isDeadlineTeammate(p)
	if not p then return false end

	-- Standard team check
	if p.Team and player.Team and p.Team == player.Team then
		return true
	end

	-- Deadline: check attributes on character or player
	pcall(function()
		local myTeam = player:GetAttribute("Team") or player:GetAttribute("team")
			or player:GetAttribute("Side") or player:GetAttribute("side")
		local theirTeam = p:GetAttribute("Team") or p:GetAttribute("team")
			or p:GetAttribute("Side") or p:GetAttribute("side")
		if myTeam and theirTeam and myTeam == theirTeam then
			return true
		end
	end)

	-- Check character attributes
	pcall(function()
		local myChar = getCharacterModel(player)
		local theirChar = getCharacterModel(p)
		if myChar and theirChar then
			local myTeam = myChar:GetAttribute("Team") or myChar:GetAttribute("team")
			local theirTeam = theirChar:GetAttribute("Team") or theirChar:GetAttribute("team")
			if myTeam and theirTeam and myTeam == theirTeam then
				return true
			end
		end
	end)

	-- Check leaderstats or similar
	pcall(function()
		local myLS = player:FindFirstChild("leaderstats")
		local theirLS = p:FindFirstChild("leaderstats")
		if myLS and theirLS then
			local myTeamVal = myLS:FindFirstChild("Team") or myLS:FindFirstChild("Side")
			local theirTeamVal = theirLS:FindFirstChild("Team") or theirLS:FindFirstChild("Side")
			if myTeamVal and theirTeamVal and myTeamVal.Value == theirTeamVal.Value then
				return true
			end
		end
	end)

	return false
end

