local function overrideSingleValue(obj, isSpread)
	if not isValidInstance(obj) or not obj:IsA("ValueBase") then return end
	local key = tostring(obj)
	if CFG.noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj.Value end)
	if not ok or typeof(val) ~= "number" then return end
	local red = isSpread and (CFG.noSpreadStrength/100) or (CFG.noRecoilStrength/100)
	CFG.noRecoilOverriddenObjects[key] = {obj=obj, originalValue=val, type="value"}
	pcall(function() obj.Value = val * (1-red) end)
end

local function overrideSingleAttribute(obj, attrName, isSpread)
	if not isValidInstance(obj) then return end
	local key = tostring(obj).."_attr_"..attrName
	if CFG.noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj:GetAttribute(attrName) end)
	if not ok or typeof(val) ~= "number" then return end
	local red = isSpread and (CFG.noSpreadStrength/100) or (CFG.noRecoilStrength/100)
	CFG.noRecoilOverriddenObjects[key] = {obj=obj, attrName=attrName, originalValue=val, type="attribute"}
	pcall(function() obj:SetAttribute(attrName, val*(1-red)) end)
end

local function overrideTableRecoil(tbl, depth)
	depth = depth or 0
	if depth > 4 or typeof(tbl) ~= "table" then return end
	for key, val in pairs(tbl) do
		if typeof(key) == "string" then
			if CFG.noRecoilEnabled and typeof(val) == "number" then
				for _, kw in ipairs(recoilKeywords) do if key:lower():find(kw) then tbl[key] = val*(1-CFG.noRecoilStrength/100) break end end
			end
			if CFG.noSpreadEnabled and typeof(val) == "number" then
				for _, kw in ipairs(spreadKeywords) do if key:lower():find(kw) then tbl[key] = val*(1-CFG.noSpreadStrength/100) break end end
			end
			if typeof(val) == "table" then overrideTableRecoil(val, depth+1) end
		end
	end
end

local function scanEquippedTool(tool)
	if not tool or not isValidInstance(tool) or not tool:IsA("Tool") then return end
	local char = player.Character
	if not char or tool.Parent ~= char then return end
	CFG.noRecoilCurrentTool = tool
	for _, desc in ipairs(tool:GetDescendants()) do
		if not isValidInstance(desc) then continue end
		if desc:IsA("ValueBase") then
			if CFG.noRecoilEnabled and containsKeyword(desc.Name, recoilKeywords) then overrideSingleValue(desc, false) end
			if CFG.noSpreadEnabled and containsKeyword(desc.Name, spreadKeywords) then overrideSingleValue(desc, true) end
		end
		if desc:IsA("Configuration") or desc:IsA("Folder") then
			for _, child in ipairs(desc:GetChildren()) do
				if child:IsA("ValueBase") then
					if CFG.noRecoilEnabled and containsKeyword(child.Name, recoilKeywords) then overrideSingleValue(child, false) end
					if CFG.noSpreadEnabled and containsKeyword(child.Name, spreadKeywords) then overrideSingleValue(child, true) end
				end
			end
		end
		pcall(function()
			for an, av in pairs(desc:GetAttributes()) do
				if typeof(av) == "number" then
					if CFG.noRecoilEnabled and containsKeyword(an, recoilKeywords) then overrideSingleAttribute(desc, an, false) end
					if CFG.noSpreadEnabled and containsKeyword(an, spreadKeywords) then overrideSingleAttribute(desc, an, true) end
				end
			end
		end)
	end
	pcall(function()
		for an, av in pairs(tool:GetAttributes()) do
			if typeof(av) == "number" then
				if CFG.noRecoilEnabled and containsKeyword(an, recoilKeywords) then overrideSingleAttribute(tool, an, false) end
				if CFG.noSpreadEnabled and containsKeyword(an, spreadKeywords) then overrideSingleAttribute(tool, an, true) end
			end
		end
	end)
	for _, desc in ipairs(tool:GetDescendants()) do
		if desc:IsA("ModuleScript") then
			local n = desc.Name:lower()
			if n:find("recoil") or n:find("spread") or n:find("config") or n:find("stat") or n:find("setting") or n:find("weapon") or n:find("gun") then
				pcall(function() local md = require(desc) if typeof(md) == "table" then overrideTableRecoil(md) end end)
			end
		end
	end
end

local function restoreAllRecoilValues()
	for _, d in pairs(CFG.noRecoilOverriddenObjects) do
		pcall(function()
			if d.type == "value" and isValidInstance(d.obj) then d.obj.Value = d.originalValue
			elseif d.type == "attribute" and isValidInstance(d.obj) then d.obj:SetAttribute(d.attrName, d.originalValue) end
		end)
	end
	CFG.noRecoilOverriddenObjects = {}
	CFG.noRecoilCurrentTool = nil
	CFG.noRecoilIsShooting = false
	CFG.noRecoilLockedCFrame = nil
end

local function refreshRecoilOverrides()
	if not (CFG.noRecoilEnabled or CFG.noSpreadEnabled) or not CFG.noRecoilValueOverride then return end
	for key, d in pairs(CFG.noRecoilOverriddenObjects) do
		if not isValidInstance(d.obj) then CFG.noRecoilOverriddenObjects[key] = nil continue end
		pcall(function()
			if d.type == "value" then
				local cv = d.obj.Value
				if typeof(cv) == "number" then
					local isSp = containsKeyword(d.obj.Name, spreadKeywords)
					local red = isSp and (CFG.noSpreadStrength/100) or (CFG.noRecoilStrength/100)
					local tv = d.originalValue*(1-red)
					if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj.Value = tv end
				end
			elseif d.type == "attribute" then
				local cv = d.obj:GetAttribute(d.attrName)
				if typeof(cv) == "number" then
					local isSp = containsKeyword(d.attrName, spreadKeywords)
					local red = isSp and (CFG.noSpreadStrength/100) or (CFG.noRecoilStrength/100)
					local tv = d.originalValue*(1-red)
					if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj:SetAttribute(d.attrName, tv) end
				end
			end
		end)
	end
end

local function applyNoRecoilCameraLock()
	if not CFG.noRecoilCameraLock or not (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then return end
	local shooting = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
	if shooting then
		if not CFG.noRecoilIsShooting then
			CFG.noRecoilIsShooting = true
			CFG.noRecoilLockedCFrame = camera.CFrame
		elseif CFG.noRecoilLockedCFrame then
			local str = CFG.noRecoilStrength/100
			local cp = camera.CFrame.Position
			local ll = CFG.noRecoilLockedCFrame.LookVector
			camera.CFrame = camera.CFrame:Lerp(CFrame.new(cp, cp+ll), str*0.8)
		end
	elseif CFG.noRecoilIsShooting then
		CFG.noRecoilIsShooting = false
		CFG.noRecoilLockedCFrame = nil
	end
end

local function overrideRecoilPhysics()
	if not CFG.noRecoilEnabled then return end
	local char = player.Character
	if not char then return end
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("BodyAngularVelocity") or desc:IsA("BodyGyro") then
			local n = desc.Name:lower()
			if n:find("recoil") or n:find("kick") or n:find("shake") then pcall(function() desc:Destroy() end) end
		end
	end
end

local function setupToolListener(char)
	if not char then return end
	if CFG.noRecoilToolConnection then pcall(function() CFG.noRecoilToolConnection:Disconnect() end) end
	CFG.noRecoilToolConnection = char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") and (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then
			task.wait(0.3)
			if isValidInstance(child) and child.Parent == char then scanEquippedTool(child) end
		end
	end)
	task.wait(0.5)
	if not isValidInstance(char) then return end
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Tool") and (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then scanEquippedTool(child) end
	end
end

local function deepScanModules()
	if not (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then return 0 end
	local places = {ReplicatedStorage}
	pcall(function() table.insert(places, player.PlayerScripts) end)
	local count = 0
	for _, place in ipairs(places) do
		pcall(function()
			for _, desc in ipairs(place:GetDescendants()) do
				if desc:IsA("ModuleScript") then
					local n = desc.Name:lower()
					if n:find("recoil") or n:find("spread") or n:find("weapon") or n:find("gun") or n:find("config") then
						pcall(function() local md = require(desc) if typeof(md) == "table" then overrideTableRecoil(md) count=count+1 end end)
					end
				end
			end
		end)
	end
	return count
end

local function hookNoRecoilRemotes()
	if CFG.noRecoilHooked then return end
	CFG.noRecoilHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local args = {...}
			if CFG.noRecoilEnabled and CFG.noRecoilRemoteIntercept then
				if name:find("recoil") or name:find("kick") or name:find("camerashake") or name:find("shake") then
					if CFG.noRecoilStrength >= 100 then return nil end
				end
			end
			if CFG.noSpreadEnabled and (name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet")) then
				for i, arg in ipairs(args) do
					if typeof(arg) == "Vector3" then
						local ld = camera.CFrame.LookVector
						if arg.Unit:Dot(ld) > 0.8 then args[i] = ld:Lerp(arg.Unit, 1-CFG.noSpreadStrength/100) * arg.Magnitude end
					elseif typeof(arg) == "table" then
						for k, v in pairs(arg) do
							if typeof(k)=="string" and typeof(v)=="number" then
								if containsKeyword(k, spreadKeywords) then arg[k]=v*(1-CFG.noSpreadStrength/100) end
								if containsKeyword(k, recoilKeywords) then arg[k]=v*(1-CFG.noRecoilStrength/100) end
							end
						end
					end
				end
				return oldFS(self, unpack(args))
			end
			return oldFS(self, ...)
		end))
	end)
end

