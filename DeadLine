local function lerpV2(a,b,t) return Vector2.new(a.X+(b.X-a.X)*t, a.Y+(b.Y-a.Y)*t) end

local function updatePlayerESP()
	if not CFG.espEnabled then return end
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)

	for _, tp in ipairs(Players:GetPlayers()) do
		if tp == player then continue end
		if CFG.espTeamCheck and isTeammate(tp) then
			if CFG.espObjects[tp] then
				local d=CFG.espObjects[tp]
				if d.box then d.box.Visible=false end if d.line then d.line.Visible=false end
				if d.name then d.name.Visible=false end if d.distText then d.distText.Visible=false end
				if d.healthText then d.healthText.Visible=false end if d.healthBar then d.healthBar.Visible=false end
				if d.healthBg then d.healthBg.Visible=false end
				if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
			end
			continue
		end

		local char = getCharacterModel(tp)

		if not CFG.espObjects[tp] then
			CFG.espObjects[tp] = {
				box=Drawing.new("Square"), line=Drawing.new("Line"),
				name=Drawing.new("Text"), distText=Drawing.new("Text"),
				healthText=Drawing.new("Text"), healthBar=Drawing.new("Line"),
				healthBg=Drawing.new("Line"), smoothFrom=nil, smoothTo=nil,
			}
			local d=CFG.espObjects[tp]
			d.box.Thickness=1.5 d.box.Filled=false d.box.Visible=false
			d.line.Thickness=1.5 d.line.Visible=false
			d.name.Size=14 d.name.Center=true d.name.Outline=true d.name.Font=2 d.name.Visible=false
			d.distText.Size=12 d.distText.Center=true d.distText.Outline=true d.distText.Font=2 d.distText.Visible=false
			d.healthText.Size=12 d.healthText.Center=true d.healthText.Outline=true d.healthText.Font=2 d.healthText.Visible=false
			d.healthBar.Thickness=3 d.healthBar.Visible=false
			d.healthBg.Thickness=5 d.healthBg.Visible=false d.healthBg.Color=Color3.fromRGB(40,40,40)
		end

		local d=CFG.espObjects[tp]
		local color = CFG.espTeamCheck and (isTeammate(tp) and CFG.espTeamColor or CFG.espEnemyColor) or CFG.espColor

		if not char then
			d.box.Visible=false d.line.Visible=false d.name.Visible=false
			d.distText.Visible=false d.healthText.Visible=false d.healthBar.Visible=false d.healthBg.Visible=false
			if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
			continue
		end

		local hrp = getRootPart(char)
		local head = getHeadPart(char)
		local _, health, maxHealth = getHealthInfo(char)

		if not hrp or not isAlive(char) then
			d.box.Visible=false d.line.Visible=false d.name.Visible=false
			d.distText.Visible=false d.healthText.Visible=false d.healthBar.Visible=false d.healthBg.Visible=false
			if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
			continue
		end

		local pos,onS=camera:WorldToViewportPoint(hrp.Position)
		if onS then
			-- Calculate bounding box based on character size
			local charHeight = 6 -- default
			local headPos = head and head.Position or (hrp.CFrame * CFrame.new(0, 3, 0)).Position
			local feetPos = (hrp.CFrame * CFrame.new(0, -3, 0)).Position

			-- Try to get more accurate bounds
			pcall(function()
				if head and hrp then
					local diff = (headPos.Y - hrp.Position.Y)
					if diff > 0 then
						charHeight = diff * 2 + 1
					end
				end
			end)

			local tp2=camera:WorldToViewportPoint(headPos + Vector3.new(0, 0.5, 0))
			local bp=camera:WorldToViewportPoint(feetPos - Vector3.new(0, 0.5, 0))
			local h=math.abs(tp2.Y-bp.Y) local w=h/1.8

			if h < 5 then h = 5 w = h/1.8 end -- minimum size

			if CFG.espBox then d.box.Size=Vector2.new(w,h) d.box.Position=Vector2.new(pos.X-w/2,pos.Y-h/2) d.box.Color=color d.box.Visible=true else d.box.Visible=false end
			if CFG.espLine then
				local tf=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y) local tt=Vector2.new(pos.X,pos.Y)
				if d.smoothFrom and d.smoothTo then d.smoothFrom=lerpV2(d.smoothFrom,tf,CFG.espLineSmoothing) d.smoothTo=lerpV2(d.smoothTo,tt,CFG.espLineSmoothing)
				else d.smoothFrom=tf d.smoothTo=tt end
				d.line.From=d.smoothFrom d.line.To=d.smoothTo d.line.Color=color d.line.Visible=true
			else d.line.Visible=false d.smoothFrom=nil d.smoothTo=nil end

			if CFG.espName then
				local namePos = head and camera:WorldToViewportPoint(headPos + Vector3.new(0, 1.5, 0)) or camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
				d.name.Position=Vector2.new(namePos.X,namePos.Y) d.name.Text=tp.DisplayName.." (@"..tp.Name..")" d.name.Color=color d.name.Visible=true
			else d.name.Visible=false end

			if CFG.espDistance and myHrp then
				local dist=math.floor((myHrp.Position-hrp.Position).Magnitude)
				local distPos = head and camera:WorldToViewportPoint(headPos + Vector3.new(0, 1.5, 0)) or camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
				d.distText.Position=Vector2.new(distPos.X,distPos.Y+(CFG.espName and 14 or 0)) d.distText.Text="["..dist.."m]" d.distText.Color=Color3.fromRGB(200,200,200) d.distText.Visible=true
			else d.distText.Visible=false end

			if CFG.espHealth then
				local hp=math.clamp(health/math.max(maxHealth, 1),0,1)
				if CFG.espBox then
					local bx=pos.X-w/2-7
					d.healthBg.From=Vector2.new(bx,pos.Y+h/2) d.healthBg.To=Vector2.new(bx,pos.Y-h/2) d.healthBg.Visible=true
					d.healthBar.From=Vector2.new(bx,pos.Y+h/2) d.healthBar.To=Vector2.new(bx,pos.Y+h/2-h*hp)
					d.healthBar.Color=Color3.fromRGB(255*(1-hp),255*hp,0) d.healthBar.Visible=true
				else d.healthBar.Visible=false d.healthBg.Visible=false end
				local yOff=(CFG.espName and 14 or 0)+(CFG.espDistance and 14 or 0)
				local hpPos = head and camera:WorldToViewportPoint(headPos + Vector3.new(0, 1.5, 0)) or camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
				d.healthText.Position=Vector2.new(hpPos.X,hpPos.Y+yOff)
				d.healthText.Text=math.floor(health).."/"..math.floor(maxHealth).." HP"
				d.healthText.Color=Color3.fromRGB(255*(1-hp),255*hp,0) d.healthText.Visible=true
			else d.healthBar.Visible=false d.healthBg.Visible=false d.healthText.Visible=false end

			if CFG.espHighlight then
				if not d.highlight or not d.highlight.Parent then
					d.highlight=Instance.new("Highlight") d.highlight.FillColor=color d.highlight.OutlineColor=Color3.new(1,1,1)
					d.highlight.FillTransparency=0.7 d.highlight.OutlineTransparency=0.3 d.highlight.Parent=char
				else d.highlight.FillColor=color end
			elseif d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
		else
			d.box.Visible=false d.line.Visible=false d.name.Visible=false
			d.distText.Visible=false d.healthText.Visible=false d.healthBar.Visible=false d.healthBg.Visible=false
			d.smoothFrom=nil d.smoothTo=nil
		end
	end
end

local function clearAllESP()
	for _, d in pairs(CFG.espObjects) do
		pcall(function() d.box:Remove() end) pcall(function() d.line:Remove() end)
