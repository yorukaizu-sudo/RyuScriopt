local function canSeeTarget(fromPos, targetPart)
	if not CFG.silentAimVisibleCheck then return true end
	if CFG.wallbangEnabled and CFG.wallbangSilentAimIntegration then
		return findPlayerThroughWalls(fromPos, targetPart.Position)
	end
	local myChar = getCharacterModel(player)
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {myChar or player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local dir = (targetPart.Position - fromPos)
	local result = workspace:Raycast(fromPos, dir, params)
	if result then
		local hm = result.Instance:FindFirstAncestorOfClass("Model")
		local tm = targetPart:FindFirstAncestorOfClass("Model")
		if hm and tm and hm == tm then return true end
		if result.Instance:IsDescendantOf(targetPart.Parent) then return true end
	end
	return result == nil
end

local function getSilentAimTargetPart(char)
	if CFG.silentAimAutoHeadshot and math.random(1,100) <= CFG.silentAimHeadshotChance then
		local head = getHeadPart(char)
		if head then return head end
	end
	if CFG.silentAimPart == "Head" then
		return getHeadPart(char) or getRootPart(char)
	elseif CFG.silentAimPart == "Body" then
		return getRootPart(char) or getBodyPart(char, "UpperTorso") or getBodyPart(char, "Torso")
	elseif CFG.silentAimPart == "Random" then
		local valid = {}
		for _, pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do
			local p = getBodyPart(char, pn) if p then table.insert(valid, p) end
		end
		if #valid > 0 then return valid[math.random(1,#valid)] end
	elseif CFG.silentAimPart == "Nearest to Cursor" then
		local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
		local cp, cd = nil, math.huge
		for _, pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do
			local p = getBodyPart(char, pn)
			if p then
				local sp, onS = camera:WorldToViewportPoint(p.Position)
				if onS then local sd = (Vector2.new(sp.X,sp.Y)-cs).Magnitude if sd < cd then cd=sd cp=p end end
			end
		end
		return cp or getRootPart(char)
	elseif CFG.silentAimPart == "Aim Assist Sync" then
		if CFG.aimAssistCurrentTarget and CFG.aimAssistLastChosenPart then
			local aaChar = getCharacterModel(CFG.aimAssistCurrentTarget)
			if aaChar == char then
				local p = getBodyPart(char, CFG.aimAssistLastChosenPart)
				if p then return p end
			end
		end
		return getHeadPart(char) or getRootPart(char)
	end
	return getRootPart(char)
end

local function getPredictedPosition(targetPart, char)
	if not CFG.silentAimPrediction then return targetPart.Position end
	local hrp = getRootPart(char)
	if not hrp then return targetPart.Position end
	local vel = Vector3.zero
	pcall(function() vel = hrp.AssemblyLinearVelocity end)
	return targetPart.Position + Vector3.new(vel.X, 0, vel.Z) * CFG.silentAimPredictionAmount
end

local function getSilentAimTarget()
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)
	if not myHrp then return nil, nil end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local closest, closestDist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			local char = getCharacterModel(p)
			if char then
				local hrp = getRootPart(char)
				if hrp and isAlive(char) then
					if CFG.silentAimTeamCheck and isTeammate(p) then continue end
					if (myHrp.Position - hrp.Position).Magnitude > CFG.silentAimDistance then continue end
					local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
					local screenDist = math.huge
					if onScreen then
						screenDist = (Vector2.new(sp.X,sp.Y)-cs).Magnitude
					elseif CFG.wallbangEnabled and CFG.wallbangSilentAimIntegration then
						screenDist = (myHrp.Position - hrp.Position).Magnitude * 0.5
					end
					if screenDist <= CFG.silentAimFOV and screenDist < closestDist and canSeeTarget(myHrp.Position, hrp) then
						closestDist = screenDist
						closest = p
					end
				end
			end
		end
	end
	if closest then
		local char = getCharacterModel(closest)
		if char then return closest, getSilentAimTargetPart(char) end
	end
	return nil, nil
end

local function hookSilentAim()
	if CFG.silentAimHooked then return end
	CFG.silentAimHooked = true
	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then return end
		local oldIdx = mt.__index
		setreadonly(mt, false)
		mt.__index = newcclosure(function(self, key)
			if CFG.silentAimEnabled and self == mouse then
				if key == "Hit" or key == "hit" then
					local t, tp = getSilentAimTarget()
					if t and tp then
						local char = getCharacterModel(t)
						CFG.silentAimCurrentTarget = t
						return CFrame.new(getPredictedPosition(tp, char))
					end
				elseif key == "Target" or key == "target" then
					local t, tp = getSilentAimTarget() if t and tp then return tp end
				elseif key == "UnitRay" or key == "unitray" then
					local t, tp = getSilentAimTarget()
					if t and tp then
						local char = getCharacterModel(t)
						local pos = getPredictedPosition(tp, char)
						return Ray.new(camera.CFrame.Position, (pos-camera.CFrame.Position).Unit)
					end
				end
			end
			if key == "Size" and typeof(self)=="Instance" and self:IsA("BasePart") and self.Name == "HitboxOverlay" then return Vector3.new(2,2,1) end
			return oldIdx(self, key)
		end)
		setreadonly(mt, true)
	end)
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldRC = workspace.Raycast
		hf(workspace.Raycast, newcclosure(function(self, origin, direction, rayParams, ...)
			if not CFG.silentAimEnabled then return oldRC(self, origin, direction, rayParams, ...) end
			local myChar = getCharacterModel(player)
			local myHrp = myChar and getRootPart(myChar)
			if myHrp and (origin-myHrp.Position).Magnitude < 15 then
				local t, tp = getSilentAimTarget()
				if t and tp and math.random(1,100) <= CFG.silentAimHitChance then
					local char = getCharacterModel(t)
					local tPos = getPredictedPosition(tp, char)
					return oldRC(self, origin, (tPos-origin).Unit * direction.Magnitude, rayParams, ...)
				end
			end
			return oldRC(self, origin, direction, rayParams, ...)
		end))
	end)
end

local function hookBulletRedirect()
	if CFG.bulletRedirectHooked then return end
	CFG.bulletRedirectHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (CFG.silentAimEnabled or CFG.bulletRedirectEnabled) then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local isShoot = name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") or name:find("weapon") or name:find("gun") or name:find("hit") or name:find("damage") or name:find("ray") or name:find("cast") or name:find("projectile")
			if not isShoot then return oldFS(self, ...) end
			local t, tp = getSilentAimTarget()
			if not t or not tp or math.random(1,100) > CFG.silentAimHitChance then return oldFS(self, ...) end
			local char = getCharacterModel(t)
			local tPos = getPredictedPosition(tp, char)
			local args = {...}
			for i, arg in ipairs(args) do
				if typeof(arg) == "Vector3" then
					local myChar = getCharacterModel(player)
					local myHrp = myChar and getRootPart(myChar)
					if myHrp then
						if arg.Unit:Dot(camera.CFrame.LookVector) > 0.5 then args[i] = (tPos-camera.CFrame.Position).Unit * arg.Magnitude
						elseif (arg-myHrp.Position).Magnitude > 5 then args[i] = tPos end
					end
				elseif typeof(arg) == "CFrame" then args[i] = CFrame.new(arg.Position, tPos)
				elseif typeof(arg) == "Ray" then args[i] = Ray.new(arg.Origin, (tPos-arg.Origin).Unit * arg.Direction.Magnitude)
				elseif typeof(arg) == "Instance" and arg:IsA("BasePart") then args[i] = tp
				elseif typeof(arg) == "table" then
					for k, v in pairs(arg) do
						if typeof(v)=="Vector3" and typeof(k)=="string" then
							local kl = k:lower()
							if kl:find("pos") or kl:find("hit") or kl:find("target") or kl:find("point") then arg[k]=tPos
							elseif kl:find("dir") or kl:find("look") or kl:find("aim") then arg[k]=(tPos-camera.CFrame.Position).Unit end
						elseif typeof(v)=="CFrame" and typeof(k)=="string" then
							if k:lower():find("aim") or k:lower():find("look") then arg[k]=CFrame.new(v.Position,tPos) end
						elseif typeof(v)=="Instance" and v:IsA("BasePart") and typeof(k)=="string" then
							if k:lower():find("hit") or k:lower():find("target") then arg[k]=tp end
						end
					end
				end
			end
			return oldFS(self, unpack(args))
		end))
	end)
end

