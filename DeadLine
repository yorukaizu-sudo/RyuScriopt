local function getMoveDirection()
	local char = player.Character
	if not char then return Vector3.zero end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return Vector3.zero end
	return hum.MoveDirection.Magnitude > 0 and hum.MoveDirection.Unit or Vector3.zero
end

local function getGroundInfo()
	local myChar = getCharacterModel(player)
	local hrp = myChar and getRootPart(myChar)
	if not hrp then return math.huge end
	local p = RaycastParams.new() p.FilterDescendantsInstances={myChar or player.Character} p.FilterType=Enum.RaycastFilterType.Exclude
	local r = workspace:Raycast(hrp.Position, Vector3.new(0,-500,0), p) return r and (hrp.Position-r.Position).Magnitude or math.huge
end

local function applySpeed(dt)
	local char=player.Character if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	if CFG.speedMethod=="Default" then hum.WalkSpeed=CFG.speed
	elseif CFG.speedMethod=="CFrame Bypass" then hum.WalkSpeed=16 local d=getMoveDirection() if d.Magnitude>0 and CFG.speed>16 then hrp.CFrame=hrp.CFrame+(d*(CFG.speed-16)*dt) end
	elseif CFG.speedMethod=="Velocity Bypass" then hum.WalkSpeed=16 local d=getMoveDirection() if d.Magnitude>0 then hrp.AssemblyLinearVelocity=Vector3.new(d.X*CFG.speed,hrp.AssemblyLinearVelocity.Y,d.Z*CFG.speed) end
	elseif CFG.speedMethod=="BodyVelocity Bypass" then
		hum.WalkSpeed=16 local bv=hrp:FindFirstChild("SpeedBV")
		if not bv then bv=Instance.new("BodyVelocity") bv.Name="SpeedBV" bv.MaxForce=Vector3.new(100000,0,100000) bv.P=10000 bv.Parent=hrp end
		local d=getMoveDirection() bv.Velocity=d.Magnitude>0 and d*CFG.speed or Vector3.zero bv.MaxForce=d.Magnitude>0 and Vector3.new(100000,0,100000) or Vector3.zero
	end
end

local function applyJump()
	local char=player.Character if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	if CFG.jumpMethod=="Default" then hum.UseJumpPower=true hum.JumpPower=CFG.jumpPower
	else hum.JumpPower=0 if CFG.isJumping and CFG.canJump then CFG.canJump=false
		if CFG.jumpMethod=="CFrame Bypass" then hrp.CFrame=hrp.CFrame+Vector3.new(0,CFG.jumpPower/50,0)
		elseif CFG.jumpMethod=="Velocity Bypass" then hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X,CFG.jumpPower,hrp.AssemblyLinearVelocity.Z)
		elseif CFG.jumpMethod=="BodyVelocity Bypass" then
			local bv=Instance.new("BodyVelocity") bv.MaxForce=Vector3.new(0,100000,0) bv.Velocity=Vector3.new(0,CFG.jumpPower,0) bv.Parent=hrp
			task.delay(0.15,function() if bv.Parent then bv:Destroy() end end) end
		task.delay(0.3,function() CFG.canJump=true end) end end
end

local function applyNoFall()
	local char=player.Character if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false) hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
	local vel=hrp.AssemblyLinearVelocity
	if CFG.noFallMethod=="Default" then if vel.Y<-50 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-10,vel.Z) end
	elseif CFG.noFallMethod=="Velocity Brake" then if vel.Y<-50 and getGroundInfo()<20 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-10,vel.Z) end
	elseif CFG.noFallMethod=="Health Restore" then
		if vel.Y<-20 then CFG.wasInAir=true CFG.lastHealth=hum.Health end
		if CFG.wasInAir and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<CFG.lastHealth then hum.Health=CFG.lastHealth end CFG.wasInAir=false end
	elseif CFG.noFallMethod=="Hybrid" then
		if vel.Y<-20 and not CFG.isFalling then CFG.isFalling=true CFG.lastHealth=hum.Health end
		if vel.Y<-80 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-30,vel.Z) end
		if CFG.isFalling and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<CFG.lastHealth then hum.Health=CFG.lastHealth end CFG.isFalling=false end
	end
end

