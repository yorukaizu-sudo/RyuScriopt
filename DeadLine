-- ==========================================
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	local isAK = false
	if typeof(CFG.aimlockKey)=="EnumItem" then
		if CFG.aimlockKey.EnumType==Enum.UserInputType then isAK=input.UserInputType==CFG.aimlockKey
		elseif CFG.aimlockKey.EnumType==Enum.KeyCode then isAK=input.KeyCode==CFG.aimlockKey end
	end
	if isAK then CFG.aimlockHeld=true if CFG.aimlockEnabled then CFG.aimlockTarget=getClosestInFOV() end end
	if input.KeyCode==Enum.KeyCode.Space and CFG.jumpMethod~="Default" then CFG.isJumping=true task.delay(0.15,function() CFG.isJumping=false end) end
end)

UserInputService.InputEnded:Connect(function(input)
	local isAK = false
	if typeof(CFG.aimlockKey)=="EnumItem" then
		if CFG.aimlockKey.EnumType==Enum.UserInputType then isAK=input.UserInputType==CFG.aimlockKey
		elseif CFG.aimlockKey.EnumType==Enum.KeyCode then isAK=input.KeyCode==CFG.aimlockKey end
	end
	if isAK then CFG.aimlockHeld=false end
end)

UserInputService.JumpRequest:Connect(function()
	local hum=player.Character and player.Character:FindFirstChildOfClass("Humanoid") if not hum then return end
	if _G.InfiniteJump then
		if CFG.jumpMethod=="Default" then hum:ChangeState(Enum.HumanoidStateType.Jumping)
		else CFG.isJumping=true task.delay(0.1,function() CFG.isJumping=false end) end
	elseif hum.FloorMaterial~=Enum.Material.Air then CFG.isJumping=true task.delay(0.1,function() CFG.isJumping=false end) end
end)

-- ==========================================
-- CHARACTER ADDED
-- ==========================================
player.CharacterAdded:Connect(function(char)
	local hum=char:WaitForChild("Humanoid",10)
	if hum then CFG.lastHealth=hum.Health CFG.isFalling=false CFG.wasInAir=false end
	for _,pd in pairs(CFG.antiHitboxParts) do pcall(function() pd.fakePart:Destroy() end) end
	CFG.antiHitboxParts={}
	CFG.noRecoilOverriddenObjects={} CFG.noRecoilCurrentTool=nil CFG.noRecoilIsShooting=false CFG.noRecoilLockedCFrame=nil
	if CFG.noRecoilEnabled or CFG.noSpreadEnabled then
		task.wait(0.5)
		if char and char.Parent then setupToolListener(char) end
	end
	-- Re-detect Deadline on respawn
	if DEADLINE.isDeadline then
		task.wait(1)
		detectDeadline()
	end
end)

-- ==========================================
-- MAIN LOOP
-- ==========================================
RunService.RenderStepped:Connect(function(dt)
	local char=player.Character if not char then return end local now=tick()

	if CFG.noclip then applyNoclip() end
	applySpeed(dt) applyJump()
	if CFG.noFallDamage then applyNoFall() end
	if (CFG.noRecoilEnabled or CFG.noSpreadEnabled) and CFG.noRecoilCameraLock then applyNoRecoilCameraLock() end

	-- Aimlock (Updated for Deadline)
	if CFG.aimlockEnabled and CFG.aimlockHeld then
		if CFG.autoSwitchTarget and not isTargetValid(CFG.aimlockTarget) then CFG.aimlockTarget=getClosestInFOV() end
		if CFG.aimlockTarget then
			local tChar = getCharacterModel(CFG.aimlockTarget)
			if tChar and isAlive(tChar) then
				local tp=getBodyPart(tChar, CFG.aimlockPart) or getRootPart(tChar)
				if tp then
					local myChar = getCharacterModel(player)
					local myHrp = myChar and getRootPart(myChar)
					if myHrp and (myHrp.Position-tp.Position).Magnitude<=CFG.aimlockDistance then
						camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tp.Position),CFG.aimlockSmooth)
					else CFG.aimlockTarget=CFG.autoSwitchTarget and getClosestInFOV() or nil end
				else CFG.aimlockTarget=CFG.autoSwitchTarget and getClosestInFOV() or nil end
			else CFG.aimlockTarget=CFG.autoSwitchTarget and getClosestInFOV() or nil end
		end
	end

	if CFG.aimAssistEnabled then applyAimAssist(dt) end

	-- FOV Circles
	local cx,cy = camera.ViewportSize.X/2, camera.ViewportSize.Y/2
	if CFG.fovCircle then CFG.fovCircle.Position=Vector2.new(cx,cy) CFG.fovCircle.Radius=CFG.aimlockFOV CFG.fovCircle.Visible=CFG.showFOVCircle and CFG.aimlockEnabled end
	if CFG.aimAssistFOVCircle then CFG.aimAssistFOVCircle.Position=Vector2.new(cx,cy) CFG.aimAssistFOVCircle.Radius=CFG.aimAssistFOV CFG.aimAssistFOVCircle.Visible=CFG.showAimAssistFOV and CFG.aimAssistEnabled end
	if CFG.silentAimFOVCircle then CFG.silentAimFOVCircle.Position=Vector2.new(cx,cy) CFG.silentAimFOVCircle.Radius=CFG.silentAimFOV CFG.silentAimFOVCircle.Visible=CFG.silentAimShowFOV and CFG.silentAimEnabled end

	-- No Recoil
	if now-CFG.lastNoRecoilUpdate >= CFG.NORECOIL_RATE then
		CFG.lastNoRecoilUpdate=now
		if (CFG.noRecoilEnabled or CFG.noSpreadEnabled) and CFG.noRecoilValueOverride then refreshRecoilOverrides() end
		if CFG.noRecoilEnabled then overrideRecoilPhysics() end
	end

	-- Silent Aim Visual
	if now-CFG.lastSilentAimUpdate >= CFG.SILENT_RATE then
		CFG.lastSilentAimUpdate=now
		if CFG.silentAimEnabled then
			local t, tp = getSilentAimTarget()
			CFG.silentAimCurrentTarget = t
			if CFG.silentAimVisualLine and t and tp and CFG.silentAimVisualLineObj then
				local sp, onS = camera:WorldToViewportPoint(tp.Position)
				if onS then
					CFG.silentAimVisualLineObj.From=Vector2.new(cx,cy)
					CFG.silentAimVisualLineObj.To=Vector2.new(sp.X,sp.Y)
					CFG.silentAimVisualLineObj.Visible=true
					CFG.silentAimVisualLineObj.Color=tp.Name=="Head" and Color3.fromRGB(255,50,50) or Color3.fromRGB(255,0,255)
				else CFG.silentAimVisualLineObj.Visible=false end
			elseif CFG.silentAimVisualLineObj then CFG.silentAimVisualLineObj.Visible=false end
		elseif CFG.silentAimVisualLineObj then CFG.silentAimVisualLineObj.Visible=false end
	end

	-- Wallbang Visual
	if now-CFG.lastWallbangUpdate >= CFG.WALLBANG_RATE then
		CFG.lastWallbangUpdate=now
		if CFG.wallbangEnabled and CFG.wallbangVisual then applyWallbangVisual() end
	end

	-- ESP
	if now-CFG.lastESPUpdate >= CFG.ESP_RATE then CFG.lastESPUpdate=now if CFG.espEnabled then updatePlayerESP() end end

	-- Hitbox
	if now-CFG.lastHitboxUpdate >= CFG.HITBOX_RATE then
		CFG.lastHitboxUpdate=now
		if CFG.hitboxEnabled then updateHitboxExpander() end
		if CFG.antiHitboxEnabled then updateAntiHitbox() end
	end
end)

-- Cleanup
Players.PlayerRemoving:Connect(function(p)
	if CFG.espObjects[p] then
		local d=CFG.espObjects[p]
		pcall(function() d.box:Remove() end) pcall(function() d.line:Remove() end)
		pcall(function() d.name:Remove() end) pcall(function() d.distText:Remove() end)
		pcall(function() d.healthText:Remove() end) pcall(function() d.healthBar:Remove() end)
		pcall(function() d.healthBg:Remove() end)
		if d.highlight then pcall(function() d.highlight:Destroy() end) end
		CFG.espObjects[p]=nil
	end
	if CFG.hitboxData[p] then cleanHitboxForPlayer(p) CFG.hitboxData[p]=nil end
end)

task.spawn(function()
	task.wait(1)
	if player.Character and (CFG.noRecoilEnabled or CFG.noSpreadEnabled) then setupToolListener(player.Character) end
end)

-- Monitor for character folder changes (Deadline specific)
if DEADLINE.isDeadline then
	task.spawn(function()
		while true do
			task.wait(2)
			if not DEADLINE.characterFolder or not DEADLINE.characterFolder.Parent then
				detectDeadline()
			end
		end
	end)
end

