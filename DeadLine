	end
	return closest
end

local function isTargetValid(t)
	if not t then return false end
	local char = getCharacterModel(t)
	if not char or not isAlive(char) then return false end
	local tp=getBodyPart(char, CFG.aimlockPart) or getRootPart(char)
	if not tp then return false end
	local myChar = getCharacterModel(player)
	local myHrp = myChar and getRootPart(myChar)
	return myHrp and (myHrp.Position-tp.Position).Magnitude<=CFG.aimlockDistance
end

