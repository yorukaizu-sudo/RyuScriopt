-- ==================== TROLL CARRY SYSTEM ====================

local function getCarryRemote()
    local success, result = pcall(function()
        return ReplicatedStorage.CarryReplic.CarryRemotes.CarryRemote
    end)
    return success and result or nil
end

local function getCarryChoice()
    local success, result = pcall(function()
        return ReplicatedStorage.CarryReplic.CarryChoices.Hug
    end)
    return success and result or nil
end

local function startTrollCarry()
    if trollCarryLoop then
        pcall(function() task.cancel(trollCarryLoop) end)
    end

    trollCarryLoop = task.spawn(function()
        while trollCarryEnabled do
            pcall(function()
                local Event = getCarryRemote()
                local CarryChoice = getCarryChoice()

                if Event and CarryChoice then
                    if trollCarryTarget == "All Players" then
                        for _, player in pairs(Players:GetPlayers()) do
                            if player ~= LocalPlayer then
                                Event:FireServer({
                                    cmd = "Carry",
                                    carrychoicesss = CarryChoice,
                                    firstPlr = player
                                })
                                task.wait(0.1)
                            end
                        end
                    else
                        local target = Players:FindFirstChild(trollCarryTarget)
                        if target and target ~= LocalPlayer then
                            Event:FireServer({
                                cmd = "Carry",
                                carrychoicesss = CarryChoice,
                                firstPlr = target
                            })
                        end
                    end
                end
            end)
            task.wait(carrySpeed)
        end
    end)
end

local function stopTrollCarry()
    trollCarryEnabled = false
    if trollCarryLoop then
        pcall(function() task.cancel(trollCarryLoop) end)
        trollCarryLoop = nil
    end
end

local function getPlayerList()
    local list = {"All Players"}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(list, player.Name)
        end
    end
    return list
end

-- ==================== CORE FISHING FUNCTIONS ====================

local function getRod()
    local rod = LocalPlayer.Backpack:FindFirstChild(selectedRod) or
        (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(selectedRod))
    return rod
end

local function equipRod()
    local rod = LocalPlayer.Backpack:FindFirstChild(selectedRod)
    if rod and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:EquipTool(rod)
        end
    end
end

local function findMinigameGUI()
    for _, gui in pairs(LocalPlayer.PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") or gui:IsA("BillboardGui") then
            local bg = gui:FindFirstChild("Background", true)
            if bg then
                local filler = bg:FindFirstChild("Filler")
                local reel = bg:FindFirstChild("Reel")
                if filler and reel then
                    local progressBg = gui:FindFirstChild("ProgressBackground", true)
                    if progressBg then
                        return {
                            GUI = gui,
                            Background = bg,
                            Filler = filler,
                            Reel = reel,
                            ProgressFiller = progressBg:FindFirstChild("ProgressFiller")
                        }
                    end
                end
            end
        end
    end
    return nil
end

local function pressSpace()
    if not isHoldingInput then
        isHoldingInput = true
        VIM:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
    end
end

local function releaseSpace()
    if isHoldingInput then
        isHoldingInput = false
        VIM:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
    end
end

local function startAutoMinigameTracker()
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end

    renderConnection = RunService.RenderStepped:Connect(function()
        if not autoMinigame then
            releaseSpace()
            return
        end

        local mgui = findMinigameGUI()
        if not mgui then
            releaseSpace()
            return
        end

        local filler = mgui.Filler
        local reel = mgui.Reel

        if not filler or not reel then
            releaseSpace()
            return
        end

        if not filler.Parent or not reel.Parent then
            releaseSpace()
            return
        end

        local fillerPos = filler.Position.X.Scale
        local fillerSize = filler.Size.X.Scale
        local fillerCenter = fillerPos + (fillerSize / 2)

        local reelPos = reel.Position.X.Scale
        local reelSize = reel.Size.X.Scale
        local reelCenter = reelPos + (reelSize / 2)

        local offset = 0.02

        if reelCenter < fillerCenter - offset then
            pressSpace()
        elseif reelCenter > fillerCenter + offset then
            releaseSpace()
        else
            if reelCenter < fillerCenter then
                pressSpace()
            else
                releaseSpace()
            end
        end
    end)
end

local function castRod()
    local rod = getRod()
    if rod and rod.Parent == LocalPlayer.Character then
        local isFishing = rod:FindFirstChild("IsFishingOrMinigameActive")
        if isFishing and not isFishing.Value then
            rod:Activate()
            task.wait(1.0 + math.random() * 0.8)
            rod:Deactivate()
        end
    end
end

local function setupMinigameListener()
    if minigameConnection then
        minigameConnection:Disconnect()
        minigameConnection = nil
    end

    local rod = getRod()
    if not rod then return end

    local miniGame = rod:FindFirstChild("MiniGame")
    if not miniGame then return end

    minigameConnection = miniGame.OnClientEvent:Connect(function(action, rarity)
        if action == "Start" and autoMinigame then
            Notification.new({
                Title = "🐟 Fish Hooked!",
                Description = "Rarity: " .. tostring(rarity),
                Duration = 3,
                Icon = "rbxassetid://8997385628"
            })
            task.wait(0.3)
            startAutoMinigameTracker()
        end
    end)
end

local function startFishingLoop()
    if fishingLoop then
        pcall(function() task.cancel(fishingLoop) end)
    end

    fishingLoop = task.spawn(function()
        while autoFishing do
            pcall(function()
                local rod = getRod()

                if rod and rod.Parent == LocalPlayer.Backpack then
                    equipRod()
                    task.wait(0.5)
                end

                rod = getRod()
                if rod and rod.Parent == LocalPlayer.Character then
                    local isFishing = rod:FindFirstChild("IsFishingOrMinigameActive")
                    if isFishing and not isFishing.Value then
                        castRod()
                    end
                end
            end)

            task.wait(3 + math.random() * 2)
        end
    end)
end

local function getRodList()
    local rods = {}
    for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
        if item:IsA("Tool") and item:FindFirstChild("MiniGame") then
            table.insert(rods, item.Name)
        end
    end
    if LocalPlayer.Character then
        for _, item in pairs(LocalPlayer.Character:GetChildren()) do
            if item:IsA("Tool") and item:FindFirstChild("MiniGame") then
                if not table.find(rods, item.Name) then
                    table.insert(rods, item.Name)
                end
            end
        end
    end
    if #rods == 0 then
        table.insert(rods, "Basic Rod")
    end
    return rods
end

