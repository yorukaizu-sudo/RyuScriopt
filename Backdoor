local function grabWorkspaceTools()
	addLog("Grabbing tools from all accessible locations...", "info")
	local char = player.Character
	local count = 0
	local seen = {}

	local function tryGrab(source, sourceName)
		pcall(function()
			for _, desc in ipairs(source:GetDescendants()) do
				pcall(function()
					if desc:IsA("Tool") and not seen[desc.Name] then
						-- Try direct parent
						pcall(function()
							desc.Parent = backpack
							count = count + 1
							seen[desc.Name] = true
							addLog("Grabbed: " .. desc.Name .. " from " .. sourceName, "success")
						end)

						-- Try clone if direct fails
						if not seen[desc.Name] then
							pcall(function()
								local clone = desc:Clone()
								clone.Parent = backpack
								count = count + 1
								seen[desc.Name] = true
								addLog("Cloned: " .. desc.Name .. " from " .. sourceName, "success")
							end)
						end
					end

					-- Try click detectors
					if desc:IsA("ClickDetector") then
						pcall(function()
							if fireclickdetector then
								fireclickdetector(desc)
							end
						end)
					end

					-- Try proximity prompts
					if desc:IsA("ProximityPrompt") then
						pcall(function()
							if fireproximityprompt then
								fireproximityprompt(desc)
							end
						end)
					end

					-- Try touch interests (simulate touching)
					if desc:IsA("TouchTransmitter") and char and char:FindFirstChild("HumanoidRootPart") then
						pcall(function()
							if firetouchinterest then
								firetouchinterest(char.HumanoidRootPart, desc.Parent, 0)
								task.wait(0.1)
								firetouchinterest(char.HumanoidRootPart, desc.Parent, 1)
							end
						end)
					end
				end)
			end
		end)
	end

	tryGrab(Workspace, "Workspace")
	tryGrab(ReplicatedStorage, "ReplicatedStorage")
	pcall(function() tryGrab(ReplicatedFirst, "ReplicatedFirst") end)
	tryGrab(Lighting, "Lighting")
	tryGrab(StarterPack, "StarterPack")
	pcall(function() tryGrab(StarterGui, "StarterGui") end)
	pcall(function() tryGrab(StarterPlayer, "StarterPlayer") end)
	pcall(function() tryGrab(SoundService, "SoundService") end)

	-- Try nil instances
	pcall(function()
		if getnilinstances then
			for _, inst in ipairs(getnilinstances()) do
				if inst:IsA("Tool") and not seen[inst.Name] then
					pcall(function()
						local clone = inst:Clone()
						clone.Parent = backpack
						count = count + 1
						seen[inst.Name] = true
						addLog("Grabbed nil: " .. inst.Name, "success")
					end)
				end
			end
		end
	end)

	addLog(string.format("Grabbed %d tools from all sources", count), count > 0 and "success" or "info")
end

-- ==========================================
-- ENHANCED REMOTE SPY v3
-- ==========================================
local remoteSpyEnabled = false
local spyConnection = nil
local spyHookInstalled = false

local function startRemoteSpy()
	if spyHookInstalled then
		remoteSpyEnabled = true
		addLog("Remote Spy re-enabled!", "info")
		return
	end

	remoteSpyEnabled = true
	addLog("Remote Spy starting...", "info")

	-- Method 1: Metatable hook
	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then return end
		local oldNC = mt.__namecall
		local oldIdx = mt.__index
		setreadonly(mt, false)

		mt.__namecall = newcclosure(function(self, ...)
			local method = getnamecallmethod()
			if remoteSpyEnabled then
				if (method == "FireServer" or method == "InvokeServer") and
				   (self:IsA("RemoteEvent") or self:IsA("RemoteFunction")) then
					local args = {...}
					local argParts = {}
					for i, arg in ipairs(args) do
						local argStr = typeof(arg) .. ":"
						if typeof(arg) == "Instance" then
							argStr = argStr .. arg.ClassName .. ":" .. arg.Name
						elseif typeof(arg) == "table" then
							local tParts = {}
							pcall(function()
								for k, v in pairs(arg) do
									table.insert(tParts, tostring(k) .. "=" .. tostring(v):sub(1, 30))
									if #tParts > 5 then break end
								end
							end)
							argStr = argStr .. "{" .. table.concat(tParts, ",") .. "}"
						else
							argStr = argStr .. tostring(arg):sub(1, 50)
						end
						table.insert(argParts, argStr)
					end

					local entry = {
						time = os.clock(),
						remote = self.Name,
						path = getRemotePath(self),
						method = method,
						args = table.concat(argParts, " | "),
						argCount = #args,
						rawArgs = args,
						className = self.ClassName,
					}
					table.insert(spyLog, entry)
					if #spyLog > 500 then table.remove(spyLog, 1) end

					addLog(string.format("[SPY] %s -> %s(%s)",
						method, self.Name,
						table.concat(argParts, ", "):sub(1, 150)
					), "info")
				end
			end
			return oldNC(self, ...)
		end)

		setreadonly(mt, true)
		spyHookInstalled = true
		addLog("Remote Spy hook installed!", "success")
	end)

	-- Method 2: Connection-based monitoring (fallback)
	if not spyHookInstalled then
		addLog("Metatable hook failed, using connection-based spy...", "warning")

		-- Monitor known remotes
		collectAllRemotes()
		-- Note: Connection-based spy is limited compared to metatable hook
		addLog("Connection-based spy active (limited functionality)", "warning")
	end
end

