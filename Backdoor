-- SCAN MODES
-- ==========================================
local function ultraScan()
	if isScanning then addLog("Already scanning!", "warning") return end
	isScanning = true
	totalScanned = 0 totalVulnerable = 0 totalErrors = 0 totalItems = 0 totalResponses = 0
	vulnerableRemotes = {} responseLog = {} successfulArgs = {}

	addLog("╔══════════════════════════════════════╗", "info")
	addLog("║    ULTRA SCAN - MAXIMUM POWER        ║", "info")
	addLog("╚══════════════════════════════════════╝", "info")

	collectEverything()

	-- Sort by priority (give/item/admin first)
	local prioritized = {}
	for _, re in ipairs(allRemoteEvents) do
		if not isValid(re) then continue end
		local p = 0
		if hasKeyword(re.Name, GIVE_KW) then p = p + 5 end
		if hasKeyword(re.Name, ITEM_KW) then p = p + 3 end
		if hasKeyword(re.Name, ADMIN_KW) then p = p + 10 end
		if hasKeyword(re.Name, BACKPACK_KW) then p = p + 4 end
		if isDangerous(re.Name) then p = p - 20 end
		-- Short/suspicious names get priority
		if #re.Name <= 3 then p = p + 7 end
		if re.Name:match("^[%d]+$") then p = p + 5 end
		table.insert(prioritized, {remote = re, priority = p, isEvent = true})
	end
	for _, rf in ipairs(allRemoteFunctions) do
		if not isValid(rf) then continue end
		local p = 0
		if hasKeyword(rf.Name, GIVE_KW) then p = p + 5 end
		if hasKeyword(rf.Name, ITEM_KW) then p = p + 3 end
		if hasKeyword(rf.Name, ADMIN_KW) then p = p + 10 end
		if hasKeyword(rf.Name, BACKPACK_KW) then p = p + 4 end
		if isDangerous(rf.Name) then p = p - 20 end
		if #rf.Name <= 3 then p = p + 7 end
		table.insert(prioritized, {remote = rf, priority = p, isEvent = false})
	end

	table.sort(prioritized, function(a, b) return a.priority > b.priority end)

	scanTotal = #prioritized
	scanProgress = 0

	for idx, entry in ipairs(prioritized) do
		if not isScanning then addLog("SCAN CANCELLED!", "warning") break end

		scanProgress = idx
		local remote = entry.remote
		if not isValid(remote) then continue end

		-- Skip dangerous in safe mode
		if safeMode and entry.priority < -10 then continue end

		-- Generate args based on priority
		local testArgs
		if entry.priority >= 5 then
			-- High priority: use mega args + smart args
			testArgs = generateMegaArgs(remote.Name, remote)
			local smartArgs = generateSmartArgs(remote.Name)
			for _, sa in ipairs(smartArgs) do table.insert(testArgs, sa) end
		elseif entry.priority >= 0 then
			-- Medium priority: basic args + some smart
			testArgs = generateSmartArgs(remote.Name)
			-- Add basic args
			for _, ba in ipairs({{}, {player}, {player.Name}, {true}, {1}, {999}, {"all"}, {player, "all"}, {player, 1}}) do
				table.insert(testArgs, 1, ba) -- prepend
			end
		else
			-- Low priority: minimal args
			testArgs = {{}, {player}, {true}, {1}, {"all"}}
		end

		-- Limit based on settings
		if not aggressiveMode and #testArgs > maxArgSets then
			local limited = {}
			for i = 1, maxArgSets do table.insert(limited, testArgs[i]) end
			testArgs = limited
		end

		local label = ""
		if entry.priority >= 10 then label = " ★★★ ADMIN"
		elseif entry.priority >= 5 then label = " ★★ HIGH"
		elseif entry.priority >= 0 then label = " ★ MED" end

		addLog(string.format("[%d/%d] %s %s (%d args)%s",
			idx, #prioritized, entry.isEvent and "RE" or "RF",
			getPath(remote), #testArgs, label), "info")

		for _, args in ipairs(testArgs) do
			if not isScanning then break end
			pcall(function()
				if entry.isEvent then
					fireRE(remote, args)
				else
					fireRF(remote, args)
				end
			end)
			task.wait(fireDelay)
		end

		task.wait(scanDelay)
	end

	addLog("╔══════════════════════════════════════╗", "success")
	addLog(string.format("║ DONE! Scanned:%d Vuln:%d Items:%d    ║", totalScanned, totalVulnerable, totalItems), "success")
	addLog("╚══════════════════════════════════════╝", "success")

	isScanning = false
end

