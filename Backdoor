-- BACKPACK MONITOR (Live)
-- ==========================================
local monitorConnection = nil
local monitorEnabled = false

local function startBackpackMonitor()
	if monitorConnection then return end
	monitorEnabled = true

	monitorConnection = backpack.ChildAdded:Connect(function(child)
		if monitorEnabled then
			addLog("📦 NEW ITEM IN BACKPACK: " .. child.Name .. " [" .. child.ClassName .. "]", "success")
			Rayfield:Notify({Title="New Item!", Content=child.Name .. " added to backpack!", Duration=3})
		end
	end)

	-- Also monitor character for equipped tools
	local char = player.Character
	if char then
		char.ChildAdded:Connect(function(child)
			if monitorEnabled and child:IsA("Tool") then
				addLog("🔧 TOOL EQUIPPED: " .. child.Name, "success")
			end
		end)
	end

	player.CharacterAdded:Connect(function(newChar)
		if monitorEnabled then
			newChar.ChildAdded:Connect(function(child)
				if monitorEnabled and child:IsA("Tool") then
					addLog("🔧 TOOL EQUIPPED: " .. child.Name, "success")
				end
			end)
		end
	end)
end

ReportTab:CreateSection("Monitoring")
ReportTab:CreateToggle({
	Name = "📦 Live Backpack Monitor",
	CurrentValue = false,
	Flag = "BPMonitor",
	Callback = function(V)
		if V then
			startBackpackMonitor()
			Rayfield:Notify({Title="Monitor", Content="Backpack monitor started!", Duration=3})
		else
			monitorEnabled = false
			if monitorConnection then
				monitorConnection:Disconnect()
				monitorConnection = nil
			end
		end
	end
})

ReportTab:CreateButton({
	Name = "📦 Show Current Backpack",
	Callback = function()
		local items = {}
		for _, item in ipairs(backpack:GetChildren()) do
			table.insert(items, item.Name .. " [" .. item.ClassName .. "]")
