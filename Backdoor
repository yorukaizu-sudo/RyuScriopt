	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") or item:IsA("Accessory") then
				characterBefore[item.Name .. "_" .. item.ClassName] = true
			end
		end
	end

	-- Snapshot leaderstats
	local ls = player:FindFirstChild("leaderstats")
	if ls then
		for _, stat in ipairs(ls:GetChildren()) do
			pcall(function()
				leaderstatsBeefore[stat.Name] = stat.Value
			end)
		end
	end

	-- Snapshot other value containers
	for _, child in ipairs(player:GetChildren()) do
		pcall(function()
			if child:IsA("Folder") or child:IsA("Configuration") then
				for _, val in ipairs(child:GetChildren()) do
					if val:IsA("ValueBase") then
						leaderstatsBeefore[child.Name .. "." .. val.Name] = val.Value
					end
				end
			end
		end)
	end
end

local function deepCheckChanges(remoteName)
