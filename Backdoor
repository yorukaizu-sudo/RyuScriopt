		-- Common codes
		for _, code in ipairs({"FREE","RELEASE","LAUNCH","UPDATE","100K","1M","REWARD","GIFT","SPECIAL","VIP","PREMIUM","BETA","ALPHA","TEST","DEBUG","ADMIN","OWNER","SECRET","HIDDEN","EASTER","EGG","BONUS","EXTRA","SUPER","MEGA","ULTRA","HYPER","MAX","OP","GOD","INFINITE"}) do
			table.insert(args, {code})
			table.insert(args, {code:lower()})
			table.insert(args, {player, code})
