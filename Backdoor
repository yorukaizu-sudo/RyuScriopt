-- REPLAY SYSTEM v3
-- ==========================================
local function replaySpyEntry(entry)
	if not entry then return end

	pcall(function()
		-- Find the remote
		local parts = string.split(entry.path, ".")
		local current = game
		for _, part in ipairs(parts) do
			current = current:FindFirstChild(part) or current[part]
		end

		if current and entry.rawArgs then
			deepSnapshot()
			if entry.method == "FireServer" and current:IsA("RemoteEvent") then
				current:FireServer(unpack(entry.rawArgs))
			elseif entry.method == "InvokeServer" and current:IsA("RemoteFunction") then
				local result = current:InvokeServer(unpack(entry.rawArgs))
				addLog("Replay response: " .. tostring(result):sub(1, 200), "info")
			end
			task.wait(0.2)
			local changes = deepCheckChanges("Replay:" .. entry.remote)
			if changes.hasChanges then
				addLog("Replay caused changes!", "vuln")
			end
		end
	end)
end

-- ==========================================
-- RE-FIRE VULNERABLE v3
-- ==========================================
local function refireVulnerable()
	if #vulnerableRemotes == 0 then
		addLog("No vulnerable remotes found yet!", "warning")
		return
	end

	addLog("Re-firing " .. #vulnerableRemotes .. " vulnerable remotes...", "info")

	for _, v in ipairs(vulnerableRemotes) do
		if isValidInstance(v.remote) then
			deepSnapshot()
			pcall(function()
				if v.remote:IsA("RemoteEvent") then
					if v.args and #v.args > 0 then
						v.remote:FireServer(unpack(v.args))
					else
						v.remote:FireServer()
						task.wait(0.05)
						v.remote:FireServer(player)
						task.wait(0.05)
						v.remote:FireServer(player, "all")
					end
				elseif v.remote:IsA("RemoteFunction") then
					if v.args and #v.args > 0 then
						v.remote:InvokeServer(unpack(v.args))
					else
						v.remote:InvokeServer()
						task.wait(0.05)
						v.remote:InvokeServer(player)
					end
				end
			end)
			task.wait(0.15)
			local changes = deepCheckChanges("ReFire:" .. v.name)
			if changes.hasChanges then
				addLog("Re-fire success on " .. v.name, "vuln")
			end
		end
	end
end

local function autoFarmVulnerable()
	addLog("Starting auto-farm on vulnerable remotes...", "info")
	while isScanning and #vulnerableRemotes > 0 do
		for _, v in ipairs(vulnerableRemotes) do
			if not isScanning then break end
			if isValidInstance(v.remote) then
				pcall(function()
					if v.remote:IsA("RemoteEvent") then
						if v.args and #v.args > 0 then
							v.remote:FireServer(unpack(v.args))
						else
							v.remote:FireServer(player)
						end
					elseif v.remote:IsA("RemoteFunction") then
						if v.args and #v.args > 0 then
							v.remote:InvokeServer(unpack(v.args))
						else
							v.remote:InvokeServer(player)
						end
					end
				end)
			end
			task.wait(fireDelay)
		end
		task.wait(1)
	end
	addLog("Auto-farm stopped", "info")
end

