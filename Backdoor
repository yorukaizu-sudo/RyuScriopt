local function addLog(msg, logType)
	local entry = {
		time = os.clock(),
		message = msg,
		type = logType or "info"
	}
	table.insert(scanLog, entry)
	if #scanLog > 2000 then table.remove(scanLog, 1) end

	if logType == "success" then
		print("[✓] " .. msg)
	elseif logType == "vuln" then
		warn("[!!!] VULNERABLE: " .. msg)
	elseif logType == "error" then
		warn("[✗] " .. msg)
	elseif logType == "warning" then
		warn("[⚠] " .. msg)
	elseif logType == "critical" then
		warn("[🔴 CRITICAL] " .. msg)
	elseif logType == "discovery" then
		print("[🔍] " .. msg)
	else
		print("[i] " .. msg)
	end
end

local function isValidInstance(obj)
	local ok, r = pcall(function() return obj and obj.Parent ~= nil and obj.Name end)
	return ok and r ~= nil
end

local function containsAnyKeyword(name, keywords)
	local nl = name:lower()
	local matches = {}
	for _, kw in ipairs(keywords) do
		if nl:find(kw:lower()) then
			table.insert(matches, kw)
		end
	end
	return #matches > 0, matches
end

local function getRemotePath(remote)
	local path = {}
	local current = remote
	local depth = 0
	while current and current ~= game and depth < 20 do
		table.insert(path, 1, current.Name)
		current = current.Parent
		depth = depth + 1
	end
	return table.concat(path, ".")
end

local function getRemoteDepth(remote)
	local depth = 0
	local current = remote
	while current and current ~= game do
		depth = depth + 1
		current = current.Parent
	end
	return depth
end

