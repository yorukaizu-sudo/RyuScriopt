-- ==========================================
-- RESPONSE ANALYZER v3
-- ==========================================
local function analyzeResponse(response, remoteName, args)
	if response == nil then return nil end

	local analysis = {
		type = typeof(response),
		interesting = false,
		details = {},
		raw = tostring(response):sub(1, 500)
	}

	if typeof(response) == "table" then
		local function analyzeTable(t, prefix, depth)
			if depth > 5 then return end
			for k, v in pairs(t) do
				local fullKey = prefix .. tostring(k)
				local kl = tostring(k):lower()
				local vl = tostring(v):lower()

				-- Check for interesting keys
				if containsAnyKeyword(kl, {"item","weapon","tool","reward","loot","drop","give","success","unlocked","obtained","granted"}) then
					analysis.interesting = true
					table.insert(analysis.details, {key = fullKey, value = tostring(v), reason = "interesting_key"})
				end

				-- Check for success indicators
				if kl:find("success") or kl:find("result") or kl:find("status") then
					if vl == "true" or vl == "success" or vl == "ok" or vl == "1" then
						analysis.interesting = true
						table.insert(analysis.details, {key = fullKey, value = tostring(v), reason = "success_indicator"})
					end
				end

				-- Check for item data
				if typeof(v) == "Instance" and (v:IsA("Tool") or v:IsA("Model")) then
					analysis.interesting = true
					table.insert(analysis.details, {key = fullKey, value = v.Name, reason = "instance_ref"})
				end

				-- Recurse into sub-tables
				if type(v) == "table" then
					analyzeTable(v, fullKey .. ".", depth + 1)
				end
			end
		end

		analyzeTable(response, "", 0)
	elseif typeof(response) == "boolean" then
		if response == true then
			analysis.interesting = true
			table.insert(analysis.details, {key = "return", value = "true", reason = "success_bool"})
		end
	elseif typeof(response) == "string" then
		local rl = response:lower()
		if rl:find("success") or rl:find("granted") or rl:find("given") or rl:find("unlocked") or rl:find("obtained") then
			analysis.interesting = true
			table.insert(analysis.details, {key = "return", value = response:sub(1, 200), reason = "success_string"})
		end
	elseif typeof(response) == "Instance" then
		if response:IsA("Tool") or response:IsA("Model") then
			analysis.interesting = true
			table.insert(analysis.details, {key = "return", value = response.Name, reason = "instance_return"})
		end
	end

	if analysis.interesting then
		addLog(string.format("Interesting response from %s: %s",
			remoteName, analysis.raw:sub(1, 150)), "discovery")
	end

	return analysis
end

