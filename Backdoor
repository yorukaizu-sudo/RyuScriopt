	report = report .. "BindableFunctions: " .. #bindableFunctions .. "\n"
	report = report .. "Hidden/Obfuscated: " .. #hiddenRemotes .. "\n"
	report = report .. "ModuleScripts: " .. #moduleScripts .. "\n\n"

	report = report .. "═══ SCAN RESULTS ═══\n"
	report = report .. "Total Scanned: " .. totalScanned .. "\n"
	report = report .. "Vulnerable: " .. totalVulnerable .. "\n"
	report = report .. "Errors: " .. totalErrors .. "\n"
	report = report .. "Items Obtained: " .. totalItems .. "\n"
	report = report .. "Responses Analyzed: " .. totalResponses .. "\n\n"

	if #vulnerableRemotes > 0 then
		report = report .. "═══ VULNERABLE REMOTES ═══\n"
		for i, v in ipairs(vulnerableRemotes) do
			report = report .. string.format("%d. %s\n   Path: %s\n   Class: %s\n",
				i, v.name, v.path, v.className or "?")

			if v.items and #v.items > 0 then
				local names = {}
				for _, item in ipairs(v.items) do table.insert(names, item.name) end
				report = report .. "   Items: " .. table.concat(names, ", ") .. "\n"
			end
			if v.charItems and #v.charItems > 0 then
				local names = {}
				for _, item in ipairs(v.charItems) do table.insert(names, item.name) end
				report = report .. "   Char Items: " .. table.concat(names, ", ") .. "\n"
			end
			if v.statChanges and #v.statChanges > 0 then
				local stats = {}
				for _, s in ipairs(v.statChanges) do
					table.insert(stats, s.name .. ": " .. tostring(s.oldValue) .. " -> " .. tostring(s.newValue))
				end
				report = report .. "   Stat Changes: " .. table.concat(stats, ", ") .. "\n"
			end
			if v.argTypes then
				report = report .. "   Arg Types: " .. table.concat(v.argTypes, ", ") .. "\n"
			end
			report = report .. "\n"
		end
	end

	if #itemsObtained > 0 then
		report = report .. "═══ ITEMS OBTAINED ═══\n"
		for i, item in ipairs(itemsObtained) do
			report = report .. string.format("%d. %s [%s] from %s (source: %s)\n",
				i, item.name, item.className, item.remote, item.source or "?")
		end
		report = report .. "\n"
	end

	if #hiddenRemotes > 0 then
		report = report .. "═══ HIDDEN/OBFUSCATED REMOTES ═══\n"
		for i, h in ipairs(hiddenRemotes) do
			report = report .. string.format("%d. %s [%s] type=%s depth=%d\n",
				i, h.path, h.className, h.obfuscationType, h.depth)
		end
		report = report .. "\n"
	end

	-- Interesting module scripts
	local interestingModules = {}
	for _, m in ipairs(moduleLog) do
		if m.interesting then table.insert(interestingModules, m) end
	end
	if #interestingModules > 0 then
		report = report .. "═══ INTERESTING MODULES ═══\n"
		for i, m in ipairs(interestingModules) do
			report = report .. string.format("%d. %s (%s)\n", i, m.name, m.path)
			if #m.functions > 0 then
				report = report .. "   Functions: " .. table.concat(m.functions, ", "):sub(1, 200) .. "\n"
			end
			if #m.remoteRefs > 0 then
				for _, ref in ipairs(m.remoteRefs) do
					report = report .. string.format("   Remote Ref: %s -> %s\n", ref.key, ref.remotePath)
				end
			end
		end
		report = report .. "\n"
	end

	-- Interesting responses
	local interestingResponses = {}
	for _, r in ipairs(responseLog) do
		if r.interesting then table.insert(interestingResponses, r) end
	end
	if #interestingResponses > 0 then
		report = report .. "═══ INTERESTING RESPONSES ═══\n"
		for i, r in ipairs(interestingResponses) do
			if i > 30 then break end
			report = report .. string.format("%s: %s\n", r.remote, r.response:sub(1, 200))
		end
		report = report .. "\n"
	end

	-- All remote events list
	report = report .. "═══ ALL REMOTE EVENTS ═══\n"
	for i, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			local tags = {}
			if info.isGiveRelated then table.insert(tags, "GIVE") end
			if info.isItemRelated then table.insert(tags, "ITEM") end
			if info.isAdminRelated then table.insert(tags, "ADMIN") end
			if info.isDangerous then table.insert(tags, "DANGER") end
			if info.isObfuscated then table.insert(tags, "OBF") end
			report = report .. string.format("%d. %s [%s] p=%d\n",
				i, getRemotePath(re), table.concat(tags, ","), info.priority)
		end
	end

	report = report .. "\n═══ ALL REMOTE FUNCTIONS ═══\n"
	for i, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			local tags = {}
			if info.isGiveRelated then table.insert(tags, "GIVE") end
			if info.isItemRelated then table.insert(tags, "ITEM") end
			if info.isAdminRelated then table.insert(tags, "ADMIN") end
			if info.isObfuscated then table.insert(tags, "OBF") end
			report = report .. string.format("%d. %s [%s] p=%d\n",
				i, getRemotePath(rf), table.concat(tags, ","), info.priority)
		end
	end

	-- Spy log summary
	if #spyLog > 0 then
		report = report .. "\n═══ SPY LOG SUMMARY ═══\n"
		local remoteCounts = {}
		for _, entry in ipairs(spyLog) do
			remoteCounts[entry.remote] = (remoteCounts[entry.remote] or 0) + 1
		end
		local sorted = {}
		for name, count in pairs(remoteCounts) do
			table.insert(sorted, {name = name, count = count})
		end
		table.sort(sorted, function(a, b) return a.count > b.count end)
		for i, s in ipairs(sorted) do
			if i > 30 then break end
			report = report .. string.format("%d. %s: %d calls\n", i, s.name, s.count)
		end
	end

	return report
end

