local function generateSmartArgs(remoteName)
	local args = {}
	local nl = remoteName:lower()

	-- Buy/Purchase pattern
	if nl:find("buy") or nl:find("purchase") or nl:find("shop") or nl:find("store") then
		for i = 1, 50 do
			table.insert(args, {i})
			table.insert(args, {tostring(i)})
