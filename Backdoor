local function addLog(msg, logType)
	local entry = {time = os.clock(), message = msg, type = logType or "info"}
	table.insert(scanLog, entry)
	if #scanLog > 2000 then table.remove(scanLog, 1) end
	if logType == "vuln" then warn("[!!!VULN!!!] " .. msg)
	elseif logType == "success" then print("[✓] " .. msg)
	elseif logType == "error" then -- silent
	elseif logType == "warning" then warn("[⚠] " .. msg)
	else print("[i] " .. msg) end
end

local function isValid(obj)
	local ok, r = pcall(function() return obj and obj.Parent ~= nil end)
	return ok and r
end

local function getPath(obj)
	local p = {} local c = obj
	while c and c ~= game do table.insert(p, 1, c.Name) c = c.Parent end
	return table.concat(p, ".")
end

local function hasKeyword(name, keywords)
	local nl = name:lower()
	for _, kw in ipairs(keywords) do if nl:find(kw:lower()) then return true, kw end end
	return false, nil
end

local function isDangerous(name)
	return hasKeyword(name, DANGER_KW)
end

