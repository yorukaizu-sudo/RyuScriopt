			table.insert(args, {{itemId = i}})
			table.insert(args, {{id = i, amount = 999}})
			table.insert(args, {{ItemId = i, Quantity = 999}})
		end
	end

	-- Equip pattern
	if nl:find("equip") or nl:find("wear") or nl:find("use") or nl:find("select") then
		for i = 1, 50 do
			table.insert(args, {i})
			table.insert(args, {tostring(i)})
			table.insert(args, {"equip", i})
			table.insert(args, {player, i})
		end
		for _, name in ipairs(ITEM_NAMES) do
