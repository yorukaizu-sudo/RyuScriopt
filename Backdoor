-- REMOTE SPY
-- ==========================================
local spyLog = {}
local spyHooked = false

local function startSpy()
	if spyHooked then return end
	spyEnabled = true
	spyHooked = true

	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then addLog("No metatable access for spy", "warning") return end
		local oldNC = mt.__namecall
		setreadonly(mt, false)
		mt.__namecall = newcclosure(function(self, ...)
			local method = getnamecallmethod()
			if spyEnabled and (method == "FireServer" or method == "InvokeServer") then
				if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
					local args = {...}
					local argParts = {}
					for i, arg in ipairs(args) do
						table.insert(argParts, typeof(arg) .. ":" .. tostring(arg):sub(1, 60))
					end
					local entry = {
						time = os.clock(), remote = self.Name, path = getPath(self),
						method = method, args = table.concat(argParts, " | "), argCount = #args,
						rawArgs = args
					}
					table.insert(spyLog, entry)
					if #spyLog > 500 then table.remove(spyLog, 1) end
					addLog(string.format("[SPY] %s -> %s(%s)", method, self.Name, table.concat(argParts, ", "):sub(1, 120)), "info")
				end
			end
			return oldNC(self, ...)
		end)
		setreadonly(mt, true)
	end)

	addLog("🕵️ Remote Spy ACTIVE!", "success")
end

local function replaySpy(index)
	if index > #spyLog then return end
	local entry = spyLog[index]
	addLog("Replaying: " .. entry.remote .. " with " .. entry.argCount .. " args", "info")

	-- Find the remote
	local remote = nil
	pcall(function()
		local parts = string.split(entry.path, ".")
		local current = game
		for _, part in ipairs(parts) do
			current = current:FindFirstChild(part)
			if not current then break end
		end
		remote = current
	end)

	if not remote or not isValid(remote) then
		addLog("Remote not found: " .. entry.path, "error")
		return
	end

	deepSnapshotBackpack()
	pcall(function()
		if entry.method == "FireServer" then
			remote:FireServer(unpack(entry.rawArgs))
		else
			remote:InvokeServer(unpack(entry.rawArgs))
		end
	end)
	task.wait(0.2)
	local items = checkNewItems(remote.Name)
	if #items > 0 then
		addLog("Replay got items: " .. table.concat(items, ", "), "vuln")
	end
end

