local function parseCustomArgs(str)
	local args = {}
	if str == "" then return args end
	for _, raw in ipairs(string.split(str, ",")) do
		local t = raw:match("^%s*(.-)%s*$")
		if t == "player" then table.insert(args, player)
		elseif t == "true" then table.insert(args, true)
		elseif t == "false" then table.insert(args, false)
		elseif t == "nil" then table.insert(args, nil)
		elseif t == "backpack" then table.insert(args, backpack)
		elseif t == "character" or t == "char" then table.insert(args, player.Character)
		elseif t == "hrp" then table.insert(args, player.Character and player.Character:FindFirstChild("HumanoidRootPart"))
		elseif t == "head" then table.insert(args, player.Character and player.Character:FindFirstChild("Head"))
		elseif t == "userId" then table.insert(args, player.UserId)
		elseif t == "name" then table.insert(args, player.Name)
		elseif t == "inf" or t == "math.huge" then table.insert(args, math.huge)
		elseif tonumber(t) then table.insert(args, tonumber(t))
		else table.insert(args, t) end
	end
	return args
end

local function findRemote(path)
	local parts = string.split(path, ".")
	local current = game
	for _, part in ipairs(parts) do
		pcall(function() current = current:FindFirstChild(part) or current[part] end)
	end
	return current
end

