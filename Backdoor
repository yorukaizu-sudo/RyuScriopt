						className = item.ClassName,
						remote = remoteName,
						time = os.clock(),
						source = "character"
					})
				end
			end
		end
	end

	-- Check stat changes
	local ls = player:FindFirstChild("leaderstats")
	if ls then
		for _, stat in ipairs(ls:GetChildren()) do
			pcall(function()
				local oldVal = leaderstatsBeefore[stat.Name]
				if oldVal ~= nil and stat.Value ~= oldVal then
					table.insert(changes.statChanges, {
						name = stat.Name,
						oldValue = oldVal,
						newValue = stat.Value,
						diff = (type(stat.Value) == "number" and type(oldVal) == "number") and (stat.Value - oldVal) or "changed"
					})
					changes.hasChanges = true
				end
			end)
		end
	end

	-- Check other value containers
	for _, child in ipairs(player:GetChildren()) do
		pcall(function()
			if child:IsA("Folder") or child:IsA("Configuration") then
				for _, val in ipairs(child:GetChildren()) do
					if val:IsA("ValueBase") then
						local key = child.Name .. "." .. val.Name
						local oldVal = leaderstatsBeefore[key]
						if oldVal ~= nil and val.Value ~= oldVal then
							table.insert(changes.statChanges, {
								name = key,
								oldValue = oldVal,
								newValue = val.Value,
								diff = (type(val.Value) == "number" and type(oldVal) == "number") and (val.Value - oldVal) or "changed"
							})
							changes.hasChanges = true
						end
					end
				end
			end
		end)
	end

	return changes
end

