		table.insert(args, {player, 999})
		table.insert(args, {"open", "all"})
		table.insert(args, {player, "open", "all"})
	end

	-- Spawn/Create pattern
	if nl:find("spawn") or nl:find("create") or nl:find("make") or nl:find("generate") or nl:find("instantiate") then
		for _, name in ipairs(ITEM_NAMES) do
			table.insert(args, {name})
