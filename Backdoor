local interceptHooked = false
local interceptLog = {}

local function startInterceptor()
	if interceptHooked then return end
	interceptHooked = true
	interceptEnabled = true

	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then addLog("hookfunction not available", "warning") return end

		-- Hook FireServer
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if interceptEnabled and self:IsA("RemoteEvent") then
				local args = {...}
				table.insert(interceptLog, {
					time = os.clock(), type = "FireServer",
					remote = self.Name, path = getPath(self),
					argCount = #args
				})
			end
			return oldFS(self, ...)
		end))

		-- Hook InvokeServer
		local oldIS
		oldIS = hf(Instance.new("RemoteFunction").InvokeServer, newcclosure(function(self, ...)
			if interceptEnabled and self:IsA("RemoteFunction") then
				local args = {...}
				table.insert(interceptLog, {
					time = os.clock(), type = "InvokeServer",
					remote = self.Name, path = getPath(self),
					argCount = #args
				})
			end
			return oldIS(self, ...)
		end))

		addLog("🎯 Remote Interceptor ACTIVE!", "success")
	end)
end

