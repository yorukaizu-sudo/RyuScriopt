-- ==========================================
-- COLLECTOR - Find ALL Remotes
-- ==========================================
local function collectEverything()
	allRemoteEvents = {}
	allRemoteFunctions = {}
	allBindables = {}

	local seen = {}

	local function scanInstance(inst)
		pcall(function()
			for _, desc in ipairs(inst:GetDescendants()) do
				pcall(function()
					if seen[desc] then return end
					seen[desc] = true
					if desc:IsA("RemoteEvent") then
						table.insert(allRemoteEvents, desc)
					elseif desc:IsA("RemoteFunction") then
						table.insert(allRemoteFunctions, desc)
					elseif desc:IsA("BindableEvent") or desc:IsA("BindableFunction") then
						table.insert(allBindables, desc)
					end
				end)
			end
		end)
	end

	-- Primary locations
	scanInstance(RS)
	scanInstance(WS)
	scanInstance(Lighting)
	scanInstance(StarterGui)
	scanInstance(StarterPack)
	pcall(function() scanInstance(playerGui) end)
	pcall(function() scanInstance(player.PlayerScripts) end)
	pcall(function() scanInstance(player.StarterGear) end)
	if player.Character then scanInstance(player.Character) end

	-- Ultra deep - scan ALL services
	if ultraDeepScan then
		pcall(function()
			for _, service in ipairs(game:GetChildren()) do
				pcall(function() scanInstance(service) end)
			end
		end)

		-- Try hidden services
		local hiddenServices = {
			"ServerScriptService", "ServerStorage",
			"NetworkServer", "NetworkClient",
			"CoreGui", "CorePackages",
			"RobloxReplicatedStorage", "TestService",
			"JointsService", "InsertService",
			"ChangeHistoryService", "Selection",
			"ScriptEditorService", "AnalyticsService",
		}
		for _, sName in ipairs(hiddenServices) do
			pcall(function()
				local s = game:GetService(sName)
				if s then scanInstance(s) end
			end)
		end
	end

	-- Use CollectionService tags
	pcall(function()
		for _, tag in ipairs(CollectionService:GetAllTags()) do
			for _, inst in ipairs(CollectionService:GetTagged(tag)) do
				if not seen[inst] then
					seen[inst] = true
					if inst:IsA("RemoteEvent") then table.insert(allRemoteEvents, inst)
					elseif inst:IsA("RemoteFunction") then table.insert(allRemoteFunctions, inst) end
				end
			end
		end
	end)

	-- Deduplicate
	local uniqueRE, uniqueRF = {}, {}
	local reSet, rfSet = {}, {}
	for _, re in ipairs(allRemoteEvents) do
		if isValid(re) and not reSet[re] then reSet[re] = true table.insert(uniqueRE, re) end
	end
	for _, rf in ipairs(allRemoteFunctions) do
		if isValid(rf) and not rfSet[rf] then rfSet[rf] = true table.insert(uniqueRF, rf) end
	end
	allRemoteEvents = uniqueRE
	allRemoteFunctions = uniqueRF

	addLog(string.format("Collected: %d RE, %d RF, %d Bindables",
		#allRemoteEvents, #allRemoteFunctions, #allBindables), "success")

	return #allRemoteEvents + #allRemoteFunctions
end

