-- ==========================================
local function fireRE(remote, args, skipDanger)
	if not isValid(remote) then return false, "invalid" end
	if not skipDanger and safeMode and isDangerous(remote.Name) then return false, "dangerous" end

	deepSnapshotBackpack()
	local success, err = pcall(function() remote:FireServer(unpack(args)) end)
	task.wait(0.08)
	local items = checkNewItems(remote.Name)

	if #items > 0 then
		totalVulnerable = totalVulnerable + 1
		addLog(string.format("🎁 ITEMS FROM %s: %s | Args: %d",
			getPath(remote), table.concat(items, ", "), #args), "vuln")
		table.insert(vulnerableRemotes, {
			remote = remote, name = remote.Name, path = getPath(remote),
			args = args, items = items, type = "RemoteEvent", time = os.clock()
		})
		-- Save successful args
		if not successfulArgs[remote] then successfulArgs[remote] = {} end
		table.insert(successfulArgs[remote], {args = args, items = items})

		-- Auto clone items if enabled
		if cloneOnFind then
			for _, item in ipairs(backpack:GetChildren()) do
				for _, newName in ipairs(items) do
					if item.Name == newName then
						pcall(function()
							for i = 1, 3 do
								local clone = item:Clone()
								clone.Parent = backpack
							end
						end)
					end
				end
			end
		end
	end

	totalScanned = totalScanned + 1
	return success, items
end

local function fireRF(remote, args, skipDanger)
	if not isValid(remote) then return false, "invalid" end
	if not skipDanger and safeMode and isDangerous(remote.Name) then return false, "dangerous" end

	deepSnapshotBackpack()
	local success, result = pcall(function() return remote:InvokeServer(unpack(args)) end)
	task.wait(0.08)
	local items = checkNewItems(remote.Name)

	if #items > 0 then
		totalVulnerable = totalVulnerable + 1
		addLog(string.format("🎁 ITEMS FROM %s: %s", getPath(remote), table.concat(items, ", ")), "vuln")
		table.insert(vulnerableRemotes, {
			remote = remote, name = remote.Name, path = getPath(remote),
			args = args, items = items, type = "RemoteFunction", time = os.clock(),
			response = tostring(result):sub(1, 200)
		})
		if not successfulArgs[remote] then successfulArgs[remote] = {} end
		table.insert(successfulArgs[remote], {args = args, items = items})
	end

	-- Log interesting responses
	if success and result ~= nil then
		totalResponses = totalResponses + 1
		local rStr = tostring(result)
		if typeof(result) == "table" then
			pcall(function()
				local parts = {}
				for k, v in pairs(result) do
					table.insert(parts, tostring(k) .. "=" .. tostring(v))
					if #parts > 15 then break end
				end
				rStr = "{" .. table.concat(parts, ", ") .. "}"
			end)
		end
		table.insert(responseLog, {
			remote = remote.Name, path = getPath(remote),
			args = #args, response = rStr, time = os.clock()
		})

		-- Check response for useful info
		local rl = rStr:lower()
		if rl:find("success") or rl:find("true") or rl:find("granted") or rl:find("given") or rl:find("added") or rl:find("unlocked") then
			addLog("📌 POSITIVE RESPONSE from " .. remote.Name .. ": " .. rStr:sub(1, 150), "success")
		end
	end

	totalScanned = totalScanned + 1
	return success, result
end

