local function generateTestArgs(remoteName)
	local args = {}

	-- Basic empty call
	table.insert(args, {})

	-- Player-based args
	table.insert(args, {player})
	table.insert(args, {player.Name})
	table.insert(args, {player.UserId})

	-- String args
	table.insert(args, {"give"})
	table.insert(args, {"all"})
	table.insert(args, {true})
	table.insert(args, {false})
	table.insert(args, {1})
	table.insert(args, {100})
	table.insert(args, {999999})
	table.insert(args, {math.huge})

	-- Item/give related
	if isGiveRelated(remoteName) or isItemRelated(remoteName) then
		table.insert(args, {player, "all"})
		table.insert(args, {player.Name, 1})
		table.insert(args, {player, true})
		table.insert(args, {player, 1})
		table.insert(args, {player, 999})
		table.insert(args, {"give", player.Name})
		table.insert(args, {"give", player})
		table.insert(args, {"equip", 1})
		table.insert(args, {"buy", 1})
		table.insert(args, {player, "give", "all"})
		table.insert(args, {1, player})
		table.insert(args, {true, player})
		table.insert(args, {player.Name, "all", true})

		-- Try common item names
		for _, itemName in ipairs({"Sword","Gun","Knife","Pistol","Rifle","Shotgun","Sniper","RPG","Grenade","Bomb","Shield","Armor","Potion","Speed","Strength","Health"}) do
			table.insert(args, {itemName})
			table.insert(args, {player, itemName})
			table.insert(args, {"give", itemName})
			table.insert(args, {itemName, player})
		end
	end

	-- Admin/backdoor related
	if isAdminRelated(remoteName) then
		table.insert(args, {player, "give", "all"})
		table.insert(args, {"loadstring", ""})
		table.insert(args, {player.Name, "admin"})
		table.insert(args, {"execute", ""})
		table.insert(args, {":give all"})
		table.insert(args, {":giveall"})
		table.insert(args, {player, ":give all"})

		-- Common admin commands
		for _, cmd in ipairs({":give all",":givetools",":tools me",":gear me all",":btools me","give","giveall","tools"}) do
			table.insert(args, {cmd})
			table.insert(args, {player, cmd})
			table.insert(args, {player.Name, cmd})
		end
	end

	-- Backpack related
	if isBackpackRelated(remoteName) then
		table.insert(args, {player, backpack})
		table.insert(args, {backpack})
		table.insert(args, {player, "all"})
		table.insert(args, {"fill"})
		table.insert(args, {"loadout", 1})
	end

	-- CFrame/Vector3 args (for teleport/spawn related)
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		local pos = char.HumanoidRootPart.Position
		table.insert(args, {pos})
		table.insert(args, {CFrame.new(pos)})
		table.insert(args, {player, pos})
	end

	-- Table/Dictionary args
	table.insert(args, {{player = player, action = "give"}})
	table.insert(args, {{Type = "give", Amount = 1}})
	table.insert(args, {{item = "all", quantity = 999}})
	table.insert(args, {{Action = "Buy", ItemId = 1}})
	table.insert(args, {{cmd = "give", target = player.Name}})

	return args
end

