local function parseCustomArgs()
	local args = {}
	if customArgs == "" then return args end

	for _, arg in ipairs(string.split(customArgs, ",")) do
		local trimmed = arg:match("^%s*(.-)%s*$")
		if trimmed == "player" then table.insert(args, player)
		elseif trimmed == "player.Name" then table.insert(args, player.Name)
		elseif trimmed == "player.UserId" then table.insert(args, player.UserId)
		elseif trimmed == "backpack" then table.insert(args, backpack)
		elseif trimmed == "character" then table.insert(args, player.Character)
		elseif trimmed == "true" then table.insert(args, true)
		elseif trimmed == "false" then table.insert(args, false)
		elseif trimmed == "nil" then table.insert(args, nil)
		elseif trimmed == "inf" or trimmed == "math.huge" then table.insert(args, math.huge)
		elseif trimmed == "-inf" then table.insert(args, -math.huge)
		elseif trimmed == "nan" then table.insert(args, 0/0)
		elseif tonumber(trimmed) then table.insert(args, tonumber(trimmed))
		elseif trimmed:sub(1,1) == "{" and trimmed:sub(-1) == "}" then
			-- Simple table parsing
			pcall(function()
				local inner = trimmed:sub(2, -2)
				local t = {}
				for _, pair in ipairs(string.split(inner, ";")) do
					local k, v = pair:match("(%w+)%s*=%s*(.+)")
					if k and v then
						if tonumber(v) then t[k] = tonumber(v)
						elseif v == "true" then t[k] = true
						elseif v == "false" then t[k] = false
						elseif v == "player" then t[k] = player
						else t[k] = v end
					end
				end
				table.insert(args, t)
			end)
		else
			table.insert(args, trimmed)
		end
	end
	return args
end

local function findRemoteByPath(path)
	local parts = string.split(path, ".")
	local current = game
	for _, part in ipairs(parts) do
		local next = nil
		pcall(function() next = current:FindFirstChild(part) end)
		if not next then pcall(function() next = current[part] end) end
		if not next then return nil end
		current = next
	end
	return current
end

