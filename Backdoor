-- ==========================================
local function scanModules()
	addLog("📦 Scanning ModuleScripts for item data...", "info")
	local modulesFound = 0
	local itemDataFound = 0

	local function scanModule(mod)
		pcall(function()
			local data = require(mod)
			if typeof(data) ~= "table" then return end
			modulesFound = modulesFound + 1

			-- Search for item/weapon/tool data
			local function searchTable(tbl, depth, path)
				if depth > 5 then return end
				for k, v in pairs(tbl) do
					local kStr = tostring(k):lower()
					if typeof(v) == "table" then
						-- Check if this looks like item data
						if v.Name or v.name or v.ItemName or v.itemName or v.ToolName or v.toolName then
							local itemName = v.Name or v.name or v.ItemName or v.itemName or v.ToolName or v.toolName
							addLog(string.format("📋 Item data: %s (in %s.%s)", tostring(itemName), mod.Name, path .. tostring(k)), "info")
							itemDataFound = itemDataFound + 1
						end
						searchTable(v, depth + 1, path .. tostring(k) .. ".")
					end
				end
			end
			searchTable(data, 0, "")
		end)
	end

	local places = {RS, Lighting, StarterPack, StarterGui}
	pcall(function() table.insert(places, player.PlayerScripts) end)

	for _, place in ipairs(places) do
		pcall(function()
			for _, desc in ipairs(place:GetDescendants()) do
				if desc:IsA("ModuleScript") then
					local nl = desc.Name:lower()
					if nl:find("item") or nl:find("weapon") or nl:find("tool") or nl:find("shop") or
					   nl:find("store") or nl:find("config") or nl:find("data") or nl:find("settings") or
					   nl:find("inventory") or nl:find("gear") or nl:find("equip") or nl:find("pet") or
					   nl:find("fruit") or nl:find("ability") or nl:find("skill") or nl:find("class") or
					   nl:find("loadout") or nl:find("catalog") or nl:find("product") or nl:find("reward") then
						scanModule(desc)
					end
				end
			end
		end)
	end

	addLog(string.format("Module scan: %d modules, %d item entries found", modulesFound, itemDataFound), "success")
end

