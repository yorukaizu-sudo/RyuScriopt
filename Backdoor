-- ==========================================
-- UTILITY FUNCTIONS
-- ==========================================
local function addLog(msg, logType)
	local entry = {
		time = os.clock(),
		message = msg,
		type = logType or "info" -- info, success, warning, error, vuln
	}
	table.insert(scanLog, entry)
	if #scanLog > 500 then table.remove(scanLog, 1) end

	if logType == "success" then
		print("[✓] " .. msg)
	elseif logType == "vuln" then
		warn("[!] VULNERABLE: " .. msg)
	elseif logType == "error" then
		warn("[✗] " .. msg)
	elseif logType == "warning" then
		warn("[⚠] " .. msg)
	else
		print("[i] " .. msg)
	end
end

local function isValidInstance(obj)
	local ok, r = pcall(function() return obj and obj.Parent ~= nil end)
	return ok and r
end

local function containsAnyKeyword(name, keywords)
	local nl = name:lower()
	for _, kw in ipairs(keywords) do
		if nl:find(kw:lower()) then return true, kw end
	end
	return false, nil
end

local function getRemotePath(remote)
	local path = {}
	local current = remote
	while current and current ~= game do
		table.insert(path, 1, current.Name)
		current = current.Parent
	end
	return table.concat(path, ".")
end

local function isDangerous(name)
	return containsAnyKeyword(name, dangerKeywords)
end

local function isGiveRelated(name)
	return containsAnyKeyword(name, giveKeywords)
end

local function isItemRelated(name)
	return containsAnyKeyword(name, itemKeywords)
end

local function isAdminRelated(name)
	return containsAnyKeyword(name, adminKeywords)
end

local function isBackpackRelated(name)
	return containsAnyKeyword(name, backpackKeywords)
end

