		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local pos = player.Character.HumanoidRootPart.Position
			for _, name in ipairs({"Sword","Gun","Knife","Tool","Item"}) do
				table.insert(args, {name, pos})
				table.insert(args, {player, name, pos})
				table.insert(args, {name, CFrame.new(pos)})
			end
		end
	end

	-- Trade/Transfer pattern
	if nl:find("trade") or nl:find("transfer") or nl:find("send") or nl:find("give2") then
		table.insert(args, {player, player, "all"})
		table.insert(args, {player, "all", 999})
		table.insert(args, {{from = "server", to = player.Name, items = "all"}})
