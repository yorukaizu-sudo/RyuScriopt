-- OBFUSCATION DETECTION v3
-- ==========================================
local function isObfuscatedName(name)
	-- Check for base64-like patterns
	if name:match("^[A-Za-z0-9+/]+=*$") and #name > 8 then return true, "base64" end

	-- Check for hex patterns
	if name:match("^[0-9a-fA-F]+$") and #name >= 8 then return true, "hex" end

	-- Check for random character strings
	local consonants = 0
	local vowels = 0
	local digits = 0
	local specials = 0
	for c in name:gmatch(".") do
		local l = c:lower()
		if l:match("[aeiou]") then vowels = vowels + 1
		elseif l:match("[bcdfghjklmnpqrstvwxyz]") then consonants = consonants + 1
		elseif l:match("[0-9]") then digits = digits + 1
		else specials = specials + 1 end
	end

	-- Too many consonants without vowels = likely obfuscated
	if #name > 5 and vowels == 0 then return true, "no_vowels" end
	if #name > 8 and consonants > vowels * 4 then return true, "consonant_heavy" end

	-- Single or double character names
	if #name <= 2 then return true, "short" end

	-- UUID-like patterns
	if name:match("^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$") then
		return true, "uuid"
	end

	-- All numbers
	if name:match("^%d+$") then return true, "numeric" end

	-- Mixed case chaos
	local upperCount = 0
	local lowerCount = 0
	for c in name:gmatch(".") do
		if c:match("%u") then upperCount = upperCount + 1 end
		if c:match("%l") then lowerCount = lowerCount + 1 end
	end
	if upperCount > 0 and lowerCount > 0 and #name > 6 then
		local ratio = upperCount / (upperCount + lowerCount)
		if ratio > 0.4 and ratio < 0.6 then return true, "mixed_case" end
	end

	-- Repeating patterns
	if #name > 6 then
		local half = name:sub(1, math.floor(#name/2))
		if name:find(half, math.floor(#name/2) + 1, true) then return true, "repeating" end
	end

	return false, nil
end

local function detectHiddenRemotes()
	hiddenRemotes = {}
	addLog("Scanning for hidden/obfuscated remotes...", "info")

	local allRemotes = {}

	-- Scan all accessible services deeply
	local function deepSearch(parent, depth)
		if depth > 15 then return end
		pcall(function()
			for _, child in ipairs(parent:GetChildren()) do
				pcall(function()
					if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
						local isObf, obfType = isObfuscatedName(child.Name)
						if isObf then
							table.insert(hiddenRemotes, {
								instance = child,
								name = child.Name,
								path = getRemotePath(child),
								className = child.ClassName,
								obfuscationType = obfType,
								depth = depth
							})
							addLog(string.format("Hidden remote found: %s [%s] type=%s depth=%d",
								child.Name, child.ClassName, obfType, depth), "discovery")
						end
					end
					deepSearch(child, depth + 1)
				end)
			end
		end)
	end

	for _, service in ipairs(game:GetChildren()) do
		pcall(function()
			deepSearch(service, 0)
		end)
	end

	addLog(string.format("Found %d hidden/obfuscated remotes", #hiddenRemotes), "info")
	return hiddenRemotes
end

