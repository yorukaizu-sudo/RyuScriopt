				i, v.name, v.path, table.concat(v.items or {}, ", "))
		end
		report = report .. "\n"
	end

	if #itemsObtained > 0 then
		report = report .. "--- ITEMS OBTAINED ---\n"
		for i, item in ipairs(itemsObtained) do
			report = report .. string.format("%d. %s [%s] from %s\n",
				i, item.name, item.className, item.remote)
		end
		report = report .. "\n"
	end

	if #responseLog > 0 then
		report = report .. "--- REMOTE RESPONSES ---\n"
		for i, resp in ipairs(responseLog) do
			if i > 50 then break end
			report = report .. string.format("%s: %s\n", resp.remote, resp.response:sub(1, 150))
		end
		report = report .. "\n"
	end

	-- All remotes list
	report = report .. "--- ALL REMOTE EVENTS ---\n"
	for i, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			local tags = {}
			if info.isGiveRelated then table.insert(tags, "GIVE") end
			if info.isItemRelated then table.insert(tags, "ITEM") end
			if info.isAdminRelated then table.insert(tags, "ADMIN") end
			if info.isDangerous then table.insert(tags, "DANGER") end
			report = report .. string.format("%d. %s [%s]\n", i, getRemotePath(re), table.concat(tags, ","))
		end
	end
	report = report .. "\n--- ALL REMOTE FUNCTIONS ---\n"
	for i, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			local tags = {}
			if info.isGiveRelated then table.insert(tags, "GIVE") end
			if info.isItemRelated then table.insert(tags, "ITEM") end
			if info.isAdminRelated then table.insert(tags, "ADMIN") end
			report = report .. string.format("%d. %s [%s]\n", i, getRemotePath(rf), table.concat(tags, ","))
		end
	end

	return report
end

-- ==========================================
-- RE-FIRE VULNERABLE
-- ==========================================
local function refireVulnerable()
	if #vulnerableRemotes == 0 then
		addLog("No vulnerable remotes found yet! Run a scan first.", "warning")
		return
	end

	addLog("Re-firing " .. #vulnerableRemotes .. " vulnerable remotes...", "info")
	snapshotBackpack()

	for _, v in ipairs(vulnerableRemotes) do
		if isValidInstance(v.remote) then
			pcall(function()
				if v.remote:IsA("RemoteEvent") then
					if v.args then
						v.remote:FireServer(unpack(v.args))
					else
						v.remote:FireServer()
						v.remote:FireServer(player)
						v.remote:FireServer(player, "all")
					end
				elseif v.remote:IsA("RemoteFunction") then
					if v.args then
						v.remote:InvokeServer(unpack(v.args))
					else
						v.remote:InvokeServer()
						v.remote:InvokeServer(player)
					end
				end
			end)
			task.wait(0.1)
		end
	end

	task.wait(0.5)
	local items = checkNewItems("ReFire")
	if #items > 0 then
		addLog("Re-fire got items: " .. table.concat(items, ", "), "vuln")
	end
end

