-- SCANNER CORE v3
-- ==========================================
local function collectAllRemotes()
	remoteEvents = {}
	remoteFunctions = {}
	bindableEvents = {}
	bindableFunctions = {}

	local seen = {}

	local function addRemote(remote)
		local id = tostring(remote)
		if seen[id] then return end
		seen[id] = true

		if remote:IsA("RemoteEvent") then
			table.insert(remoteEvents, remote)
		elseif remote:IsA("RemoteFunction") then
			table.insert(remoteFunctions, remote)
		elseif remote:IsA("BindableEvent") then
			table.insert(bindableEvents, remote)
		elseif remote:IsA("BindableFunction") then
			table.insert(bindableFunctions, remote)
		end
	end

	local function searchLocation(location)
		pcall(function()
			for _, desc in ipairs(location:GetDescendants()) do
				pcall(function()
					if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") or
					   desc:IsA("BindableEvent") or desc:IsA("BindableFunction") then
						addRemote(desc)
					end
				end)
			end
		end)
	end

	-- Primary locations
	searchLocation(ReplicatedStorage)
	searchLocation(Workspace)
	searchLocation(Lighting)
	searchLocation(StarterGui)
	searchLocation(StarterPack)

	-- Player locations
	pcall(function() searchLocation(player.PlayerGui) end)
	pcall(function() searchLocation(player.PlayerScripts) end)
	pcall(function() searchLocation(player.Backpack) end)
	if player.Character then searchLocation(player.Character) end

	-- Additional locations
	pcall(function() searchLocation(ReplicatedFirst) end)
	pcall(function() searchLocation(StarterPlayer) end)
	pcall(function() searchLocation(Chat) end)
	pcall(function() searchLocation(Teams) end)
	pcall(function() searchLocation(SoundService) end)

	-- Deep scan - all services
	if deepScanEnabled then
		for _, service in ipairs(game:GetChildren()) do
			pcall(function() searchLocation(service) end)
		end
	end

	-- Ultra deep scan - use getinstances if available
	if ultraDeepScan then
		pcall(function()
			if getinstances then
				for _, inst in ipairs(getinstances()) do
					pcall(function()
						if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
							addRemote(inst)
						end
					end)
				end
			end
		end)

		-- Try getnilinstances
		pcall(function()
			if getnilinstances then
				for _, inst in ipairs(getnilinstances()) do
					pcall(function()
						if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
							addRemote(inst)
							addLog("NIL instance found: " .. inst.Name .. " [" .. inst.ClassName .. "]", "discovery")
						end
					end)
				end
			end
		end)
	end

	-- Monitor for new remotes
	pcall(function()
		local conn
		conn = ReplicatedStorage.DescendantAdded:Connect(function(desc)
			if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") then
				addRemote(desc)
				addLog("New remote added: " .. desc.Name .. " at " .. getRemotePath(desc), "discovery")
			end
		end)
		-- Auto disconnect after 60 seconds
		task.delay(60, function() pcall(function() conn:Disconnect() end) end)
	end)

	addLog(string.format("Found: %d RE, %d RF, %d BE, %d BF",
		#remoteEvents, #remoteFunctions, #bindableEvents, #bindableFunctions), "info")
end

local function analyzeRemote(remote)
	local info = {
		name = remote.Name,
		path = getRemotePath(remote),
		className = remote.ClassName,
		isGiveRelated = false,
		isItemRelated = false,
		isAdminRelated = false,
		isDangerous = false,
		isBackpackRelated = false,
		isObfuscated = false,
		obfuscationType = nil,
		priority = 0,
		keywords = {},
		responses = {},
		vulnerable = false,
		itemsGiven = {},
		statChanges = {},
		depth = getRemoteDepth(remote),
		parentInfo = "",
	}

	local name = remote.Name

	-- Keyword analysis
	local isGive, giveKws = containsAnyKeyword(name, giveKeywords)
	if isGive then info.isGiveRelated = true info.priority = info.priority + 3
		for _, kw in ipairs(giveKws) do table.insert(info.keywords, kw) end
	end

	local isItem, itemKws = containsAnyKeyword(name, itemKeywords)
	if isItem then info.isItemRelated = true info.priority = info.priority + 2
		for _, kw in ipairs(itemKws) do table.insert(info.keywords, kw) end
	end

	local isAdmin, adminKws = containsAnyKeyword(name, adminKeywords)
	if isAdmin then info.isAdminRelated = true info.priority = info.priority + 5
		for _, kw in ipairs(adminKws) do table.insert(info.keywords, kw) end
	end

	local isDanger, dangerKws = containsAnyKeyword(name, dangerKeywords)
	if isDanger then info.isDangerous = true info.priority = info.priority - 10
		for _, kw in ipairs(dangerKws) do table.insert(info.keywords, kw) end
	end

	local isBP, bpKws = containsAnyKeyword(name, backpackKeywords)
	if isBP then info.isBackpackRelated = true info.priority = info.priority + 2
		for _, kw in ipairs(bpKws) do table.insert(info.keywords, kw) end
	end

	-- Obfuscation check
	local isObf, obfType = isObfuscatedName(name)
	if isObf then
		info.isObfuscated = true
		info.obfuscationType = obfType
		info.priority = info.priority + 4 -- obfuscated = potentially interesting
	end

	-- Check parent path for keywords
	local pathStr = info.path:lower()
	for _, kw in ipairs(adminKeywords) do
		if pathStr:find(kw) and not info.isAdminRelated then
			info.isAdminRelated = true
			info.priority = info.priority + 3
		end
	end
	for _, kw in ipairs(giveKeywords) do
		if pathStr:find(kw) and not info.isGiveRelated then
			info.isGiveRelated = true
			info.priority = info.priority + 2
		end
	end

	-- Parent context
	pcall(function()
		if remote.Parent then
			info.parentInfo = remote.Parent.Name .. " [" .. remote.Parent.ClassName .. "]"
		end
	end)

	-- Depth bonus (deeply nested = more suspicious)
	if info.depth > 5 then info.priority = info.priority + 2 end

	return info
end

local function fireRemoteWithRetry(remote, args, info, isEvent)
	if safeMode and info and info.isDangerous then
		addLog("SKIPPED (dangerous): " .. remote.Name, "warning")
		return nil, "skipped_dangerous", nil
	end

	deepSnapshot()

	local success, result
	local attempts = autoRetry and retryCount or 1

	for attempt = 1, attempts do
		if isEvent then
			success, result = pcall(function()
				remote:FireServer(unpack(args))
			end)
		else
			success, result = pcall(function()
				return remote:InvokeServer(unpack(args))
			end)
		end

		if success then break end
		if attempt < attempts then task.wait(0.05) end
	end

	task.wait(0.15) -- wait for server response

	local changes = deepCheckChanges(remote.Name)
	local responseAnalysis = nil

	if not isEvent and success and result ~= nil then
		responseAnalysis = analyzeResponse(result, remote.Name, args)
		totalResponses = totalResponses + 1

		local responseStr = tostring(result)
		if typeof(result) == "table" then
			pcall(function()
				responseStr = HttpService:JSONEncode(result)
			end)
			if responseStr == nil or responseStr == "" then
				pcall(function()
					local parts = {}
					for k, v in pairs(result) do
						table.insert(parts, tostring(k) .. "=" .. tostring(v))
						if #parts > 15 then table.insert(parts, "...") break end
					end
					responseStr = "{" .. table.concat(parts, ", ") .. "}"
				end)
			end
		end

		table.insert(responseLog, {
			remote = remote.Name,
			path = getRemotePath(remote),
			args = #args,
			response = responseStr:sub(1, 500),
			interesting = responseAnalysis and responseAnalysis.interesting or false,
			time = os.clock()
		})
	end

	if changes.hasChanges then
		info.vulnerable = true
		totalVulnerable = totalVulnerable + 1

		local changeMsg = ""
		if #changes.newItems > 0 then
			local names = {}
			for _, i in ipairs(changes.newItems) do table.insert(names, i.name) end
			changeMsg = changeMsg .. "Items: " .. table.concat(names, ", ")
			info.itemsGiven = changes.newItems
		end
		if #changes.newCharItems > 0 then
			local names = {}
			for _, i in ipairs(changes.newCharItems) do table.insert(names, i.name) end
			if changeMsg ~= "" then changeMsg = changeMsg .. " | " end
			changeMsg = changeMsg .. "Char: " .. table.concat(names, ", ")
		end
		if #changes.statChanges > 0 then
			local stats = {}
			for _, s in ipairs(changes.statChanges) do
				table.insert(stats, s.name .. ":" .. tostring(s.diff))
			end
			if changeMsg ~= "" then changeMsg = changeMsg .. " | " end
			changeMsg = changeMsg .. "Stats: " .. table.concat(stats, ", ")
			info.statChanges = changes.statChanges
		end

		addLog(string.format("🔓 VULNERABLE: %s -> %s (args: %d)",
			remote.Name, changeMsg, #args), "vuln")

		table.insert(vulnerableRemotes, {
			remote = remote,
			name = remote.Name,
			path = getRemotePath(remote),
			className = remote.ClassName,
			args = args,
			items = changes.newItems,
			charItems = changes.newCharItems,
			statChanges = changes.statChanges,
			response = result,
			time = os.clock(),
			argTypes = (function()
				local types = {}
				for _, a in ipairs(args) do table.insert(types, typeof(a)) end
				return types
			end)()
		})
	end

	if success then
		totalScanned = totalScanned + 1
		return true, result, changes
	else
		totalErrors = totalErrors + 1
		return false, result, changes
	end
end

