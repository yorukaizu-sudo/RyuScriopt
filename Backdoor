local backpackBefore = {}
local function snapshotBackpack()
	backpackBefore = {}
	for _, item in ipairs(backpack:GetChildren()) do
		backpackBefore[item.Name] = true
	end
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") then
				backpackBefore[item.Name] = true
			end
		end
	end
end

local function checkNewItems(remoteName)
	local newItems = {}
	for _, item in ipairs(backpack:GetChildren()) do
		if not backpackBefore[item.Name] then
			table.insert(newItems, item.Name)
			table.insert(itemsObtained, {
				name = item.Name,
				className = item.ClassName,
				remote = remoteName,
				time = os.clock()
			})
			totalItems = totalItems + 1
		end
	end
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") and not backpackBefore[item.Name] then
				table.insert(newItems, item.Name)
				table.insert(itemsObtained, {
					name = item.Name,
					className = item.ClassName,
					remote = remoteName,
					time = os.clock()
				})
				totalItems = totalItems + 1
			end
		end
	end
	return newItems
end

