local function deepSnapshotBackpack()
	backpackSnapshot = {}
	charSnapshot = {}
	for _, item in ipairs(backpack:GetChildren()) do
		backpackSnapshot[item.Name .. "_" .. item.ClassName] = true
	end
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") or item:IsA("Accessory") or item:IsA("HopperBin") then
				charSnapshot[item.Name .. "_" .. item.ClassName] = true
			end
		end
	end
	-- Also snapshot PlayerGui for any UI items
	pcall(function()
		for _, gui in ipairs(playerGui:GetChildren()) do
			-- Some games add items as GUI elements
		end
	end)
end

local function checkNewItems(remoteName)
	local newItems = {}
	-- Check backpack
	for _, item in ipairs(backpack:GetChildren()) do
		local key = item.Name .. "_" .. item.ClassName
		if not backpackSnapshot[key] then
			table.insert(newItems, item.Name)
			table.insert(itemsObtained, {
				name = item.Name, className = item.ClassName,
				remote = remoteName, time = os.clock(),
				location = "Backpack"
			})
			totalItems = totalItems + 1
		end
	end
	-- Check character
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if (item:IsA("Tool") or item:IsA("Accessory") or item:IsA("HopperBin")) then
				local key = item.Name .. "_" .. item.ClassName
				if not charSnapshot[key] then
					table.insert(newItems, item.Name .. " (Equipped)")
					table.insert(itemsObtained, {
						name = item.Name, className = item.ClassName,
						remote = remoteName, time = os.clock(),
						location = "Character"
					})
					totalItems = totalItems + 1
				end
			end
		end
	end
	return newItems
end

