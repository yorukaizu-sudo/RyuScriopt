local function scanGiveRemotes()
	if isScanning then return end
	isScanning = true
	addLog("========== SCANNING GIVE/ITEM REMOTES ==========", "info")
	collectAllRemotes()

	local targets = {}
	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local isG = containsAnyKeyword(re.Name, giveKeywords)
			local isI = containsAnyKeyword(re.Name, itemKeywords)
			local isB = containsAnyKeyword(re.Name, backpackKeywords)
			if isG or isI or isB then
				table.insert(targets, {remote = re, isEvent = true})
			end
		end
	end
	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local isG = containsAnyKeyword(rf.Name, giveKeywords)
			local isI = containsAnyKeyword(rf.Name, itemKeywords)
			local isB = containsAnyKeyword(rf.Name, backpackKeywords)
			if isG or isI or isB then
				table.insert(targets, {remote = rf, isEvent = false})
			end
		end
	end

	addLog(string.format("Found %d give/item related remotes", #targets), "info")

	for _, target in ipairs(targets) do
		if not isScanning then break end
		local info = analyzeRemote(target.remote)
		local testArgs = generateTestArgs(target.remote.Name)

		addLog("Testing: " .. getRemotePath(target.remote), "info")

		for _, args in ipairs(testArgs) do
			if not isScanning then break end
			pcall(function()
				if target.isEvent then
					fireRemoteEvent(target.remote, args, info)
				else
					fireRemoteFunction(target.remote, args, info)
				end
			end)
			task.wait(fireDelay)
		end
		task.wait(scanDelay)
	end

	addLog("Give/Item scan complete!", "success")
	isScanning = false
end

local function scanAdminRemotes()
	if isScanning then return end
	isScanning = true
	addLog("========== SCANNING ADMIN/BACKDOOR REMOTES ==========", "info")
	collectAllRemotes()

	local targets = {}
	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) and containsAnyKeyword(re.Name, adminKeywords) then
			table.insert(targets, {remote = re, isEvent = true})
		end
	end
	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) and containsAnyKeyword(rf.Name, adminKeywords) then
			table.insert(targets, {remote = rf, isEvent = false})
		end
	end

	-- Also check for suspiciously named remotes (random strings, single chars, etc)
	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local name = re.Name
			-- Single character or very short names are suspicious
			if #name <= 2 or name:match("^[a-zA-Z]$") or name:match("^[%d]+$") then
				local found = false
				for _, t in ipairs(targets) do if t.remote == re then found = true break end end
				if not found then
					table.insert(targets, {remote = re, isEvent = true, suspicious = true})
				end
			end
		end
	end
	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local name = rf.Name
			if #name <= 2 or name:match("^[a-zA-Z]$") or name:match("^[%d]+$") then
				local found = false
				for _, t in ipairs(targets) do if t.remote == rf then found = true break end end
				if not found then
					table.insert(targets, {remote = rf, isEvent = false, suspicious = true})
				end
			end
		end
	end

	addLog(string.format("Found %d admin/suspicious remotes", #targets), "info")

	for _, target in ipairs(targets) do
		if not isScanning then break end
		local info = analyzeRemote(target.remote)
		info.isDangerous = false -- override for admin scan

		local testArgs = generateTestArgs(target.remote.Name)

		-- Extra admin-specific args
		local extraArgs = {
			{"print('test')"},
			{"loadstring('')()"},
			{player, "admin"},
			{":give all"},
			{":btools"},
			{":ff me"},
			{":speed me 100"},
			{":tools me"},
			{"give " .. player.Name .. " all"},
		}
		for _, ea in ipairs(extraArgs) do
			table.insert(testArgs, ea)
		end

		addLog("Testing admin: " .. getRemotePath(target.remote) .. (target.suspicious and " [SUSPICIOUS]" or ""), "warning")

		for _, args in ipairs(testArgs) do
			if not isScanning then break end
			pcall(function()
				if target.isEvent then
					fireRemoteEvent(target.remote, args, info)
				else
					fireRemoteFunction(target.remote, args, info)
				end
			end)
			task.wait(fireDelay)
		end
		task.wait(scanDelay)
	end

	addLog("Admin/Backdoor scan complete!", "success")
	isScanning = false
end

local function fireAllRemotes()
	if isScanning then return end
	isScanning = true
	isFiring = true
	addLog("========== FIRE ALL REMOTES ==========", "warning")
	collectAllRemotes()

	local count = 0
	for _, re in ipairs(remoteEvents) do
		if not isScanning then break end
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			if safeMode and info.isDangerous then
				addLog("Skipped dangerous: " .. re.Name, "warning")
				continue
			end

			snapshotBackpack()
			pcall(function() re:FireServer() end)
			task.wait(0.05)
			pcall(function() re:FireServer(player) end)
			task.wait(0.05)
			pcall(function() re:FireServer(player, "all") end)
			task.wait(0.05)
			pcall(function() re:FireServer(true) end)
			task.wait(0.05)
			pcall(function() re:FireServer(1) end)

			local items = checkNewItems(re.Name)
			if #items > 0 then
				addLog("ITEMS from " .. re.Name .. ": " .. table.concat(items, ", "), "vuln")
				table.insert(vulnerableRemotes, {
					remote = re,
					name = re.Name,
					path = getRemotePath(re),
					items = items,
				})
				totalVulnerable = totalVulnerable + 1
			end
			count = count + 1
			task.wait(fireDelay)
		end
	end

	for _, rf in ipairs(remoteFunctions) do
		if not isScanning then break end
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			if safeMode and info.isDangerous then continue end

			snapshotBackpack()
			pcall(function()
				local result = rf:InvokeServer()
				if result ~= nil then
					addLog("RF Response " .. rf.Name .. ": " .. tostring(result):sub(1, 100), "info")
				end
			end)
			task.wait(0.05)
			pcall(function() rf:InvokeServer(player) end)
			task.wait(0.05)
			pcall(function() rf:InvokeServer(player, "all") end)

			local items = checkNewItems(rf.Name)
			if #items > 0 then
				addLog("ITEMS from " .. rf.Name .. ": " .. table.concat(items, ", "), "vuln")
				table.insert(vulnerableRemotes, {
					remote = rf,
					name = rf.Name,
					path = getRemotePath(rf),
					items = items,
				})
				totalVulnerable = totalVulnerable + 1
			end
			count = count + 1
			task.wait(fireDelay)
		end
	end

	addLog(string.format("Fired %d remotes total", count), "success")
	isScanning = false
	isFiring = false
end

