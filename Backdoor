-- FULL SCAN v3
-- ==========================================
local function runFullScan()
	if isScanning then
		addLog("Scan already running!", "warning")
		return
	end

	isScanning = true
	totalScanned = 0
	totalVulnerable = 0
	totalErrors = 0
	totalItems = 0
	totalResponses = 0
	scanResults = {}
	vulnerableRemotes = {}
	responseLog = {}

	addLog("══════════ STARTING FULL SCAN v3.0 ══════════", "info")

	-- Fingerprint game first
	fingerprintGame()

	-- Collect all remotes
	collectAllRemotes()

	-- Detect hidden remotes
	if obfuscationDetection then
		detectHiddenRemotes()
	end

	-- Scan module scripts
	if moduleScanning then
		scanModuleScripts()
	end

	-- Analyze and prioritize all remotes
	local allRemotes = {}

	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			info.instance = re
			info.isEvent = true
			table.insert(allRemotes, info)
		end
	end

	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			info.instance = rf
			info.isEvent = false
			table.insert(allRemotes, info)
		end
	end

	-- Sort by priority (highest first)
	table.sort(allRemotes, function(a, b) return a.priority > b.priority end)

	addLog(string.format("Scanning %d remotes (sorted by priority)...", #allRemotes), "info")
	addLog(string.format("Game type: %s | Security: %s | Brute force level: %d",
		gameFingerprint.gameType, gameFingerprint.securityLevel, bruteForceLevel), "info")

	local scanStartTime = os.clock()

	for idx, info in ipairs(allRemotes) do
		if not isScanning then
			addLog("Scan cancelled by user!", "warning")
			break
		end

		if not isValidInstance(info.instance) then continue end

		-- Priority label
		local labels = {}
		if info.isAdminRelated then table.insert(labels, "🔑ADMIN") end
		if info.isGiveRelated then table.insert(labels, "🎁GIVE") end
		if info.isItemRelated then table.insert(labels, "📦ITEM") end
		if info.isBackpackRelated then table.insert(labels, "🎒BP") end
		if info.isObfuscated then table.insert(labels, "🔒OBF:" .. (info.obfuscationType or "?")) end
		if info.isDangerous then table.insert(labels, "⚠️DANGER") end

		local labelStr = #labels > 0 and (" " .. table.concat(labels, " ")) or ""
		addLog(string.format("[%d/%d] %s: %s%s (priority: %d)",
			idx, #allRemotes, info.className, info.path, labelStr, info.priority), "info")

		-- Generate args based on context
		local testArgs = generateSmartArgs(info.name, info, bruteForceLevel)

		-- Limit args for low-priority remotes
		local maxArgs
		if info.priority >= 5 then
			maxArgs = #testArgs -- test all for high priority
		elseif info.priority >= 2 then
			maxArgs = math.min(maxArgCombinations * 2, #testArgs) -- medium
		else
			maxArgs = math.min(maxArgCombinations, #testArgs) -- low
		end

		local foundVuln = false
		for argIdx = 1, maxArgs do
			if not isScanning then break end
			if foundVuln and not info.isAdminRelated then break end -- skip rest if already found vuln (unless admin)

			local args = testArgs[argIdx]

			local ok, result, changes = pcall(function()
				return fireRemoteWithRetry(info.instance, args, info, info.isEvent)
			end)

			if ok and changes and changes.hasChanges then
				foundVuln = true
			end

			task.wait(fireDelay)
		end

		info.scanned = true
		table.insert(scanResults, info)

		task.wait(scanDelay)

		-- Progress update every 10 remotes
		if idx % 10 == 0 then
			addLog(string.format("Progress: %d/%d | Vulnerable: %d | Items: %d | Time: %.1fs",
				idx, #allRemotes, totalVulnerable, totalItems, os.clock() - scanStartTime), "info")
		end
	end

	local elapsed = os.clock() - scanStartTime

	addLog("══════════ SCAN COMPLETE ══════════", "success")
	addLog(string.format("Time: %.1fs | Scanned: %d | Vulnerable: %d | Errors: %d | Items: %d | Responses: %d",
		elapsed, totalScanned, totalVulnerable, totalErrors, totalItems, totalResponses), "success")

	if #vulnerableRemotes > 0 then
		addLog("══════════ VULNERABLE REMOTES ══════════", "vuln")
		for i, v in ipairs(vulnerableRemotes) do
			local itemNames = {}
			for _, item in ipairs(v.items or {}) do table.insert(itemNames, item.name) end
			for _, item in ipairs(v.charItems or {}) do table.insert(itemNames, item.name .. "(char)") end
			local statNames = {}
			for _, s in ipairs(v.statChanges or {}) do table.insert(statNames, s.name .. ":" .. tostring(s.diff)) end

			addLog(string.format("[%d] %s (%s) -> Items: %s | Stats: %s",
				i, v.name, v.path,
				#itemNames > 0 and table.concat(itemNames, ", ") or "none",
				#statNames > 0 and table.concat(statNames, ", ") or "none"
			), "vuln")
		end
	end

	isScanning = false
end

