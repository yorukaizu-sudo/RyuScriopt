local function scanModuleScripts()
	if not moduleScanning then return end
	moduleScripts = {}
	moduleLog = {}

	addLog("Scanning ModuleScripts for remote references...", "info")

	local function searchModules(parent)
		pcall(function()
			for _, desc in ipairs(parent:GetDescendants()) do
				pcall(function()
					if desc:IsA("ModuleScript") then
						table.insert(moduleScripts, desc)

						-- Try to require and analyze
						local success, result = pcall(function()
							return require(desc)
						end)

						if success and type(result) == "table" then
							local moduleInfo = {
								name = desc.Name,
								path = getRemotePath(desc),
								functions = {},
								remoteRefs = {},
								interesting = false
							}

							for key, value in pairs(result) do
								local keyStr = tostring(key):lower()
								if type(value) == "function" then
									table.insert(moduleInfo.functions, tostring(key))

									-- Check if function name relates to giving/items
									local isG = containsAnyKeyword(tostring(key), giveKeywords)
									local isI = containsAnyKeyword(tostring(key), itemKeywords)
									local isA = containsAnyKeyword(tostring(key), adminKeywords)
									if isG or isI or isA then
										moduleInfo.interesting = true
										addLog(string.format("Interesting module function: %s.%s",
											desc.Name, tostring(key)), "discovery")
									end
								elseif typeof(value) == "Instance" then
									if value:IsA("RemoteEvent") or value:IsA("RemoteFunction") then
										table.insert(moduleInfo.remoteRefs, {
											key = tostring(key),
											remote = value,
											remoteName = value.Name,
											remotePath = getRemotePath(value)
										})
										moduleInfo.interesting = true
										addLog(string.format("Module %s references remote: %s -> %s",
											desc.Name, tostring(key), value.Name), "discovery")
									end
								elseif type(value) == "table" then
									-- Deep check tables for remotes
									pcall(function()
										for k2, v2 in pairs(value) do
											if typeof(v2) == "Instance" and (v2:IsA("RemoteEvent") or v2:IsA("RemoteFunction")) then
												table.insert(moduleInfo.remoteRefs, {
													key = tostring(key) .. "." .. tostring(k2),
													remote = v2,
													remoteName = v2.Name,
													remotePath = getRemotePath(v2)
												})
												moduleInfo.interesting = true
											end
										end
									end)
								end
							end

							table.insert(moduleLog, moduleInfo)
						end
					end
				end)
			end
		end)
	end

	searchModules(ReplicatedStorage)
	pcall(function() searchModules(ReplicatedFirst) end)
	pcall(function() searchModules(StarterPlayer) end)
	pcall(function() searchModules(player.PlayerScripts) end)
	pcall(function() searchModules(player.PlayerGui) end)
	pcall(function() searchModules(Workspace) end)

	addLog(string.format("Scanned %d ModuleScripts, found %d interesting",
		#moduleScripts,
		#(function()
			local t = {}
			for _, m in ipairs(moduleLog) do if m.interesting then table.insert(t, m) end end
			return t
		end)()
	), "info")
end

