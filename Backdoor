-- ==========================================
-- REMOTE SPY (Simple)
-- ==========================================
local remoteSpyEnabled = false
local spyLog = {}
local spyConnection = nil

local function startRemoteSpy()
	if spyConnection then return end
	remoteSpyEnabled = true
	addLog("Remote Spy started!", "info")

	-- Hook __namecall to spy on remotes
	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then
			addLog("Cannot hook metatable for spy", "warning")
			return
		end
		local oldNC = mt.__namecall
		setreadonly(mt, false)
		mt.__namecall = newcclosure(function(self, ...)
			local method = getnamecallmethod()
			if remoteSpyEnabled then
				if (method == "FireServer" or method == "InvokeServer") and
				   (self:IsA("RemoteEvent") or self:IsA("RemoteFunction")) then
					local args = {...}
					local argStr = ""
					for i, arg in ipairs(args) do
						argStr = argStr .. tostring(typeof(arg)) .. ":" .. tostring(arg):sub(1, 50)
						if i < #args then argStr = argStr .. ", " end
					end
					local entry = {
						time = os.clock(),
						remote = self.Name,
						path = getRemotePath(self),
						method = method,
						args = argStr,
						argCount = #args,
					}
					table.insert(spyLog, entry)
					if #spyLog > 200 then table.remove(spyLog, 1) end
					addLog(string.format("[SPY] %s -> %s(%s)", method, self.Name, argStr:sub(1, 100)), "info")
				end
			end
			return oldNC(self, ...)
		end)
		setreadonly(mt, true)
	end)
end

local function stopRemoteSpy()
	remoteSpyEnabled = false
	addLog("Remote Spy stopped. Logged " .. #spyLog .. " calls", "info")
end

