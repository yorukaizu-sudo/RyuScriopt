local function collectAllRemotes()
	remoteEvents = {}
	remoteFunctions = {}
	bindableEvents = {}
	bindableFunctions = {}

	local searchLocations = {
		ReplicatedStorage,
		Workspace,
		Lighting,
		StarterGui,
		StarterPack,
		player.PlayerGui,
	}

	-- Also search player scripts
	pcall(function() table.insert(searchLocations, player.PlayerScripts) end)
	pcall(function() table.insert(searchLocations, player:FindFirstChild("PlayerGui")) end)

	-- Search character
	if player.Character then
		table.insert(searchLocations, player.Character)
	end

	for _, location in ipairs(searchLocations) do
		pcall(function()
			for _, desc in ipairs(location:GetDescendants()) do
				pcall(function()
					if desc:IsA("RemoteEvent") then
						table.insert(remoteEvents, desc)
					elseif desc:IsA("RemoteFunction") then
						table.insert(remoteFunctions, desc)
					elseif desc:IsA("BindableEvent") then
						table.insert(bindableEvents, desc)
					elseif desc:IsA("BindableFunction") then
						table.insert(bindableFunctions, desc)
					end
				end)
			end
		end)
	end

	-- Deep scan - search everywhere accessible
	if deepScanEnabled then
		pcall(function()
			for _, service in ipairs(game:GetChildren()) do
				pcall(function()
					for _, desc in ipairs(service:GetDescendants()) do
						pcall(function()
							if desc:IsA("RemoteEvent") and not table.find(remoteEvents, desc) then
								table.insert(remoteEvents, desc)
							elseif desc:IsA("RemoteFunction") and not table.find(remoteFunctions, desc) then
								table.insert(remoteFunctions, desc)
							end
						end)
					end
				end)
			end
		end)
	end

	addLog(string.format("Found: %d RemoteEvents, %d RemoteFunctions, %d BindableEvents, %d BindableFunctions",
		#remoteEvents, #remoteFunctions, #bindableEvents, #bindableFunctions), "info")
end

local function analyzeRemote(remote)
	local info = {
		name = remote.Name,
		path = getRemotePath(remote),
		className = remote.ClassName,
		isGiveRelated = false,
		isItemRelated = false,
		isAdminRelated = false,
		isDangerous = false,
		isBackpackRelated = false,
		priority = 0, -- higher = more interesting
		keywords = {},
		responses = {},
		vulnerable = false,
		itemsGiven = {},
	}

	local name = remote.Name

	local isGive, giveKw = containsAnyKeyword(name, giveKeywords)
	if isGive then info.isGiveRelated = true info.priority = info.priority + 3 table.insert(info.keywords, giveKw) end

	local isItem, itemKw = containsAnyKeyword(name, itemKeywords)
	if isItem then info.isItemRelated = true info.priority = info.priority + 2 table.insert(info.keywords, itemKw) end

	local isAdmin, adminKw = containsAnyKeyword(name, adminKeywords)
	if isAdmin then info.isAdminRelated = true info.priority = info.priority + 5 table.insert(info.keywords, adminKw) end

	local isDanger, dangerKw = containsAnyKeyword(name, dangerKeywords)
	if isDanger then info.isDangerous = true info.priority = info.priority - 10 table.insert(info.keywords, dangerKw) end

	local isBP, bpKw = containsAnyKeyword(name, backpackKeywords)
	if isBP then info.isBackpackRelated = true info.priority = info.priority + 2 table.insert(info.keywords, bpKw) end

	-- Check parent path for keywords too
	local pathStr = info.path:lower()
	for _, kw in ipairs(adminKeywords) do
		if pathStr:find(kw) and not info.isAdminRelated then
			info.isAdminRelated = true
			info.priority = info.priority + 3
		end
	end

	return info
end

local function fireRemoteEvent(remote, args, info)
	if safeMode and info and info.isDangerous then
		addLog("SKIPPED (dangerous): " .. remote.Name, "warning")
		return nil, "skipped_dangerous"
	end

	snapshotBackpack()

	local success, result = pcall(function()
		remote:FireServer(unpack(args))
	end)

	task.wait(0.1) -- wait for server response

	local newItems = checkNewItems(remote.Name)

	if #newItems > 0 then
		info.vulnerable = true
		info.itemsGiven = newItems
		totalVulnerable = totalVulnerable + 1
		addLog(string.format("GOT ITEMS from %s: %s (args: %s)",
			remote.Name,
			table.concat(newItems, ", "),
			tostring(#args) .. " args"
		), "vuln")
		table.insert(vulnerableRemotes, {
			remote = remote,
			name = remote.Name,
			path = getRemotePath(remote),
			args = args,
			items = newItems,
		})
	end

	if success then
		totalScanned = totalScanned + 1
		return true, newItems
	else
		totalErrors = totalErrors + 1
		return false, result
	end
end

local function fireRemoteFunction(remote, args, info)
	if safeMode and info and info.isDangerous then
		addLog("SKIPPED (dangerous): " .. remote.Name, "warning")
		return nil, "skipped_dangerous"
	end

	snapshotBackpack()

	local success, result = pcall(function()
		return remote:InvokeServer(unpack(args))
	end)

	task.wait(0.1)

	local newItems = checkNewItems(remote.Name)

	if #newItems > 0 then
		info.vulnerable = true
		info.itemsGiven = newItems
		totalVulnerable = totalVulnerable + 1
		addLog(string.format("GOT ITEMS from %s: %s", remote.Name, table.concat(newItems, ", ")), "vuln")
		table.insert(vulnerableRemotes, {
			remote = remote,
			name = remote.Name,
			path = getRemotePath(remote),
			args = args,
			items = newItems,
		})
	end

	-- Log response
	if success and result ~= nil then
		local responseStr = tostring(result)
		if typeof(result) == "table" then
			pcall(function()
				local parts = {}
				for k, v in pairs(result) do
					table.insert(parts, tostring(k) .. "=" .. tostring(v))
					if #parts > 10 then break end
				end
				responseStr = "{" .. table.concat(parts, ", ") .. "}"
			end)
		end
		table.insert(responseLog, {
			remote = remote.Name,
			path = getRemotePath(remote),
			args = #args,
			response = responseStr,
		})
		addLog(string.format("Response from %s: %s", remote.Name, responseStr:sub(1, 200)), "info")
	end

	if success then
		totalScanned = totalScanned + 1
		return true, result
	else
		totalErrors = totalErrors + 1
		return false, result
	end
end

-- ==========================================
-- FULL SCAN
-- ==========================================
local function runFullScan()
	if isScanning then
		addLog("Scan already running!", "warning")
		return
	end

	isScanning = true
	totalScanned = 0
	totalVulnerable = 0
	totalErrors = 0
	totalItems = 0
	scanResults = {}
	vulnerableRemotes = {}
	responseLog = {}

	addLog("========== STARTING FULL SCAN ==========", "info")
	collectAllRemotes()

	-- Analyze and sort by priority
	local allRemotes = {}

	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			info.instance = re
			info.isEvent = true
			table.insert(allRemotes, info)
		end
	end

	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			info.instance = rf
			info.isEvent = false
			table.insert(allRemotes, info)
		end
	end

	-- Sort: highest priority first
	table.sort(allRemotes, function(a, b) return a.priority > b.priority end)

	addLog(string.format("Scanning %d remotes (sorted by priority)...", #allRemotes), "info")

	for idx, info in ipairs(allRemotes) do
		if not isScanning then
			addLog("Scan cancelled!", "warning")
			break
		end

		if not isValidInstance(info.instance) then continue end

		local priorityLabel = ""
		if info.isAdminRelated then priorityLabel = " [ADMIN!]"
		elseif info.isGiveRelated then priorityLabel = " [GIVE]"
		elseif info.isItemRelated then priorityLabel = " [ITEM]"
		elseif info.isBackpackRelated then priorityLabel = " [BACKPACK]" end

		addLog(string.format("[%d/%d] %s: %s%s",
			idx, #allRemotes, info.className, info.path, priorityLabel), "info")

		local testArgs = generateTestArgs(info.name)

		-- Limit args for non-priority remotes
		local maxArgs = info.priority > 2 and #testArgs or math.min(maxArgCombinations, #testArgs)

		for argIdx = 1, maxArgs do
			if not isScanning then break end
			local args = testArgs[argIdx]

			pcall(function()
				if info.isEvent then
					fireRemoteEvent(info.instance, args, info)
				else
					fireRemoteFunction(info.instance, args, info)
				end
			end)

			task.wait(fireDelay)
		end

		info.scanned = true
		table.insert(scanResults, info)

		task.wait(scanDelay)
	end

	addLog("========== SCAN COMPLETE ==========", "success")
	addLog(string.format("Scanned: %d | Vulnerable: %d | Errors: %d | Items: %d",
		totalScanned, totalVulnerable, totalErrors, totalItems), "success")

	isScanning = false
end

