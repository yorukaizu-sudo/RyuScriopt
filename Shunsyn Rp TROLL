-- FLING TP MODE - TP Cepet Banget Kayak Fling
local FlingTPConnection
local currentPunchCount = 0
spawn(function()
    while true do
        wait()
        if AutoFlingTPEnabled then
            pcall(function()
                local validTargets = GetValidTargets()
                local hrp = GetHumanoidRootPart()
                local event = GetPunchEvent()
                
                if #validTargets > 0 and hrp then
                    -- Reset index jika melebihi
                    if CurrentTargetIndex > #validTargets then
                        CurrentTargetIndex = 1
                        currentPunchCount = 0
                    end
                    
                    local target = validTargets[CurrentTargetIndex]
                    
                    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local targetHRP = target.Character.HumanoidRootPart
                        
                        -- FLING STYLE TP - Random offset setiap frame
                        local randomOffset = CFrame.new(
                            math.random(-3, 3),
                            math.random(-1, 2),
                            math.random(-3, 3)
                        )
                        
                        hrp.CFrame = targetHRP.CFrame * randomOffset
                        
                        -- Punch super cepat
                        if event then
                            event:FireServer(7)
                            currentPunchCount = currentPunchCount + 1
                        end
                        
                        -- Pindah ke target berikutnya setelah X punches
                        if currentPunchCount >= PunchesPerTarget then
                            CurrentTargetIndex = CurrentTargetIndex + 1
                            currentPunchCount = 0
                            wait(0.1) -- Delay kecil sebelum pindah
                        end
                        
                        wait(FlingSpeed) -- Delay per fling
                    else
                        CurrentTargetIndex = CurrentTargetIndex + 1
                        currentPunchCount = 0
                    end
                end
            end)
        else
            currentPunchCount = 0
        end
    end
end)

-- HITBOX METHOD 1: Size Only
local OriginalSizes = {}
local function ExpandHitbox_SizeOnly(size)
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Player and v.Character then
                if not IsPlayerInVehicle(v) then
                    for _, part in pairs(v.Character:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name == "HumanoidRootPart" then
                            if not OriginalSizes[part] then
                                OriginalSizes[part] = part.Size
                            end
                            
                            part.Size = Vector3.new(size, size, size)
                            part.Transparency = 0.5
                            part.CanCollide = false
                            part.Massless = true
                        end
                    end
                end
            end
        end
    end)
end

-- HITBOX METHOD 2: Invisible Part
local InvisibleParts = {}
local function ExpandHitbox_InvisiblePart(size)
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                if not IsPlayerInVehicle(v) then
                    local hrp = v.Character.HumanoidRootPart
                    
                    if InvisibleParts[v.UserId] then
                        InvisibleParts[v.UserId]:Destroy()
                    end
                    
                    local hitbox = Instance.new("Part")
                    hitbox.Name = "Hitbox"
                    hitbox.Size = Vector3.new(size, size, size)
                    hitbox.Transparency = 1
                    hitbox.CanCollide = true
                    hitbox.Anchored = false
                    hitbox.Massless = true
                    hitbox.Parent = v.Character
                    
                    local weld = Instance.new("WeldConstraint")
                    weld.Part0 = hrp
                    weld.Part1 = hitbox
                    weld.Parent = hitbox
                    
                    InvisibleParts[v.UserId] = hitbox
                end
            end
        end
    end)
end

-- HITBOX METHOD 3: All Body Parts
local function ExpandHitbox_AllParts(size)
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Player and v.Character then
                if not IsPlayerInVehicle(v) then
                    for _, part in pairs(v.Character:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                            part.Size = Vector3.new(size/2, size/2, size/2)
                            part.Transparency = 0.7
                            part.CanCollide = false
                            part.Massless = true
                        end
                    end
                    
                    if v.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = v.Character.HumanoidRootPart
                        hrp.Size = Vector3.new(size, size, size)
                        hrp.Transparency = 0.5
                        hrp.CanCollide = false
                        hrp.Massless = true
                    end
                end
            end
        end
    end)
end

-- HITBOX METHOD 4: Force Field Style
local SelectionBoxes = {}
local function ExpandHitbox_ForceField(size)
    pcall(function()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                if not IsPlayerInVehicle(v) then
                    local hrp = v.Character.HumanoidRootPart
                    
                    hrp.Size = Vector3.new(size, size, size)
                    hrp.Transparency = 0.9
                    hrp.CanCollide = false
                    hrp.Massless = true
                    
                    if not SelectionBoxes[v.UserId] then
                        local box = Instance.new("SelectionBox")
                        box.Adornee = hrp
                        box.LineThickness = 0.05
                        box.Color3 = Color3.fromRGB(255, 0, 0)
                        box.Parent = hrp
                        SelectionBoxes[v.UserId] = box
                    end
                end
            end
        end
    end)
end

-- Main Expand Hitbox Function
local function ExpandHitbox(size)
    if HitboxMethod == "Size Only" then
        ExpandHitbox_SizeOnly(size)
    elseif HitboxMethod == "Invisible Part" then
        ExpandHitbox_InvisiblePart(size)
    elseif HitboxMethod == "All Body Parts" then
        ExpandHitbox_AllParts(size)
    elseif HitboxMethod == "Force Field" then
        ExpandHitbox_ForceField(size)
    end
end

-- Auto Expand Hitbox Loop
