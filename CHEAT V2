player.CharacterAdded:Connect(function(char)
	local hum=char:WaitForChild("Humanoid",10)
	if hum then lastHealth=hum.Health isFalling=false wasInAir=false end
	for _,pd in pairs(antiHitboxParts) do pcall(function() pd.fakePart:Destroy() end) end
	antiHitboxParts={}
	noRecoilOverriddenObjects={} noRecoilCurrentTool=nil noRecoilIsShooting=false noRecoilLockedCFrame=nil
	if noRecoilEnabled or noSpreadEnabled then
		task.wait(0.5)
		if char and char.Parent then setupToolListener(char) end
	end
end)

-- ==========================================
-- MAIN LOOP
-- ==========================================
RunService.RenderStepped:Connect(function(dt)
	local char=player.Character if not char then return end local now=tick()

	if noclip then applyNoclip() end
	applySpeed(dt) applyJump()
	if noFallDamage then applyNoFall() end
	if (noRecoilEnabled or noSpreadEnabled) and noRecoilCameraLock then applyNoRecoilCameraLock() end

	-- Aimlock
	if aimlockEnabled and aimlockHeld then
		if autoSwitchTarget and not isTargetValid(aimlockTarget) then aimlockTarget=getClosestInFOV() end
		if aimlockTarget and aimlockTarget.Character then
			local tp=aimlockTarget.Character:FindFirstChild(aimlockPart) or aimlockTarget.Character:FindFirstChild("HumanoidRootPart")
			local hum=aimlockTarget.Character:FindFirstChildOfClass("Humanoid")
			if tp and hum and hum.Health>0 then
				local myHrp=char:FindFirstChild("HumanoidRootPart")
				if myHrp and (myHrp.Position-tp.Position).Magnitude<=aimlockDistance then
					camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tp.Position),aimlockSmooth)
				else aimlockTarget=autoSwitchTarget and getClosestInFOV() or nil end
			else aimlockTarget=autoSwitchTarget and getClosestInFOV() or nil end
		end
	end

	if aimAssistEnabled then applyAimAssist(dt) end

	-- FOV Circles
	local cx,cy = camera.ViewportSize.X/2, camera.ViewportSize.Y/2
	if fovCircle then fovCircle.Position=Vector2.new(cx,cy) fovCircle.Radius=aimlockFOV fovCircle.Visible=showFOVCircle and aimlockEnabled end
	if aimAssistFOVCircle then aimAssistFOVCircle.Position=Vector2.new(cx,cy) aimAssistFOVCircle.Radius=aimAssistFOV aimAssistFOVCircle.Visible=showAimAssistFOV and aimAssistEnabled end
	if silentAimFOVCircle then silentAimFOVCircle.Position=Vector2.new(cx,cy) silentAimFOVCircle.Radius=silentAimFOV silentAimFOVCircle.Visible=silentAimShowFOV and silentAimEnabled end

	-- No Recoil
	if now-lastNoRecoilUpdate >= NO_RECOIL_UPDATE_RATE then
		lastNoRecoilUpdate=now
		if (noRecoilEnabled or noSpreadEnabled) and noRecoilValueOverride then refreshRecoilOverrides() end
		if noRecoilEnabled then overrideRecoilPhysics() end
	end

	-- Silent Aim Visual
	if now-lastSilentAimUpdate >= SILENT_AIM_UPDATE_RATE then
		lastSilentAimUpdate=now
		if silentAimEnabled then
			local t, tp = getSilentAimTarget()
			silentAimCurrentTarget = t
			if silentAimVisualLine and t and tp then
				local sp, onS = camera:WorldToViewportPoint(tp.Position)
				if onS then
					silentAimVisualLineObj.From=Vector2.new(cx,cy)
					silentAimVisualLineObj.To=Vector2.new(sp.X,sp.Y)
					silentAimVisualLineObj.Visible=true
					silentAimVisualLineObj.Color=tp.Name=="Head" and Color3.fromRGB(255,50,50) or Color3.fromRGB(255,0,255)
				else silentAimVisualLineObj.Visible=false end
			elseif silentAimVisualLineObj then silentAimVisualLineObj.Visible=false end
		else
			if silentAimVisualLineObj then silentAimVisualLineObj.Visible=false end
		end
	end

	-- ESP
	if now-lastESPUpdate >= ESP_UPDATE_RATE then lastESPUpdate=now if espEnabled then updatePlayerESP() end end

	-- Hitbox
	if now-lastHitboxUpdate >= HITBOX_UPDATE_RATE then
		lastHitboxUpdate=now
		if hitboxEnabled then updateHitboxExpander() end
		if antiHitboxEnabled then updateAntiHitbox() end
	end
end)

