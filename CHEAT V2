local function canSeeTarget(fromPos, targetPart)
	if not silentAimVisibleCheck then return true end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local dir = (targetPart.Position - fromPos)
	local result = workspace:Raycast(fromPos, dir, params)
	if result then
		local hm = result.Instance:FindFirstAncestorOfClass("Model")
		local tm = targetPart:FindFirstAncestorOfClass("Model")
		if hm and tm and hm == tm then return true end
		if result.Instance:IsDescendantOf(targetPart.Parent) then return true end
	end
	return result == nil
end

local function getSilentAimTargetPart(char)
	if silentAimAutoHeadshot and math.random(1,100) <= silentAimHeadshotChance then
		local head = char:FindFirstChild("Head")
		if head then return head end
	end
	if silentAimPart == "Head" then
		return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	elseif silentAimPart == "Body" then
		return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
	elseif silentAimPart == "Random" then
		local valid = {}
		for _, pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do
			local p = char:FindFirstChild(pn) if p then table.insert(valid, p) end
		end
		if #valid > 0 then return valid[math.random(1,#valid)] end
	elseif silentAimPart == "Nearest to Cursor" then
		local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
		local cp, cd = nil, math.huge
		for _, pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do
			local p = char:FindFirstChild(pn)
			if p then
				local sp, onS = camera:WorldToViewportPoint(p.Position)
				if onS then local sd = (Vector2.new(sp.X,sp.Y)-cs).Magnitude if sd < cd then cd=sd cp=p end end
			end
		end
		return cp or char:FindFirstChild("HumanoidRootPart")
	elseif silentAimPart == "Aim Assist Sync" then
		if aimAssistCurrentTarget and aimAssistCurrentTarget.Character == char and aimAssistLastChosenPart then
			local p = char:FindFirstChild(aimAssistLastChosenPart)
			if p then return p end
		end
		return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	end
	return char:FindFirstChild("HumanoidRootPart")
end

local function getPredictedPosition(targetPart, char)
	if not silentAimPrediction then return targetPart.Position end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return targetPart.Position end
	local vel = hrp.AssemblyLinearVelocity
	return targetPart.Position + Vector3.new(vel.X, 0, vel.Z) * silentAimPredictionAmount
end

local function getSilentAimTarget()
	local myChar = player.Character
	local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHrp then return nil, nil end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local closest, closestDist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				if silentAimTeamCheck and isTeammate(p) then continue end
				if (myHrp.Position - hrp.Position).Magnitude > silentAimDistance then continue end
				local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local sd = (Vector2.new(sp.X,sp.Y)-cs).Magnitude
					if sd <= silentAimFOV and sd < closestDist and canSeeTarget(myHrp.Position, hrp) then
						closestDist = sd
						closest = p
					end
				end
			end
		end
	end
	if closest and closest.Character then
		return closest, getSilentAimTargetPart(closest.Character)
	end
	return nil, nil
end

local function hookSilentAim()
	if silentAimHooked then return end
	silentAimHooked = true

	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then return end
		local oldIdx = mt.__index
		setreadonly(mt, false)
		mt.__index = newcclosure(function(self, key)
			if silentAimEnabled and self == mouse then
				if key == "Hit" or key == "hit" then
					local t, tp = getSilentAimTarget()
					if t and tp then
						silentAimCurrentTarget = t
						return CFrame.new(getPredictedPosition(tp, t.Character))
					end
				elseif key == "Target" or key == "target" then
					local t, tp = getSilentAimTarget()
					if t and tp then return tp end
				elseif key == "UnitRay" or key == "unitray" then
					local t, tp = getSilentAimTarget()
					if t and tp then
						local pos = getPredictedPosition(tp, t.Character)
						return Ray.new(camera.CFrame.Position, (pos-camera.CFrame.Position).Unit)
					end
				end
			end
			if key == "Size" and typeof(self)=="Instance" and self:IsA("BasePart") and self.Name == "HitboxOverlay" then
				return Vector3.new(2,2,1)
			end
			return oldIdx(self, key)
		end)
		setreadonly(mt, true)
	end)

	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldRC = workspace.Raycast
		hf(workspace.Raycast, newcclosure(function(self, origin, direction, rayParams, ...)
			if not silentAimEnabled then return oldRC(self, origin, direction, rayParams, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if myHrp and (origin-myHrp.Position).Magnitude < 15 then
				local t, tp = getSilentAimTarget()
				if t and tp and math.random(1,100) <= silentAimHitChance then
					local tPos = getPredictedPosition(tp, t.Character)
					return oldRC(self, origin, (tPos-origin).Unit * direction.Magnitude, rayParams, ...)
				end
			end
			return oldRC(self, origin, direction, rayParams, ...)
		end))
	end)

	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFPR = workspace.FindPartOnRay
		hf(workspace.FindPartOnRay, newcclosure(function(self, ray, ignoreList, ...)
			if not silentAimEnabled then return oldFPR(self, ray, ignoreList, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if myHrp and (ray.Origin-myHrp.Position).Magnitude < 15 then
				local t, tp = getSilentAimTarget()
				if t and tp and math.random(1,100) <= silentAimHitChance then
					local tPos = getPredictedPosition(tp, t.Character)
					return oldFPR(self, Ray.new(ray.Origin, (tPos-ray.Origin).Unit * ray.Direction.Magnitude), ignoreList, ...)
				end
			end
			return oldFPR(self, ray, ignoreList, ...)
		end))
	end)

	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFPR2 = workspace.FindPartOnRayWithIgnoreList
		if not oldFPR2 then return end
		hf(workspace.FindPartOnRayWithIgnoreList, newcclosure(function(self, ray, ignoreList, ...)
			if not silentAimEnabled then return oldFPR2(self, ray, ignoreList, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if myHrp and (ray.Origin-myHrp.Position).Magnitude < 15 then
				local t, tp = getSilentAimTarget()
				if t and tp and math.random(1,100) <= silentAimHitChance then
					local tPos = getPredictedPosition(tp, t.Character)
					return oldFPR2(self, Ray.new(ray.Origin, (tPos-ray.Origin).Unit * ray.Direction.Magnitude), ignoreList, ...)
				end
			end
			return oldFPR2(self, ray, ignoreList, ...)
		end))
	end)
end

local function hookBulletRedirect()
	if bulletRedirectHooked then return end
	bulletRedirectHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (silentAimEnabled or bulletRedirectEnabled) then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local isShoot = name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") or name:find("weapon") or name:find("gun") or name:find("hit") or name:find("damage") or name:find("ray") or name:find("cast") or name:find("projectile")
			if not isShoot then return oldFS(self, ...) end
			local t, tp = getSilentAimTarget()
			if not t or not tp or math.random(1,100) > silentAimHitChance then return oldFS(self, ...) end
			local tPos = getPredictedPosition(tp, t.Character)
			local args = {...}
			for i, arg in ipairs(args) do
				if typeof(arg) == "Vector3" then
					local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
					if myHrp then
						if arg.Unit:Dot(camera.CFrame.LookVector) > 0.5 then
							args[i] = (tPos-camera.CFrame.Position).Unit * arg.Magnitude
						elseif (arg-myHrp.Position).Magnitude > 5 then
							args[i] = tPos
						end
					end
				elseif typeof(arg) == "CFrame" then args[i] = CFrame.new(arg.Position, tPos)
				elseif typeof(arg) == "Ray" then args[i] = Ray.new(arg.Origin, (tPos-arg.Origin).Unit * arg.Direction.Magnitude)
				elseif typeof(arg) == "Instance" and arg:IsA("BasePart") then args[i] = tp
				elseif typeof(arg) == "table" then
					for k, v in pairs(arg) do
						if typeof(v)=="Vector3" and typeof(k)=="string" then
							local kl = k:lower()
							if kl:find("pos") or kl:find("hit") or kl:find("target") or kl:find("point") then arg[k]=tPos
							elseif kl:find("dir") or kl:find("look") or kl:find("aim") then arg[k]=(tPos-camera.CFrame.Position).Unit end
						elseif typeof(v)=="CFrame" and typeof(k)=="string" then
							if k:lower():find("aim") or k:lower():find("look") then arg[k]=CFrame.new(v.Position,tPos) end
						elseif typeof(v)=="Instance" and v:IsA("BasePart") and typeof(k)=="string" then
							if k:lower():find("hit") or k:lower():find("target") then arg[k]=tp end
						end
					end
				end
			end
			return oldFS(self, unpack(args))
		end))
	end)
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldIS
		oldIS = hf(Instance.new("RemoteFunction").InvokeServer, newcclosure(function(self, ...)
			if not (silentAimEnabled or bulletRedirectEnabled) then return oldIS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldIS(self, ...) end
			local isShoot = name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") or name:find("hit") or name:find("damage")
			if not isShoot then return oldIS(self, ...) end
			local t, tp = getSilentAimTarget()
			if not t or not tp or math.random(1,100)>silentAimHitChance then return oldIS(self, ...) end
			local tPos = getPredictedPosition(tp, t.Character)
			local args = {...}
			for i, arg in ipairs(args) do
				if typeof(arg)=="Vector3" and arg.Unit:Dot(camera.CFrame.LookVector)>0.5 then args[i]=(tPos-camera.CFrame.Position).Unit*arg.Magnitude
				elseif typeof(arg)=="CFrame" then args[i]=CFrame.new(arg.Position,tPos)
				elseif typeof(arg)=="Instance" and arg:IsA("BasePart") then args[i]=tp end
			end
			return oldIS(self, unpack(args))
		end))
	end)
end

