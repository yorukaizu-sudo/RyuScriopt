local function containsKeyword(name, keywords)
	local nl = name:lower()
	for _, kw in ipairs(keywords) do if nl:find(kw:lower()) then return true end end
	return false
end

local function isValidInstance(obj)
	local ok, r = pcall(function() return obj and obj.Parent ~= nil end)
	return ok and r
end

local function isTeammate(p)
	if not p then return false end
	return p.Team and player.Team and p.Team == player.Team
end

