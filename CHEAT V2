local function getAimAssistTargetPart(char)
	local now = tick()
	if aimAssistLastChosenPart and char:FindFirstChild(aimAssistLastChosenPart) and now-aimAssistLastPartSwitch < aimAssistPartSwitchRate then
		return char:FindFirstChild(aimAssistLastChosenPart)
	end
	aimAssistLastPartSwitch = now
	local pn = "HumanoidRootPart"
	if aimAssistTargetPart == "Dynamic" then
		if math.random(1,100) <= aimAssistHeadshotRate then pn="Head"
		else for _, n in ipairs({"HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do if char:FindFirstChild(n) then pn=n break end end end
	elseif aimAssistTargetPart == "Head" then pn="Head"
	elseif aimAssistTargetPart == "Body" then
		for _, n in ipairs({"HumanoidRootPart","UpperTorso","Torso"}) do if char:FindFirstChild(n) then pn=n break end end
	end
	aimAssistLastChosenPart = pn
	return char:FindFirstChild(pn) or char:FindFirstChild("HumanoidRootPart")
end

local function getAimAssistTarget()
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myHrp then return nil, math.huge end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local closest, cd = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				if aimAssistTeamCheck and isTeammate(p) then continue end
				if (myHrp.Position-hrp.Position).Magnitude > aimAssistDistance then continue end
				local sp, onS = camera:WorldToViewportPoint(hrp.Position)
				if onS then
					local sd = (Vector2.new(sp.X,sp.Y)-cs).Magnitude
					if sd <= aimAssistFOV and sd < cd then cd=sd closest=p end
				end
			end
		end
	end
	return closest, cd
end

local function isAimAssistTargetValid(p)
	if not p or not p.Parent or not p.Character then return false end
	local hum = p.Character:FindFirstChildOfClass("Humanoid")
	local hrp = p.Character:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp or hum.Health<=0 then return false end
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myHrp or (myHrp.Position-hrp.Position).Magnitude > aimAssistDistance then return false end
	local _, onS = camera:WorldToViewportPoint(hrp.Position)
	return onS
end

local function applyAimAssist(dt)
	if not aimAssistEnabled then return end
	local myChar = player.Character
	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
	if aimAssistOnlyWhileAiming then
		local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
		if not isAiming then aimAssistStickyTarget=nil aimAssistCurrentTarget=nil aimAssistFirstLock=false return end
	end
	local now = tick()
	local target = nil
	if aimAssistStickyAim and aimAssistStickyTarget then
		if isAimAssistTargetValid(aimAssistStickyTarget) then
			local hrp = aimAssistStickyTarget.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local sp, onS = camera:WorldToViewportPoint(hrp.Position)
				if onS and (Vector2.new(sp.X,sp.Y)-Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)).Magnitude <= aimAssistFOV*1.8 then
					target = aimAssistStickyTarget
				end
			end
		end
		if not target and now-lastStickyTime < aimAssistReattachDelay then return end
	end
	if not target then
		target = getAimAssistTarget()
		if target then aimAssistFirstLock=true aimAssistLastTargetSwitch=now end
	end
	if not target or not target.Character then aimAssistCurrentTarget=nil aimAssistStickyTarget=nil aimAssistFirstLock=false return end
	local isNew = (aimAssistStickyTarget ~= target)
	aimAssistStickyTarget=target aimAssistCurrentTarget=target lastStickyTime=now
	local tp = getAimAssistTargetPart(target.Character)
	if not tp then return end
	local tPos = tp.Position
	if aimAssistPrediction then
		local hrp = target.Character:FindFirstChild("HumanoidRootPart")
		if hrp then tPos = tPos + Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)*aimAssistPredictionAmount end
	end
	local tsp, onS = camera:WorldToViewportPoint(tPos)
	if not onS then return end
	local cs = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local offMag = (Vector2.new(tsp.X,tsp.Y)-cs).Magnitude
	if offMag <= aimAssistInnerDeadzone then camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tPos),0.95) return end
	local ms
	if offMag <= aimAssistSlowdownZone then
		local zf = 1-(offMag/aimAssistSlowdownZone)
		ms = aimAssistStrength*(0.6+zf*0.4)+aimAssistMagnetism*zf*0.5
	else
		local ff = 1-math.clamp((offMag-aimAssistSlowdownZone)/(aimAssistFOV-aimAssistSlowdownZone),0,1)
		ms = aimAssistStrength*(0.2+ff*0.4)
	end
	if aimAssistFirstLock and isNew then ms=math.min(ms+aimAssistSnapStrength*0.3,1) aimAssistFirstLock=false end
	local ts = aimAssistTrackingSmooth
	if aimAssistSmoothing and offMag < 30 then ts=ts*0.5 end
	ms = math.clamp(ms, 0.01, 0.95)
	local fl = math.clamp(ms*(1-ts)+ts, 0.02, 0.9)
	camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, tPos), fl)
end

