local function hookNoRecoilRemotes()
	if noRecoilHooked then return end
	noRecoilHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (noRecoilEnabled or noSpreadEnabled) then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local args = {...}
			if noRecoilEnabled and noRecoilRemoteIntercept then
				if name:find("recoil") or name:find("kick") or name:find("camerashake") or name:find("shake") then
					if noRecoilStrength >= 100 then return nil end
				end
			end
			if noSpreadEnabled and (name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet")) then
				for i, arg in ipairs(args) do
					if typeof(arg) == "Vector3" then
						local ld = camera.CFrame.LookVector
						if arg.Unit:Dot(ld) > 0.8 then
							args[i] = ld:Lerp(arg.Unit, 1-noSpreadStrength/100) * arg.Magnitude
						end
					elseif typeof(arg) == "table" then
						for k, v in pairs(arg) do
							if typeof(k)=="string" and typeof(v)=="number" then
								if containsKeyword(k, spreadKeywords) then arg[k]=v*(1-noSpreadStrength/100) end
								if containsKeyword(k, recoilKeywords) then arg[k]=v*(1-noRecoilStrength/100) end
							end
						end
					end
				end
				return oldFS(self, unpack(args))
			end
			return oldFS(self, ...)
		end))
	end)
end

