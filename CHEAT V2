local function overrideSingleValue(obj, isSpread)
	if not isValidInstance(obj) or not obj:IsA("ValueBase") then return end
	local key = tostring(obj)
	if noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj.Value end)
	if not ok or typeof(val) ~= "number" then return end
	local red = isSpread and (noSpreadStrength/100) or (noRecoilStrength/100)
	noRecoilOverriddenObjects[key] = {obj=obj, originalValue=val, type="value"}
	pcall(function() obj.Value = val * (1-red) end)
end

local function overrideSingleAttribute(obj, attrName, isSpread)
	if not isValidInstance(obj) then return end
	local key = tostring(obj).."_attr_"..attrName
	if noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj:GetAttribute(attrName) end)
	if not ok or typeof(val) ~= "number" then return end
	local red = isSpread and (noSpreadStrength/100) or (noRecoilStrength/100)
	noRecoilOverriddenObjects[key] = {obj=obj, attrName=attrName, originalValue=val, type="attribute"}
	pcall(function() obj:SetAttribute(attrName, val*(1-red)) end)
end

local function overrideTableRecoil(tbl, depth)
	depth = depth or 0
	if depth > 4 or typeof(tbl) ~= "table" then return end
	for key, val in pairs(tbl) do
		if typeof(key) == "string" then
			if noRecoilEnabled and typeof(val) == "number" then
				for _, kw in ipairs(recoilKeywords) do if key:lower():find(kw) then tbl[key] = val*(1-noRecoilStrength/100) break end end
			end
			if noSpreadEnabled and typeof(val) == "number" then
				for _, kw in ipairs(spreadKeywords) do if key:lower():find(kw) then tbl[key] = val*(1-noSpreadStrength/100) break end end
			end
			if typeof(val) == "table" then overrideTableRecoil(val, depth+1) end
		end
	end
end

local function scanEquippedTool(tool)
	if not tool or not isValidInstance(tool) or not tool:IsA("Tool") then return end
	local char = player.Character
	if not char or tool.Parent ~= char then return end
	noRecoilCurrentTool = tool
	for _, desc in ipairs(tool:GetDescendants()) do
		if not isValidInstance(desc) then continue end
		if desc:IsA("ValueBase") then
			if noRecoilEnabled and containsKeyword(desc.Name, recoilKeywords) then overrideSingleValue(desc, false) end
			if noSpreadEnabled and containsKeyword(desc.Name, spreadKeywords) then overrideSingleValue(desc, true) end
		end
		if desc:IsA("Configuration") or desc:IsA("Folder") then
			for _, child in ipairs(desc:GetChildren()) do
				if child:IsA("ValueBase") then
					if noRecoilEnabled and containsKeyword(child.Name, recoilKeywords) then overrideSingleValue(child, false) end
					if noSpreadEnabled and containsKeyword(child.Name, spreadKeywords) then overrideSingleValue(child, true) end
				end
			end
		end
		pcall(function()
			for an, av in pairs(desc:GetAttributes()) do
				if typeof(av) == "number" then
					if noRecoilEnabled and containsKeyword(an, recoilKeywords) then overrideSingleAttribute(desc, an, false) end
					if noSpreadEnabled and containsKeyword(an, spreadKeywords) then overrideSingleAttribute(desc, an, true) end
				end
			end
		end)
	end
	pcall(function()
		for an, av in pairs(tool:GetAttributes()) do
			if typeof(av) == "number" then
				if noRecoilEnabled and containsKeyword(an, recoilKeywords) then overrideSingleAttribute(tool, an, false) end
				if noSpreadEnabled and containsKeyword(an, spreadKeywords) then overrideSingleAttribute(tool, an, true) end
			end
		end
	end)
	for _, desc in ipairs(tool:GetDescendants()) do
		if desc:IsA("ModuleScript") then
			local n = desc.Name:lower()
			if n:find("recoil") or n:find("spread") or n:find("config") or n:find("stat") or n:find("setting") or n:find("weapon") or n:find("gun") then
				pcall(function()
					local md = require(desc)
					if typeof(md) == "table" then overrideTableRecoil(md) end
				end)
			end
		end
	end
end

local function restoreAllRecoilValues()
	for _, d in pairs(noRecoilOverriddenObjects) do
		pcall(function()
			if d.type == "value" and isValidInstance(d.obj) then d.obj.Value = d.originalValue
			elseif d.type == "attribute" and isValidInstance(d.obj) then d.obj:SetAttribute(d.attrName, d.originalValue) end
		end)
	end
	noRecoilOverriddenObjects = {}
	noRecoilCurrentTool = nil
	noRecoilIsShooting = false
	noRecoilLockedCFrame = nil
end

local function refreshRecoilOverrides()
	if not (noRecoilEnabled or noSpreadEnabled) or not noRecoilValueOverride then return end
	for key, d in pairs(noRecoilOverriddenObjects) do
		if not isValidInstance(d.obj) then noRecoilOverriddenObjects[key] = nil continue end
		pcall(function()
			if d.type == "value" then
				local cv = d.obj.Value
				if typeof(cv) == "number" then
					local isSp = containsKeyword(d.obj.Name, spreadKeywords)
					local red = isSp and (noSpreadStrength/100) or (noRecoilStrength/100)
					local tv = d.originalValue*(1-red)
					if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj.Value = tv end
				end
			elseif d.type == "attribute" then
				local cv = d.obj:GetAttribute(d.attrName)
				if typeof(cv) == "number" then
					local isSp = containsKeyword(d.attrName, spreadKeywords)
					local red = isSp and (noSpreadStrength/100) or (noRecoilStrength/100)
					local tv = d.originalValue*(1-red)
					if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj:SetAttribute(d.attrName, tv) end
				end
			end
		end)
	end
end

local function applyNoRecoilCameraLock()
	if not noRecoilCameraLock or not (noRecoilEnabled or noSpreadEnabled) then return end
	local shooting = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
	if shooting then
		if not noRecoilIsShooting then
			noRecoilIsShooting = true
			noRecoilLockedCFrame = camera.CFrame
		elseif noRecoilLockedCFrame then
			local str = noRecoilStrength/100
			local cp = camera.CFrame.Position
			local ll = noRecoilLockedCFrame.LookVector
			camera.CFrame = camera.CFrame:Lerp(CFrame.new(cp, cp+ll), str*0.8)
		end
	elseif noRecoilIsShooting then
		noRecoilIsShooting = false
		noRecoilLockedCFrame = nil
	end
end

