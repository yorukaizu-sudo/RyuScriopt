local function cleanHitboxForPlayer(p)
	local dd = hitboxData[p] if not dd then return end
	if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
	if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
	if dd.deathConn then pcall(function() dd.deathConn:Disconnect() end) end
	if p.Character then local hrp = p.Character:FindFirstChild("HumanoidRootPart") if hrp then hrp.CanQuery = true end end
	dd.overlayPart=nil dd.espVisual=nil dd.trackedChar=nil dd.deathConn=nil
end

local function createHitboxOverlay(p)
	if not p.Character then return end
	local hrp = p.Character:FindFirstChild("HumanoidRootPart")
	local hum = p.Character:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum or hum.Health <= 0 then return end
	if not hitboxData[p] then hitboxData[p] = {} end
	local dd = hitboxData[p]
	if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
	if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
	local ov = Instance.new("Part") ov.Name="HitboxOverlay"
	ov.Size=Vector3.new(hitboxSize,hitboxSize,hitboxSize)
	ov.Transparency=hitboxTransparency ov.CanCollide=false ov.CanQuery=true
	ov.Anchored=false ov.Massless=true ov.Material=Enum.Material.ForceField
	ov.Color=hitboxESPColor ov.Parent=p.Character
	local w = Instance.new("WeldConstraint") w.Part0=hrp w.Part1=ov w.Parent=ov
	ov.CFrame=hrp.CFrame hrp.CanQuery=false
	dd.overlayPart=ov dd.trackedChar=p.Character
	dd.deathConn = hum.Died:Connect(function() task.wait(0.5) cleanHitboxForPlayer(p) end)
end

local function updateHitboxExpander()
	if not hitboxEnabled then return end
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.Health > 0 then
				if not hitboxData[p] then hitboxData[p] = {} end
				local dd = hitboxData[p]
				if not dd.overlayPart or not dd.overlayPart.Parent or dd.trackedChar ~= p.Character then
					if dd.deathConn then pcall(function() dd.deathConn:Disconnect() end) end
					createHitboxOverlay(p)
				else
					dd.overlayPart.Size=Vector3.new(hitboxSize,hitboxSize,hitboxSize)
					dd.overlayPart.Transparency=hitboxTransparency
					dd.overlayPart.Color=hitboxESPColor
					if hrp.CanQuery then hrp.CanQuery=false end
				end
				if hitboxESPEnabled and dd.overlayPart and dd.overlayPart.Parent then
					if not dd.espVisual or not dd.espVisual.Parent then
						local b = Instance.new("BoxHandleAdornment") b.Adornee=dd.overlayPart b.Size=dd.overlayPart.Size
						b.Color3=hitboxESPColor b.Transparency=0.5 b.AlwaysOnTop=true b.ZIndex=10 b.Parent=dd.overlayPart
						dd.espVisual=b
					else dd.espVisual.Size=dd.overlayPart.Size dd.espVisual.Color3=hitboxESPColor end
				elseif dd.espVisual then pcall(function() dd.espVisual:Destroy() end) dd.espVisual=nil end
			elseif hitboxData[p] and hitboxData[p].overlayPart then cleanHitboxForPlayer(p) end
		end
	end
	for p in pairs(hitboxData) do if not p.Parent then cleanHitboxForPlayer(p) hitboxData[p]=nil end end
end

local function disableHitboxExpander()
	for p in pairs(hitboxData) do
		if hitboxData[p].deathConn then pcall(function() hitboxData[p].deathConn:Disconnect() end) end
		cleanHitboxForPlayer(p)
	end
	hitboxData = {}
end

local function updateAntiHitbox()
	if not antiHitboxEnabled then return end
	local mc = player.Character
	if not mc or not mc:FindFirstChild("HumanoidRootPart") then return end
	for _, pn in ipairs({"Head","Torso","UpperTorso","LowerTorso","LeftArm","RightArm","LeftLeg","RightLeg","Left Arm","Right Arm","Left Leg","Right Leg","HumanoidRootPart"}) do
		local part = mc:FindFirstChild(pn)
		if part and part:IsA("BasePart") then
			if not antiHitboxParts[pn] then antiHitboxParts[pn] = {} end
			local d = antiHitboxParts[pn]
			if not d.fakePart or not d.fakePart.Parent then
				local fp = Instance.new("Part") fp.Name="AH_"..pn fp.Size=Vector3.new(antiHitboxSize,antiHitboxSize,antiHitboxSize)
				fp.Transparency=1 fp.CanCollide=false fp.CanQuery=true fp.Anchored=false fp.Massless=true fp.Parent=mc
				local w = Instance.new("WeldConstraint") w.Part0=part w.Part1=fp w.Parent=fp
				fp.CFrame=part.CFrame d.fakePart=fp
			else d.fakePart.Size=Vector3.new(antiHitboxSize,antiHitboxSize,antiHitboxSize) end
			part.CanQuery=false
		end
	end
end

