local flightSpeed = 1.0

-- ==================== HELPER FUNCTIONS ====================

local function GetVehicleFromDescendant(Descendant)
    return
        Descendant:FindFirstAncestor(LocalPlayer.Name .. "'s Car") or
        (Descendant:FindFirstAncestor("Body") and Descendant:FindFirstAncestor("Body").Parent) or
        (Descendant:FindFirstAncestor("Misc") and Descendant:FindFirstAncestor("Misc").Parent) or
        Descendant:FindFirstAncestorWhichIsA("Model")
end

local function GetSeatPart()
    local Character = LocalPlayer.Character
    if not Character then return nil end
    local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
    if not Humanoid then return nil end
    local SeatPart = Humanoid.SeatPart
    if SeatPart and SeatPart:IsA("VehicleSeat") then
        return SeatPart
    end
    return nil
end

local function GetHorizontalSpeed(SeatPart)
    local vel = SeatPart.AssemblyLinearVelocity
    return Vector3.new(vel.X, 0, vel.Z).Magnitude
end

local function ClampVelocity(SeatPart)
    local vel = SeatPart.AssemblyLinearVelocity
    local horizontal = Vector3.new(vel.X, 0, vel.Z)
    local currentSpeed = horizontal.Magnitude
    if currentSpeed > speedLimit then
        local clamped = horizontal.Unit * speedLimit
        SeatPart.AssemblyLinearVelocity = Vector3.new(clamped.X, vel.Y, clamped.Z)
    end
end

-- ==================== FLIGHT SYSTEM ====================

local defaultCharacterParent
RunService.Stepped:Connect(function()
    local Character = LocalPlayer.Character
    if flightEnabled then
        if Character then
            local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
            if Humanoid then
                local SeatPart = Humanoid.SeatPart
                if SeatPart and SeatPart:IsA("VehicleSeat") then
                    local Vehicle = GetVehicleFromDescendant(SeatPart)
                    if Vehicle and Vehicle:IsA("Model") then
                        Character.Parent = Vehicle
                        if not Vehicle.PrimaryPart then
                            Vehicle.PrimaryPart = SeatPart.Parent == Vehicle and SeatPart or Vehicle:FindFirstChildWhichIsA("BasePart")
                        end
                        local PrimaryPartCFrame = Vehicle:GetPrimaryPartCFrame()
                        local moveX = (UIS:IsKeyDown(Enum.KeyCode.D) and flightSpeed) or (UIS:IsKeyDown(Enum.KeyCode.A) and -flightSpeed) or 0
                        local moveY = (UIS:IsKeyDown(Enum.KeyCode.E) and flightSpeed / 2) or (UIS:IsKeyDown(Enum.KeyCode.Q) and -flightSpeed / 2) or 0
                        local moveZ = (UIS:IsKeyDown(Enum.KeyCode.S) and flightSpeed) or (UIS:IsKeyDown(Enum.KeyCode.W) and -flightSpeed) or 0
                        Vehicle:SetPrimaryPartCFrame(
                            CFrame.new(
                                PrimaryPartCFrame.Position,
                                PrimaryPartCFrame.Position + workspace.CurrentCamera.CFrame.LookVector
                            ) * (UIS:GetFocusedTextBox() and CFrame.new(0,0,0) or CFrame.new(moveX, moveY, moveZ))
                        )
                        SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end
    else
        if Character then
            Character.Parent = defaultCharacterParent or Character.Parent
            defaultCharacterParent = Character.Parent
        end
    end
end)

-- ==================== SPEED LIMIT ENFORCER ====================
RunService.Heartbeat:Connect(function()
    if not speedEnabled then return end
    if not limitEnabled then return end
    if flightEnabled then return end
    local SeatPart = GetSeatPart()
    if not SeatPart then return end
    ClampVelocity(SeatPart)
end)

-- ==================== INPUT: W / S / P ====================
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not speedEnabled then return end
    if flightEnabled then return end

    -- W = Acceleration
    if input.KeyCode == Enum.KeyCode.W then
        task.spawn(function()
            while UIS:IsKeyDown(Enum.KeyCode.W) do
                task.wait(0)
                if not speedEnabled or flightEnabled then break end
                local SeatPart = GetSeatPart()
                if SeatPart then
                    -- Cek limit sebelum boost
                    local currentSpeed = GetHorizontalSpeed(SeatPart)
                    if not limitEnabled or currentSpeed < speedLimit then
                        local vel = SeatPart.AssemblyLinearVelocity
                        SeatPart.AssemblyLinearVelocity = Vector3.new(
                            vel.X * (1 + velocityMult),
                            vel.Y,
                            vel.Z * (1 + velocityMult)
                        )
                        -- Clamp setelah boost jika limit aktif
                        if limitEnabled then
                            ClampVelocity(SeatPart)
                        end
                    end
                end
            end
        end)
    end

    -- S = Brake
    if input.KeyCode == Enum.KeyCode.S then
        task.spawn(function()
            while UIS:IsKeyDown(Enum.KeyCode.S) do
                task.wait(0)
                if not speedEnabled or flightEnabled then break end
                local SeatPart = GetSeatPart()
                if SeatPart then
                    local vel = SeatPart.AssemblyLinearVelocity
                    SeatPart.AssemblyLinearVelocity = Vector3.new(
                        vel.X * (1 - velocityMult2),
                        vel.Y,
                        vel.Z * (1 - velocityMult2)
                    )
                end
            end
        end)
    end

    -- P = Stop Total
    if input.KeyCode == Enum.KeyCode.P then
        local SeatPart = GetSeatPart()
        if SeatPart then
            SeatPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            SeatPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            Fluent:Notify({
                Title = "🛑 ZalStore | STOP",
                Content = "Kendaraan dihentikan paksa!",
                Duration = 2
            })
        end
    end
end)

