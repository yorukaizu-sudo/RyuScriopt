	local function enableAntiKick()
		if antiKickHooked then return end
		antiKickHooked = true

		-- Hook Kick via namecall
		pcall(function()
			local mt = getrawmetatable(game)
			if mt then
				local oldNamecall = mt.__namecall
				setreadonly(mt, false)
				mt.__namecall = newcclosure(function(self, ...)
					local method = getnamecallmethod()
					if method == "Kick" and self == player then return nil end
					if method == "Destroy" and self == player then return nil end
					return oldNamecall(self, ...)
				end)
				setreadonly(mt, true)
			end
		end)

		-- Hook Player.Kick
		pcall(function()
			local oldKick = player.Kick
			player.Kick = function(self, ...)
				if self == player then return nil end
				return oldKick(self, ...)
			end
		end)

		-- Hook __index to spoof HRP size checks
		pcall(function()
			local mt = getrawmetatable(game)
			if mt then
				local oldIndex = mt.__index
				setreadonly(mt, false)
				mt.__index = newcclosure(function(self, key)
					-- If anti-cheat checks HRP Size, return normal size
					if key == "Size" and self:IsA("BasePart") then
						local parentModel = self:FindFirstAncestorOfClass("Model")
						if parentModel then
							for _, p in ipairs(Players:GetPlayers()) do
								if p ~= player and p.Character == parentModel then
									if self.Name == "HumanoidRootPart" and hitboxEnabled then
										-- Return fake normal size to anti-cheat
										return Vector3.new(2, 2, 1)
									end
								end
							end
						end
					end
					return oldIndex(self, key)
				end)
				setreadonly(mt, true)
			end
		end)

		-- Block anti-cheat remotes
		pcall(function()
			local hookFunc = hookfunction or replaceclosure
			if hookFunc then
				local oldFire
				oldFire = hookFunc(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
					local name = self.Name:lower()
					if name:find("kick") or name:find("ban") or name:find("punish") or
					   name:find("anticheat") or name:find("anti_cheat") or name:find("detect") or
					   name:find("violation") or name:find("report") or name:find("security") then
						return nil
					end
					return oldFire(self, ...)
				end))
			end
		end)
	end

