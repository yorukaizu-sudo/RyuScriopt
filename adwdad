	local function updatePromptCache()
		local now = tick()
		if now - lastPromptCacheUpdate < PROMPT_CACHE_RATE then return end
		lastPromptCacheUpdate = now
		cachedPrompts = {}
		cachedClickDetectors = {}
		for _, v in ipairs(workspace:GetDescendants()) do
			if v:IsA("ProximityPrompt") then table.insert(cachedPrompts, v)
			elseif v:IsA("ClickDetector") then table.insert(cachedClickDetectors, v) end
		end
	end

	local function updateVehicleCache()
		local now = tick()
		if now - lastVehicleCacheUpdate < VEHICLE_CACHE_RATE then return cachedVehicles end
		lastVehicleCacheUpdate = now
		cachedVehicles = {}
		local added = {}
		for _, v in ipairs(workspace:GetDescendants()) do
			if v:IsA("VehicleSeat") then
				local m = v:FindFirstAncestorOfClass("Model")
				if m and not added[m] then added[m] = true table.insert(cachedVehicles, {Name=m.Name, Model=m, Seat=v}) end
			end
		end
		return cachedVehicles
	end
	local function getAllVehicles() return updateVehicleCache() end

