	local function getAimAssistTargetPart(char)
		if aimAssistTargetPart == "Dynamic" then
			-- Use headshot rate to decide
			local roll = math.random(1, 100)
			if roll <= aimAssistHeadshotRate then
				return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
			else
				-- Random body part
				local bodyParts = {"HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso"}
				local chosen = bodyParts[math.random(1, #bodyParts)]
				return char:FindFirstChild(chosen) or char:FindFirstChild("HumanoidRootPart")
			end
		elseif aimAssistTargetPart == "Head" then
			return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
		elseif aimAssistTargetPart == "Body" then
			return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
		end
		return char:FindFirstChild("HumanoidRootPart")
	end

	local function getClosestPlayerToMouse()
		local myChar = player.Character
		local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myHrp then return nil, math.huge end

		local mousePos = Vector2.new(mouse.X, mouse.Y)
		local closest = nil
		local closestDist = math.huge

		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				local hrp = p.Character:FindFirstChild("HumanoidRootPart")

				if hum and hrp and hum.Health > 0 then
					-- Team check
					if aimAssistTeamCheck and isTeammate(p) then continue end

					-- Distance check
					local dist3D = (myHrp.Position - hrp.Position).Magnitude
					if dist3D > aimAssistDistance then continue end

					-- Screen distance
					local screenPos, onScreen = camera:WorldToScreenPoint(hrp.Position)
					if onScreen then
						local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
						if screenDist <= aimAssistFOV and screenDist < closestDist then
							closestDist = screenDist
							closest = p
						end
					end
				end
			end
		end

		return closest, closestDist
	end

	local function applyAimAssist()
		if not aimAssistEnabled then return end

		local myChar = player.Character
		if not myChar then return end

		-- Only assist when mouse is held down (shooting)
		local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or
		                  UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

		if not isAiming then
			aimAssistStickyTarget = nil
			return
		end

		local target, screenDist

		-- Sticky aim: keep targeting same player if still valid
		if aimAssistStickyAim and aimAssistStickyTarget then
			local now = tick()
			if now - lastStickyTime < aimAssistStickyTimeout then
				local p = aimAssistStickyTarget
				if p.Character and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
					target = p
					local hrp = p.Character:FindFirstChild("HumanoidRootPart")
					if hrp then
						local sp = camera:WorldToScreenPoint(hrp.Position)
						screenDist = (Vector2.new(sp.X, sp.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
					end
				end
			end
		end

		if not target then
			target, screenDist = getClosestPlayerToMouse()
		end

		if not target or not target.Character then return end

		-- Update sticky
		aimAssistStickyTarget = target
		lastStickyTime = tick()

		local targetPart = getAimAssistTargetPart(target.Character)
		if not targetPart then return end

		-- Calculate target position with prediction
		local targetPos = targetPart.Position
		if aimAssistPrediction then
			local hrp = target.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				targetPos = targetPos + hrp.AssemblyLinearVelocity * aimAssistPredictionAmount
			end
		end

		-- Calculate aim offset
		local targetScreenPos, onScreen = camera:WorldToScreenPoint(targetPos)
		if not onScreen then return end

		local mouseScreenPos = Vector2.new(mouse.X, mouse.Y)
		local targetScreen2D = Vector2.new(targetScreenPos.X, targetScreenPos.Y)
		local offset = targetScreen2D - mouseScreenPos

		-- Only assist if within FOV
		if offset.Magnitude > aimAssistFOV then return end

		-- Apply strength (0 = no assist, 1 = full lock)
		local strength = aimAssistStrength

		-- Smoothing: reduce strength based on distance
		if aimAssistSmoothing then
			local distFactor = 1 - (offset.Magnitude / aimAssistFOV)
			strength = strength * (0.5 + distFactor * 0.5)
		end

		-- Apply camera adjustment
		local currentCF = camera.CFrame
		local targetCF = CFrame.new(currentCF.Position, targetPos)
		camera.CFrame = currentCF:Lerp(targetCF, strength)
	end

