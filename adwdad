	-- ==========================================
	-- ANTI KICK
	-- ==========================================
	local function enableAntiKick()
		if antiKickHooked then return end
		antiKickHooked = true
		pcall(function()
			local mt = getrawmetatable(game)
			if mt then
				local oldNC = mt.__namecall
				setreadonly(mt, false)
				mt.__namecall = newcclosure(function(self, ...)
					local m = getnamecallmethod()
					if (m == "Kick" or m == "Destroy") and self == player then return nil end
					return oldNC(self, ...)
				end)
				local oldIdx = mt.__index
				mt.__index = newcclosure(function(self, key)
					if key == "Size" and self:IsA("BasePart") and self.Name == "HitboxOverlay" then
						return Vector3.new(2, 2, 1)
					end
					return oldIdx(self, key)
				end)
				setreadonly(mt, true)
			end
		end)
		pcall(function()
			player.Kick = function(self, ...) if self == player then return nil end end
		end)
		pcall(function()
			local hf = hookfunction or replaceclosure
			if hf then
				local oldFS
				oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
					local n = self.Name:lower()
					if n:find("kick") or n:find("ban") or n:find("anticheat") or n:find("anti_cheat") or n:find("detect") or n:find("violation") or n:find("report") or n:find("security") or n:find("punish") then
						return nil
					end
					return oldFS(self, ...)
				end))
			end
		end)
	end

	-- ==========================================
	-- NOCLIP
	-- ==========================================
	local function applyNoclip()
		if not noclip then return end
		local char = player.Character
		if not char then return end
		for _, v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then v.CanCollide = false end
		end
		if noclipMethod == "Phase Bypass" then
			pcall(function() char:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Running) end)
		elseif noclipMethod == "Velocity Bypass" then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp and hrp.AssemblyLinearVelocity.Magnitude > 60 then
				hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity.Unit * 60
			end
		elseif noclipMethod == "CFrame Bypass" then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.MoveDirection.Magnitude > 0 then
				local params = RaycastParams.new()
				params.FilterDescendantsInstances = {char}
				params.FilterType = Enum.RaycastFilterType.Exclude
				if workspace:Raycast(hrp.Position, hum.MoveDirection * 3, params) then
					hrp.CFrame = hrp.CFrame + hum.MoveDirection * 1.5
				end
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				hrp.CFrame = hrp.CFrame + Vector3.new(0, 1, 0)
			end
		end
	end

