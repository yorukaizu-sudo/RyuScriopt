	-- AIM ASSIST (REBUILT - SUPER STICKY/NEMPEL)
	-- ==========================================

	-- Pilih target part berdasarkan headshot rate
	local function getAimAssistTargetPart(char)
		local now = tick()
		-- Hanya ganti part setiap interval tertentu supaya tidak loncat-loncat
		if aimAssistLastChosenPart and char:FindFirstChild(aimAssistLastChosenPart) then
			if now - aimAssistLastPartSwitch < aimAssistPartSwitchRate then
				return char:FindFirstChild(aimAssistLastChosenPart)
			end
		end
		aimAssistLastPartSwitch = now

		local partName = "HumanoidRootPart"
		if aimAssistTargetPart == "Dynamic" then
			local roll = math.random(1, 100)
			if roll <= aimAssistHeadshotRate then
				partName = "Head"
			else
				local bodyParts = {"HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso"}
				for _, name in ipairs(bodyParts) do
					if char:FindFirstChild(name) then partName = name break end
				end
			end
		elseif aimAssistTargetPart == "Head" then
			partName = "Head"
		elseif aimAssistTargetPart == "Body" then
			for _, name in ipairs({"HumanoidRootPart", "UpperTorso", "Torso"}) do
				if char:FindFirstChild(name) then partName = name break end
			end
		end

		aimAssistLastChosenPart = partName
		return char:FindFirstChild(partName) or char:FindFirstChild("HumanoidRootPart")
	end

	-- Cari target terdekat ke crosshair
	local function getAimAssistTarget()
		local myChar = player.Character
		local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myHrp then return nil, math.huge end

		local vpSize = camera.ViewportSize
		local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
		local closest = nil
		local closestScreenDist = math.huge

		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				local hrp = p.Character:FindFirstChild("HumanoidRootPart")
				if hum and hrp and hum.Health > 0 then
					if aimAssistTeamCheck and isTeammate(p) then continue end
					local dist3D = (myHrp.Position - hrp.Position).Magnitude
					if dist3D > aimAssistDistance then continue end
					local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
					if onScreen then
						local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
						if screenDist <= aimAssistFOV and screenDist < closestScreenDist then
							closestScreenDist = screenDist
							closest = p
						end
					end
				end
			end
		end
		return closest, closestScreenDist
	end

	-- Validasi target masih hidup dan dalam jangkauan
	local function isAimAssistTargetValid(p)
		if not p or not p.Parent or not p.Character then return false end
		local hum = p.Character:FindFirstChildOfClass("Humanoid")
		local hrp = p.Character:FindFirstChild("HumanoidRootPart")
		if not hum or not hrp or hum.Health <= 0 then return false end
		local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHrp then return false end
		if (myHrp.Position - hrp.Position).Magnitude > aimAssistDistance then return false end
		-- Cek masih di layar
		local _, onScreen = camera:WorldToViewportPoint(hrp.Position)
		return onScreen
	end

	-- MAIN AIM ASSIST FUNCTION - Setiap frame
	local function applyAimAssist(dt)
		if not aimAssistEnabled then return end

		local myChar = player.Character
		if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end

		-- Cek apakah sedang nembak/aim
		if aimAssistOnlyWhileAiming then
			local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or
				UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
			if not isAiming then
				aimAssistStickyTarget = nil
				aimAssistCurrentTarget = nil
				aimAssistFirstLock = false
				aimAssistAccumX = 0
				aimAssistAccumY = 0
				return
			end
		end

		local now = tick()
		local target = nil

		-- STICKY: Tetap di target yang sama selama masih valid
		if aimAssistStickyAim and aimAssistStickyTarget then
			if isAimAssistTargetValid(aimAssistStickyTarget) then
				-- Cek apakah target masih dalam FOV yang diperbesar (1.5x) untuk sticky
				local hrp = aimAssistStickyTarget.Character:FindFirstChild("HumanoidRootPart")
				if hrp then
					local vpSize = camera.ViewportSize
					local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
					local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
					if onScreen then
						local screenDist = (Vector2.new(sp.X, sp.Y) - centerScreen).Magnitude
						-- Sticky FOV = 1.8x normal FOV (susah lepas)
						if screenDist <= aimAssistFOV * 1.8 then
							target = aimAssistStickyTarget
						end
					end
				end
			end
			-- Kalau target sudah tidak valid, tunggu reattach delay
			if not target then
				if now - lastStickyTime < aimAssistReattachDelay then
					return -- Tunggu sebentar sebelum cari target baru
				end
			end
		end

		-- Cari target baru
		if not target then
			target = getAimAssistTarget()
			if target then
				aimAssistFirstLock = true
				aimAssistLastTargetSwitch = now
			end
		end

		if not target or not target.Character then
			aimAssistCurrentTarget = nil
			aimAssistStickyTarget = nil
			aimAssistFirstLock = false
			return
		end

		-- Update sticky tracking
		local isNewTarget = (aimAssistStickyTarget ~= target)
		aimAssistStickyTarget = target
		aimAssistCurrentTarget = target
		lastStickyTime = now

		-- Ambil target part
		local targetPart = getAimAssistTargetPart(target.Character)
		if not targetPart then return end

		-- Hitung posisi target
		local targetPos = targetPart.Position

		-- Prediction: prediksi gerakan musuh
		if aimAssistPrediction then
			local hrp = target.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local vel = hrp.AssemblyLinearVelocity
				-- Hanya prediksi horizontal, bukan vertikal
				targetPos = targetPos + Vector3.new(vel.X, 0, vel.Z) * aimAssistPredictionAmount
			end
		end

		-- Cek apakah target di layar
		local targetScreenPos, onScreen = camera:WorldToViewportPoint(targetPos)
		if not onScreen then return end

		-- Hitung offset dari center screen ke target
		local vpSize = camera.ViewportSize
		local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
		local targetScreen2D = Vector2.new(targetScreenPos.X, targetScreenPos.Y)
		local offset = targetScreen2D - centerScreen
		local offsetMag = offset.Magnitude

		-- Kalau sudah di dalam deadzone, full lock
		if offsetMag <= aimAssistInnerDeadzone then
			-- Sudah pas di target, maintain position
			local currentCF = camera.CFrame
			local lookAt = CFrame.new(currentCF.Position, targetPos)
			camera.CFrame = currentCF:Lerp(lookAt, 0.95)
			return
		end

		-- Hitung strength berdasarkan jarak dari crosshair
		local baseStrength = aimAssistStrength

		-- Zona magnetism: semakin dekat ke target, semakin kuat tarikannya
		local magnetStrength
		if offsetMag <= aimAssistSlowdownZone then
			-- Di dalam slowdown zone: tarikan sangat kuat
			local zoneFactor = 1 - (offsetMag / aimAssistSlowdownZone) -- 1 = di center, 0 = di edge
			magnetStrength = baseStrength * (0.6 + zoneFactor * 0.4) -- Min 60% strength
			-- Tambah magnetism
			magnetStrength = magnetStrength + aimAssistMagnetism * zoneFactor * 0.5
		else
			-- Di luar slowdown zone tapi masih dalam FOV
			local fovFactor = 1 - math.clamp((offsetMag - aimAssistSlowdownZone) / (aimAssistFOV - aimAssistSlowdownZone), 0, 1)
			magnetStrength = baseStrength * (0.2 + fovFactor * 0.4) -- Lebih lemah di pinggir
		end

		-- Snap: pertama kali lock, sedikit lebih kuat
		if aimAssistFirstLock and isNewTarget then
			magnetStrength = math.min(magnetStrength + aimAssistSnapStrength * 0.3, 1)
			aimAssistFirstLock = false
		end

		-- Smoothing: gunakan lerp yang sangat halus
		local trackSpeed = aimAssistTrackingSmooth
		if aimAssistSmoothing then
			-- Semakin dekat = semakin halus (mencegah jitter)
			if offsetMag < 30 then
				trackSpeed = trackSpeed * 0.5 -- Sangat halus saat dekat
			end
		end

		-- Clamp final strength
		magnetStrength = math.clamp(magnetStrength, 0.01, 0.95)

		-- Apply: Lerp camera ke target
		local currentCF = camera.CFrame
		local lookAt = CFrame.new(currentCF.Position, targetPos)

		-- Gunakan kombinasi: magnet strength untuk "tarikan" + tracking smooth untuk kelembutan
		local finalLerp = magnetStrength * (1 - trackSpeed) + trackSpeed
		finalLerp = math.clamp(finalLerp, 0.02, 0.9)

		camera.CFrame = currentCF:Lerp(lookAt, finalLerp)
	end

	-- ==========================================
	-- ESP (SEPARATE TOGGLES + SMOOTH LINE)
	-- ==========================================
	local function lerpVector2(a, b, t)
		return Vector2.new(a.X + (b.X - a.X) * t, a.Y + (b.Y - a.Y) * t)
	end

	local function updatePlayerESP()
		if not espEnabled then return end
		local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

		for _, tp in ipairs(Players:GetPlayers()) do
			if tp == player then continue end

			if espTeamCheck and isTeammate(tp) then
				if espObjects[tp] then
					local d = espObjects[tp]
					if d.box then d.box.Visible = false end
					if d.line then d.line.Visible = false end
					if d.name then d.name.Visible = false end
					if d.distText then d.distText.Visible = false end
					if d.healthText then d.healthText.Visible = false end
					if d.healthBar then d.healthBar.Visible = false end
					if d.healthBg then d.healthBg.Visible = false end
					if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight = nil end
				end
				continue
			end

			local char = tp.Character
			if not espObjects[tp] then
				espObjects[tp] = {
					box = Drawing.new("Square"),
					line = Drawing.new("Line"),
					name = Drawing.new("Text"),
					distText = Drawing.new("Text"),
					healthText = Drawing.new("Text"),
					healthBar = Drawing.new("Line"),
					healthBg = Drawing.new("Line"),
					smoothLineFrom = nil,
					smoothLineTo = nil,
				}
				local d = espObjects[tp]
				d.box.Thickness = 1.5 d.box.Filled = false d.box.Visible = false
				d.line.Thickness = 1.5 d.line.Visible = false
				d.name.Size = 14 d.name.Center = true d.name.Outline = true d.name.Font = 2 d.name.Visible = false
				d.distText.Size = 12 d.distText.Center = true d.distText.Outline = true d.distText.Font = 2 d.distText.Visible = false
				d.healthText.Size = 12 d.healthText.Center = true d.healthText.Outline = true d.healthText.Font = 2 d.healthText.Visible = false
				d.healthBar.Thickness = 3 d.healthBar.Visible = false
				d.healthBg.Thickness = 5 d.healthBg.Visible = false d.healthBg.Color = Color3.fromRGB(40, 40, 40)
			end

			local d = espObjects[tp]
			local color = espColor
			if espTeamCheck then color = isTeammate(tp) and espTeamColor or espEnemyColor end

			if not char or not char:FindFirstChild("HumanoidRootPart") then
				d.box.Visible = false d.line.Visible = false d.name.Visible = false
				d.distText.Visible = false d.healthText.Visible = false
				d.healthBar.Visible = false d.healthBg.Visible = false
				if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight = nil end
				continue
			end

			local hrp = char.HumanoidRootPart
			local head = char:FindFirstChild("Head")
			local hum = char:FindFirstChildOfClass("Humanoid")
			local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)

			if onScreen then
				local topPos = camera:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, 3, 0)).Position)
				local botPos = camera:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, -4.5, 0)).Position)
				local h = math.abs(topPos.Y - botPos.Y)
				local w = h / 1.8

				-- Box
				if espBox then
					d.box.Size = Vector2.new(w, h) d.box.Position = Vector2.new(pos.X - w / 2, pos.Y - h / 2)
					d.box.Color = color d.box.Visible = true
				else d.box.Visible = false end

				-- Line (Smooth)
				if espLine then
					local targetFrom = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
					local targetTo = Vector2.new(pos.X, pos.Y)
					if d.smoothLineFrom and d.smoothLineTo then
						d.smoothLineFrom = lerpVector2(d.smoothLineFrom, targetFrom, espLineSmoothing)
						d.smoothLineTo = lerpVector2(d.smoothLineTo, targetTo, espLineSmoothing)
					else
						d.smoothLineFrom = targetFrom d.smoothLineTo = targetTo
					end
					d.line.From = d.smoothLineFrom d.line.To = d.smoothLineTo
					d.line.Color = color d.line.Visible = true
				else d.line.Visible = false d.smoothLineFrom = nil d.smoothLineTo = nil end

				-- Name
				if espName and head then
					local np = camera:WorldToViewportPoint((head.CFrame * CFrame.new(0, 2, 0)).Position)
					d.name.Position = Vector2.new(np.X, np.Y)
					d.name.Text = tp.DisplayName .. " (@" .. tp.Name .. ")"
					d.name.Color = color d.name.Visible = true
				else d.name.Visible = false end

				-- Distance
				if espDistance and myHrp and head then
					local dist = math.floor((myHrp.Position - hrp.Position).Magnitude)
					local np = camera:WorldToViewportPoint((head.CFrame * CFrame.new(0, 2, 0)).Position)
					local yOff = espName and 14 or 0
					d.distText.Position = Vector2.new(np.X, np.Y + yOff)
					d.distText.Text = "[" .. dist .. "m]"
					d.distText.Color = Color3.fromRGB(200, 200, 200) d.distText.Visible = true
				else d.distText.Visible = false end

				-- Health
				if espHealth and hum then
					local healthPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
					if espBox then
						local barX = pos.X - w / 2 - 7
						local barTop = pos.Y - h / 2 local barBot = pos.Y + h / 2
						d.healthBg.From = Vector2.new(barX, barBot) d.healthBg.To = Vector2.new(barX, barTop) d.healthBg.Visible = true
						d.healthBar.From = Vector2.new(barX, barBot)
						d.healthBar.To = Vector2.new(barX, barBot - (h * healthPct))
						d.healthBar.Color = Color3.fromRGB(255 * (1 - healthPct), 255 * healthPct, 0) d.healthBar.Visible = true
					else d.healthBar.Visible = false d.healthBg.Visible = false end
					local yOff = 0
					if espName then yOff = yOff + 14 end
					if espDistance then yOff = yOff + 14 end
					if head then
						local np = camera:WorldToViewportPoint((head.CFrame * CFrame.new(0, 2, 0)).Position)
						d.healthText.Position = Vector2.new(np.X, np.Y + yOff)
						d.healthText.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) .. " HP"
						d.healthText.Color = Color3.fromRGB(255 * (1 - healthPct), 255 * healthPct, 0) d.healthText.Visible = true
					end
				else d.healthBar.Visible = false d.healthBg.Visible = false d.healthText.Visible = false end

				-- Highlight
				if espHighlight then
					if not d.highlight or not d.highlight.Parent then
						d.highlight = Instance.new("Highlight")
						d.highlight.FillColor = color d.highlight.OutlineColor = Color3.new(1, 1, 1)
						d.highlight.FillTransparency = 0.7 d.highlight.OutlineTransparency = 0.3 d.highlight.Parent = char
					else d.highlight.FillColor = color end
				elseif d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight = nil end
			else
				d.box.Visible = false d.line.Visible = false d.name.Visible = false
				d.distText.Visible = false d.healthText.Visible = false
				d.healthBar.Visible = false d.healthBg.Visible = false
				d.smoothLineFrom = nil d.smoothLineTo = nil
			end
		end
	end

	local function clearAllESP()
		for _, d in pairs(espObjects) do
			if d.box then pcall(function() d.box:Remove() end) end
			if d.line then pcall(function() d.line:Remove() end) end
			if d.name then pcall(function() d.name:Remove() end) end
			if d.distText then pcall(function() d.distText:Remove() end) end
			if d.healthText then pcall(function() d.healthText:Remove() end) end
			if d.healthBar then pcall(function() d.healthBar:Remove() end) end
			if d.healthBg then pcall(function() d.healthBg:Remove() end) end
			if d.highlight then pcall(function() d.highlight:Destroy() end) end
		end
		espObjects = {}
	end

