		if noFallDamage then applyNoFall() end

		-- Aimlock (Hard Lock)
		if aimlockEnabled and aimlockHeld then
			if autoSwitchTarget and not isTargetValid(aimlockTarget) then aimlockTarget = getClosestInFOV() end
			if aimlockTarget and aimlockTarget.Character then
				local tp = aimlockTarget.Character:FindFirstChild(aimlockPart) or aimlockTarget.Character:FindFirstChild("HumanoidRootPart")
				local hum = aimlockTarget.Character:FindFirstChildOfClass("Humanoid")
				if tp and hum and hum.Health > 0 then
					local myHrp = char:FindFirstChild("HumanoidRootPart")
					if myHrp and (myHrp.Position - tp.Position).Magnitude <= aimlockDistance then
						camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, tp.Position), aimlockSmooth)
					else aimlockTarget = autoSwitchTarget and getClosestInFOV() or nil end
				else aimlockTarget = autoSwitchTarget and getClosestInFOV() or nil end
			end
		end

		-- Aim Assist (Setiap frame - super smooth & sticky)
		if aimAssistEnabled then applyAimAssist(dt) end

		-- FOV Circles
		if fovCircle then fovCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2) fovCircle.Radius = aimlockFOV fovCircle.Visible = showFOVCircle and aimlockEnabled end
		if aimAssistFOVCircle then
			local vpSize = camera.ViewportSize
			aimAssistFOVCircle.Position = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
			aimAssistFOVCircle.Radius = aimAssistFOV aimAssistFOVCircle.Visible = showAimAssistFOV and aimAssistEnabled
		end

		-- Kill Aura
		if now - lastKillAuraUpdate >= KILL_AURA_UPDATE_RATE then lastKillAuraUpdate = now if killAuraEnabled then performKillAura() updateKillAuraVisuals() end end
		-- ESP
		if now - lastESPUpdate >= ESP_UPDATE_RATE then lastESPUpdate = now if espEnabled then updatePlayerESP() end end
		if now - lastVehicleESPUpdate >= VEHICLE_ESP_UPDATE_RATE then lastVehicleESPUpdate = now updateVehicleESP() end
		-- Hitbox
		if now - lastHitboxUpdate >= HITBOX_UPDATE_RATE then lastHitboxUpdate = now if hitboxEnabled then updateHitboxExpander() end if antiHitboxEnabled then updateAntiHitbox() end end
		if now - lastVehicleCheck >= VEHICLE_CHECK_RATE then lastVehicleCheck = now applyVehicleSpeed() end
		if now - lastNoCooldownUpdate >= NO_COOLDOWN_UPDATE_RATE then lastNoCooldownUpdate = now updateNoCooldown() end
	end)

	-- Cleanup
	Players.PlayerRemoving:Connect(function(p)
		if espObjects[p] then
			local d = espObjects[p]
			if d.box then pcall(function() d.box:Remove() end) end
			if d.line then pcall(function() d.line:Remove() end) end
			if d.name then pcall(function() d.name:Remove() end) end
			if d.distText then pcall(function() d.distText:Remove() end) end
			if d.healthText then pcall(function() d.healthText:Remove() end) end
			if d.healthBar then pcall(function() d.healthBar:Remove() end) end
			if d.healthBg then pcall(function() d.healthBg:Remove() end) end
			if d.highlight then pcall(function() d.highlight:Destroy() end) end
			espObjects[p] = nil
		end
		if hitboxData[p] then cleanHitboxForPlayer(p) hitboxData[p] = nil end
	end)

