	local function getMoveDirection()
		local hum=player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if not hum then return Vector3.zero end
		return hum.MoveDirection.Magnitude>0 and hum.MoveDirection.Unit or Vector3.zero
	end

	local function getGroundInfo()
		local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not hrp then return math.huge end
		local params=RaycastParams.new() params.FilterDescendantsInstances={player.Character} params.FilterType=Enum.RaycastFilterType.Exclude
		local r=workspace:Raycast(hrp.Position,Vector3.new(0,-500,0),params)
		return r and (hrp.Position-r.Position).Magnitude or math.huge
	end

	local function applySpeed(dt)
		local char=player.Character if not char then return end
		local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
		if not hrp or not hum then return end
		if speedMethod=="Default" then hum.WalkSpeed=speed
		elseif speedMethod=="CFrame Bypass" then hum.WalkSpeed=16 local dir=getMoveDirection() if dir.Magnitude>0 and speed>16 then hrp.CFrame=hrp.CFrame+(dir*(speed-16)*dt) end
		elseif speedMethod=="Velocity Bypass" then hum.WalkSpeed=16 local dir=getMoveDirection() if dir.Magnitude>0 then hrp.AssemblyLinearVelocity=Vector3.new(dir.X*speed,hrp.AssemblyLinearVelocity.Y,dir.Z*speed) end
		elseif speedMethod=="BodyVelocity Bypass" then
			hum.WalkSpeed=16 local bv=hrp:FindFirstChild("SpeedBV")
			if not bv then bv=Instance.new("BodyVelocity") bv.Name="SpeedBV" bv.MaxForce=Vector3.new(100000,0,100000) bv.P=10000 bv.Parent=hrp end
			local dir=getMoveDirection() bv.Velocity=dir.Magnitude>0 and dir*speed or Vector3.zero bv.MaxForce=dir.Magnitude>0 and Vector3.new(100000,0,100000) or Vector3.zero
		end
	end

	local function applyJump()
		local char=player.Character if not char then return end
		local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
		if not hrp or not hum then return end
		if jumpMethod=="Default" then hum.UseJumpPower=true hum.JumpPower=jumpPower
		else hum.JumpPower=0
			if isJumping and canJump then canJump=false
				if jumpMethod=="CFrame Bypass" then hrp.CFrame=hrp.CFrame+Vector3.new(0,jumpPower/50,0)
				elseif jumpMethod=="Velocity Bypass" then hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X,jumpPower,hrp.AssemblyLinearVelocity.Z)
				elseif jumpMethod=="BodyVelocity Bypass" then
					local bv=Instance.new("BodyVelocity") bv.MaxForce=Vector3.new(0,100000,0) bv.Velocity=Vector3.new(0,jumpPower,0) bv.Parent=hrp
					task.delay(0.15,function() if bv.Parent then bv:Destroy() end end)
				end
				task.delay(0.3,function() canJump=true end)
			end
		end
	end

	local function applyNoFall()
		local char=player.Character if not char then return end
		local hrp=char:FindFirstChild("HumanoidRootPart") local hum=char:FindFirstChildOfClass("Humanoid")
		if not hrp or not hum then return end
		hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false) hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
		local vel=hrp.AssemblyLinearVelocity
		if noFallMethod=="Velocity Brake" and vel.Y<-50 then if getGroundInfo()<20 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-10,vel.Z) end
		elseif noFallMethod=="Health Restore" then
			if vel.Y<-20 then wasInAir=true lastHealth=hum.Health end
			if wasInAir and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<lastHealth then hum.Health=lastHealth end wasInAir=false end
		elseif noFallMethod=="Hybrid" then
			if vel.Y<-20 and not isFalling then isFalling=true lastHealth=hum.Health end
			if vel.Y<-80 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-30,vel.Z) end
			if isFalling and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<lastHealth then hum.Health=lastHealth end isFalling=false end
		end
	end

	local function getClosestInFOV()
		local myHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHrp then return nil end
		local closest,cd=nil,math.huge local sc=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)
		for _, p in ipairs(Players:GetPlayers()) do
			if p~=player and p.Character then
				local tp=p.Character:FindFirstChild(aimlockPart) or p.Character:FindFirstChild("HumanoidRootPart")
				local hum=p.Character:FindFirstChildOfClass("Humanoid")
				if tp and hum and hum.Health>0 and (myHrp.Position-tp.Position).Magnitude<=aimlockDistance then
					local sp,os=camera:WorldToScreenPoint(tp.Position)
					if os then local sd=(Vector2.new(sp.X,sp.Y)-sc).Magnitude if sd<=aimlockFOV and sd<cd then cd=sd closest=p end end
				end
			end
		end
		return closest
	end

	local function isTargetValid(t)
		if not t or not t.Character then return false end
		local hum=t.Character:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health<=0 then return false end
		local tp=t.Character:FindFirstChild(aimlockPart) or t.Character:FindFirstChild("HumanoidRootPart")
		if not tp then return false end
		local myHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		return myHrp and (myHrp.Position-tp.Position).Magnitude<=aimlockDistance
	end

	local function updateVehicleESP()
		if not vehicleEspEnabled then return end
		local myHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHrp then return end
		local vehs=getAllVehicles()
		for m, o in pairs(vehicleEspObjects) do if not m.Parent then if o.highlight then pcall(function() o.highlight:Destroy() end) end if o.billboard then pcall(function() o.billboard:Destroy() end) end vehicleEspObjects[m]=nil end end
		for _, v in ipairs(vehs) do
			local m=v.Model if not vehicleEspObjects[m] then vehicleEspObjects[m]={} end local o=vehicleEspObjects[m]
			if not o.highlight or not o.highlight.Parent then local h=Instance.new("Highlight") h.FillColor=vehicleEspColor h.OutlineColor=vehicleEspColor h.FillTransparency=0.7 h.Parent=m o.highlight=h
			else o.highlight.FillColor=vehicleEspColor o.highlight.OutlineColor=vehicleEspColor end
			local dist=(myHrp.Position-v.Seat.Position).Magnitude
			if not o.billboard or not o.billboard.Parent then
				local bb=Instance.new("BillboardGui") bb.Size=UDim2.new(0,150,0,40) bb.StudsOffset=Vector3.new(0,5,0) bb.AlwaysOnTop=true bb.Parent=v.Seat
				local l=Instance.new("TextLabel") l.Size=UDim2.new(1,0,1,0) l.BackgroundTransparency=1 l.TextColor3=vehicleEspColor l.TextStrokeTransparency=0 l.Font=Enum.Font.GothamBold l.TextSize=12 l.Parent=bb
				o.billboard=bb o.label=l
			end
			if o.label then o.label.Text=v.Name.." ["..math.floor(dist).."m]"..(v.Seat.Occupant and " [OCC]" or " [FREE]") o.label.TextColor3=v.Seat.Occupant and Color3.fromRGB(255,100,100) or vehicleEspColor end
		end
	end

	local function updatePlayerESP()
		if not espEnabled then return end
		local myHrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		for _, tp in ipairs(Players:GetPlayers()) do
			if tp==player then continue end local char=tp.Character
			if not espObjects[tp] then
				espObjects[tp]={box=Drawing.new("Square"),line=Drawing.new("Line"),name=Drawing.new("Text")}
				local d=espObjects[tp] d.box.Thickness=2 d.box.Filled=false d.box.Visible=false d.line.Thickness=2 d.line.Visible=false d.name.Size=14 d.name.Center=true d.name.Outline=true d.name.Visible=false
			end
			local d=espObjects[tp] d.box.Color=espColor d.line.Color=espColor d.name.Color=espColor
			if not char or not char:FindFirstChild("HumanoidRootPart") then d.box.Visible=false d.line.Visible=false d.name.Visible=false continue end
			local hrp=char.HumanoidRootPart local head=char:FindFirstChild("Head")
			local pos,onScreen=camera:WorldToViewportPoint(hrp.Position)
			if onScreen then
				if espBox then local top=camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,3,0)).Position) local bot=camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,-4.5,0)).Position)
					local h=math.abs(top.Y-bot.Y) local w=h/1.8 d.box.Size=Vector2.new(w,h) d.box.Position=Vector2.new(pos.X-w/2,pos.Y-h/2) d.box.Visible=true
				else d.box.Visible=false end
				if espLine then d.line.From=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y) d.line.To=Vector2.new(pos.X,pos.Y) d.line.Visible=true else d.line.Visible=false end
				if head then local dist=myHrp and math.floor((myHrp.Position-hrp.Position).Magnitude) or 0 local np=camera:WorldToViewportPoint((head.CFrame*CFrame.new(0,2,0)).Position)
					d.name.Position=Vector2.new(np.X,np.Y) d.name.Text=tp.Name.." ["..dist.."m]" d.name.Visible=true end
				if espHighlight then
					if not d.highlight or not d.highlight.Parent then d.highlight=Instance.new("Highlight") d.highlight.FillColor=espColor d.highlight.OutlineColor=espColor d.highlight.FillTransparency=0.7 d.highlight.Parent=char
					else d.highlight.FillColor=espColor d.highlight.OutlineColor=espColor end
				elseif d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
			else d.box.Visible=false d.line.Visible=false d.name.Visible=false end
		end
	end

	local function applyVehicleSpeed()
		if not vehicleSpeedEnabled then return end
		local hum=player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if not hum or not hum.SeatPart then return end
		if hum.SeatPart:IsA("VehicleSeat") then pcall(function() hum.SeatPart.MaxSpeed=vehicleSpeed hum.SeatPart.Torque=vehicleSpeed*2 end) end
	end

	local function updateNoCooldown()
		if not noCooldown then return end
		updatePromptCache()
		for _, v in ipairs(cachedPrompts) do if v.Parent then v.MaxActivationDistance=interactRange pcall(function() v.Cooldown=0 v.HoldDuration=0 v.RequiresLineOfSight=false end) end end
		for _, v in ipairs(cachedClickDetectors) do if v.Parent then v.MaxActivationDistance=interactRange end end
	end

	-- ==========================================
	-- INPUT
	-- ==========================================

	local aimlockHeld = false

	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		local isAK=false
		if typeof(aimlockKey)=="EnumItem" then
			if aimlockKey.EnumType==Enum.UserInputType then isAK=input.UserInputType==aimlockKey
			elseif aimlockKey.EnumType==Enum.KeyCode then isAK=input.KeyCode==aimlockKey end
		end
		if isAK then aimlockHeld=true if aimlockEnabled then aimlockTarget=getClosestInFOV() end end
		if input.KeyCode==Enum.KeyCode.Space and jumpMethod~="Default" then isJumping=true task.delay(0.15,function() isJumping=false end) end
	end)

	UserInputService.InputEnded:Connect(function(input)
		local isAK=false
		if typeof(aimlockKey)=="EnumItem" then
			if aimlockKey.EnumType==Enum.UserInputType then isAK=input.UserInputType==aimlockKey
			elseif aimlockKey.EnumType==Enum.KeyCode then isAK=input.KeyCode==aimlockKey end
		end
		if isAK then aimlockHeld=false end
	end)

	UserInputService.JumpRequest:Connect(function()
		local hum=player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if not hum then return end
		if _G.InfiniteJump then
			if jumpMethod=="Default" then hum:ChangeState(Enum.HumanoidStateType.Jumping)
			else isJumping=true task.delay(0.1,function() isJumping=false end) end
		elseif hum.FloorMaterial~=Enum.Material.Air then isJumping=true task.delay(0.1,function() isJumping=false end) end
	end)

	player.CharacterAdded:Connect(function(char)
		local hum=char:WaitForChild("Humanoid",10)
		if hum then lastHealth=hum.Health isFalling=false wasInAir=false end
		for _, pd in pairs(antiHitboxParts) do
			if pd.fakePart and pd.fakePart.Parent then pcall(function() pd.fakePart:Destroy() end) end
			if pd.visual and pd.visual.Parent then pcall(function() pd.visual:Destroy() end) end
		end
		antiHitboxParts={}
	end)

	-- ==========================================
	-- MAIN LOOP
	-- ==========================================

	RunService.RenderStepped:Connect(function(dt)
		local char=player.Character if not char then return end
		local now=tick()

		if noclip then applyNoclip() end
		applySpeed(dt) applyJump()
		if noFallDamage then applyNoFall() end

		if aimlockEnabled and aimlockHeld then
			if autoSwitchTarget and not isTargetValid(aimlockTarget) then aimlockTarget=getClosestInFOV() end
			if aimlockTarget and aimlockTarget.Character then
				local tp=aimlockTarget.Character:FindFirstChild(aimlockPart) or aimlockTarget.Character:FindFirstChild("HumanoidRootPart")
				local hum=aimlockTarget.Character:FindFirstChildOfClass("Humanoid")
				if tp and hum and hum.Health>0 then
					local myHrp=char:FindFirstChild("HumanoidRootPart")
					if myHrp and (myHrp.Position-tp.Position).Magnitude<=aimlockDistance then
						camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tp.Position),aimlockSmooth)
					else aimlockTarget=autoSwitchTarget and getClosestInFOV() or nil end
				else aimlockTarget=autoSwitchTarget and getClosestInFOV() or nil end
			end
		end

		if fovCircle then fovCircle.Position=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2) fovCircle.Radius=aimlockFOV fovCircle.Visible=showFOVCircle and aimlockEnabled end

		if now-lastKillAuraUpdate>=KILL_AURA_UPDATE_RATE then lastKillAuraUpdate=now if killAuraEnabled then performKillAura() updateKillAuraVisuals() end end
		if now-lastESPUpdate>=ESP_UPDATE_RATE then lastESPUpdate=now if espEnabled then updatePlayerESP() end end
		if now-lastVehicleESPUpdate>=VEHICLE_ESP_UPDATE_RATE then lastVehicleESPUpdate=now updateVehicleESP() end
		if now-lastHitboxUpdate>=HITBOX_UPDATE_RATE then lastHitboxUpdate=now if hitboxEnabled then updateHitboxExpander() end if antiHitboxEnabled then updateAntiHitbox() end end
		if now-lastVehicleCheck>=VEHICLE_CHECK_RATE then lastVehicleCheck=now applyVehicleSpeed() end
		if now-lastNoCooldownUpdate>=NO_COOLDOWN_UPDATE_RATE then lastNoCooldownUpdate=now updateNoCooldown() end
	end)

	Players.PlayerRemoving:Connect(function(p)
		if espObjects[p] then local d=espObjects[p] if d.box then d.box:Remove() end if d.line then d.line:Remove() end if d.name then d.name:Remove() end if d.highlight then pcall(function() d.highlight:Destroy() end) end espObjects[p]=nil end
		if hitboxData[p] then
			if hitboxData[p].overlayPart then pcall(function() hitboxData[p].overlayPart:Destroy() end) end
			if hitboxData[p].espVisual then pcall(function() hitboxData[p].espVisual:Destroy() end) end
			hitboxData[p]=nil
		end
	end)

	Rayfield:Notify({
		Title = "RyuExploit Loaded",
		Content = "Hitbox FIXED - No More Kicks!\nUse 'Safe Overlay' for best anti-kick",
		Duration = 5
	})
end
