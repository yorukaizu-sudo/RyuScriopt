	-- ==========================================
	local function updatePlayerESP()
		if not espEnabled then return end
		local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

		for _, tp in ipairs(Players:GetPlayers()) do
			if tp == player then continue end

			-- Team check
			if espTeamCheck and isTeammate(tp) then
				-- Hide ESP for teammates if team check enabled
				if espObjects[tp] then
					local d = espObjects[tp]
					if d.box then d.box.Visible = false end
					if d.line then d.line.Visible = false end
					if d.name then d.name.Visible = false end
					if d.healthBar then d.healthBar.Visible = false end
					if d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight = nil end
				end
				continue
			end

			local char = tp.Character
			if not espObjects[tp] then
				espObjects[tp] = {
					box = Drawing.new("Square"),
					line = Drawing.new("Line"),
					name = Drawing.new("Text"),
					healthBar = Drawing.new("Line")
				}
				local d = espObjects[tp]
				d.box.Thickness=2 d.box.Filled=false d.box.Visible=false
				d.line.Thickness=2 d.line.Visible=false
				d.name.Size=14 d.name.Center=true d.name.Outline=true d.name.Visible=false
				d.healthBar.Thickness=3 d.healthBar.Visible=false
			end

			local d = espObjects[tp]
			-- Color based on team
			local color = espColor
			if espTeamCheck then
				color = isTeammate(tp) and espTeamColor or espEnemyColor
			end
			d.box.Color=color d.line.Color=color d.name.Color=color

			if not char or not char:FindFirstChild("HumanoidRootPart") then
				d.box.Visible=false d.line.Visible=false d.name.Visible=false d.healthBar.Visible=false continue
			end

			local hrp = char.HumanoidRootPart
			local head = char:FindFirstChild("Head")
			local hum = char:FindFirstChildOfClass("Humanoid")
			local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)

			if onScreen then
				if espBox then
					local top = camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,3,0)).Position)
					local bot = camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,-4.5,0)).Position)
					local h = math.abs(top.Y-bot.Y) local w = h/1.8
					d.box.Size=Vector2.new(w,h) d.box.Position=Vector2.new(pos.X-w/2,pos.Y-h/2) d.box.Visible=true
				else d.box.Visible=false end

				if espLine then
					d.line.From=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y)
					d.line.To=Vector2.new(pos.X,pos.Y) d.line.Visible=true
				else d.line.Visible=false end

				if head then
					local dist = myHrp and math.floor((myHrp.Position-hrp.Position).Magnitude) or 0
					local healthText = ""
					if espHealth and hum then
						healthText = " [HP:"..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth).."]"
					end
					local distText = espDistance and " ["..dist.."m]" or ""
					local np = camera:WorldToViewportPoint((head.CFrame*CFrame.new(0,2,0)).Position)
					d.name.Position=Vector2.new(np.X,np.Y)
					d.name.Text=tp.Name..distText..healthText
					d.name.Visible=true
				end

				-- Health bar
				if espHealth and hum and espBox then
					local top = camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,3,0)).Position)
					local bot = camera:WorldToViewportPoint((hrp.CFrame*CFrame.new(0,-4.5,0)).Position)
					local h = math.abs(top.Y-bot.Y) local w = h/1.8
					local healthPct = hum.Health / hum.MaxHealth
					local barX = pos.X - w/2 - 5
					d.healthBar.From = Vector2.new(barX, pos.Y + h/2)
					d.healthBar.To = Vector2.new(barX, pos.Y + h/2 - (h * healthPct))
					d.healthBar.Color = Color3.fromRGB(255 * (1-healthPct), 255 * healthPct, 0)
					d.healthBar.Visible = true
				else d.healthBar.Visible = false end

				if espHighlight then
					if not d.highlight or not d.highlight.Parent then
						d.highlight=Instance.new("Highlight") d.highlight.FillColor=color d.highlight.OutlineColor=color d.highlight.FillTransparency=0.7 d.highlight.Parent=char
					else d.highlight.FillColor=color d.highlight.OutlineColor=color end
				elseif d.highlight then pcall(function() d.highlight:Destroy() end) d.highlight=nil end
			else d.box.Visible=false d.line.Visible=false d.name.Visible=false d.healthBar.Visible=false end
		end
	end

