	local function getEquippedTool()
		local char = player.Character
		if not char then return nil end
		for _, i in ipairs(char:GetChildren()) do if i:IsA("Tool") then return i end end
		return nil
	end

	local function getToolFromBackpack()
		local bp = player:FindFirstChild("Backpack")
		if not bp then return nil end
		for _, i in ipairs(bp:GetChildren()) do if i:IsA("Tool") then return i end end
		return nil
	end

	local function equipTool(tool)
		if not tool then return end
		local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
		if hum then hum:EquipTool(tool) end
	end

	local function getEnemiesInRange()
		local enemies = {}
		local myChar = player.Character
		local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myHrp then return enemies end
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local hrp = p.Character:FindFirstChild("HumanoidRootPart")
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				if hrp and hum and hum.Health > 0 then
					local dist = (myHrp.Position - hrp.Position).Magnitude
					if dist <= killAuraRange then
						if killAuraWhitelistTeam and isTeammate(p) then continue end
						table.insert(enemies, {Player=p, Character=p.Character, HRP=hrp, Humanoid=hum, Distance=dist, TargetPart=p.Character:FindFirstChild(killAuraTargetPart) or hrp})
					end
				end
			end
		end
		table.sort(enemies, function(a, b) return a.Distance < b.Distance end)
		return enemies
	end

	local function getNPCsInRange()
		local npcs = {}
		local myChar = player.Character
		local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myHrp then return npcs end
		for _, model in ipairs(workspace:GetDescendants()) do
			if model:IsA("Model") and model ~= myChar then
				local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso")
				local hum = model:FindFirstChildOfClass("Humanoid")
				if hrp and hum and hum.Health > 0 then
					local isPC = false
					for _, p in ipairs(Players:GetPlayers()) do if p.Character == model then isPC = true break end end
					if not isPC then
						local dist = (myHrp.Position - hrp.Position).Magnitude
						if dist <= killAuraRange then
							table.insert(npcs, {Model=model, HRP=hrp, Humanoid=hum, Distance=dist, TargetPart=model:FindFirstChild(killAuraTargetPart) or hrp})
						end
					end
				end
			end
		end
		table.sort(npcs, function(a, b) return a.Distance < b.Distance end)
		return npcs
	end

	local function attackWithClick(target)
		local tool = getEquippedTool()
		if not tool and killAuraAutoEquip then local bt = getToolFromBackpack() if bt then equipTool(bt) task.wait(0.1) tool = getEquippedTool() end end
		if not tool then return end
		pcall(function() tool:Activate() end)
		pcall(function() VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,1) task.wait(0.01) VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,1) end)
	end

	local function attackWithRemote(target)
		local tool = getEquippedTool()
		if not tool then return end
		local tp = target.TargetPart or target.HRP
		for _, r in ipairs(tool:GetDescendants()) do
			if r:IsA("RemoteEvent") then pcall(function() r:FireServer(tp, tp.Position, target.Humanoid) end) pcall(function() r:FireServer("Hit", tp, tp.Position) end) end
		end
		for _, r in ipairs(ReplicatedStorage:GetDescendants()) do
			if r:IsA("RemoteEvent") then local n=r.Name:lower() if n:find("attack") or n:find("hit") or n:find("damage") or n:find("swing") then pcall(function() r:FireServer(tp, target.Humanoid) end) end end
		end
	end

	local function attackWithTP(target)
		local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHrp then return end
		local tool = getEquippedTool()
		if not tool and killAuraAutoEquip then local bt = getToolFromBackpack() if bt then equipTool(bt) task.wait(0.1) tool = getEquippedTool() end end
		if not tool then return end
		local orig = myHrp.CFrame
		myHrp.CFrame = (target.TargetPart or target.HRP).CFrame * CFrame.new(0,0,2)
		pcall(function() tool:Activate() end)
		task.wait(0.05)
		myHrp.CFrame = orig
	end

	local function performKillAura()
		if not killAuraEnabled then return end
		local now = tick()
		if now - lastAttackTime < killAuraSpeed then return end
		lastAttackTime = now
		local all = {}
		for _, e in ipairs(getEnemiesInRange()) do table.insert(all, e) end
		for _, n in ipairs(getNPCsInRange()) do table.insert(all, n) end
		if #all == 0 then return end
		killAuraTargets = all
		for _, t in ipairs(all) do
			if killAuraMethod == "Click Simulation" then attackWithClick(t)
			elseif killAuraMethod == "Remote Bypass" then attackWithRemote(t)
			elseif killAuraMethod == "Teleport Bypass" then attackWithTP(t)
			elseif killAuraMethod == "All Methods" then attackWithClick(t) attackWithRemote(t) end
		end
	end

	local function updateKillAuraVisuals()
		if not killAuraEnabled or not killAuraVisualEnabled then
			for _, v in pairs(killAuraVisuals) do if v and v.Parent then pcall(function() v:Destroy() end) end end
			killAuraVisuals = {}
			return
		end
		local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if not myHrp then return end
		if not killAuraVisuals.range or not killAuraVisuals.range.Parent then
			local p = Instance.new("Part") p.Name="KAR" p.Shape=Enum.PartType.Cylinder p.Size=Vector3.new(0.1,killAuraRange*2,killAuraRange*2)
			p.CFrame=myHrp.CFrame*CFrame.Angles(0,0,math.rad(90)) p.Anchored=true p.CanCollide=false p.Transparency=0.8 p.Color=killAuraVisualColor p.Material=Enum.Material.Neon p.Parent=workspace
			killAuraVisuals.range = p
		else killAuraVisuals.range.Size=Vector3.new(0.1,killAuraRange*2,killAuraRange*2) killAuraVisuals.range.CFrame=myHrp.CFrame*CFrame.Angles(0,0,math.rad(90)) killAuraVisuals.range.Color=killAuraVisualColor end
		for _, t in ipairs(killAuraTargets) do
			local c = t.Character or t.Model
			if c then local k=tostring(c) if not killAuraVisuals[k] or not killAuraVisuals[k].Parent then
				local h=Instance.new("Highlight") h.FillColor=killAuraVisualColor h.OutlineColor=Color3.new(1,1,1) h.FillTransparency=0.5 h.Parent=c killAuraVisuals[k]=h
			else killAuraVisuals[k].FillColor=killAuraVisualColor end end
		end
	end

	-- ==========================================
	-- HITBOX EXPANDER (AUTO REFRESH FIXED)
	-- ==========================================
	local function updateHitboxExpander()
		if not hitboxEnabled then return end

		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character then
				local hrp = p.Character:FindFirstChild("HumanoidRootPart")
				local hum = p.Character:FindFirstChildOfClass("Humanoid")

				if hrp and hum then
					if not hitboxData[p] then hitboxData[p] = {} end
					local dd = hitboxData[p]

					-- Auto refresh: if player respawned or overlay gone, recreate
					local needsRefresh = false
					if not dd.overlayPart or not dd.overlayPart.Parent then needsRefresh = true end
					if dd.trackedChar ~= p.Character then needsRefresh = true end

					if hum.Health > 0 then
						if needsRefresh then
							-- Clean old
							if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
							if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end

							-- Create new overlay
							local overlay = Instance.new("Part")
							overlay.Name = "HBOverlay"
							overlay.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
							overlay.Transparency = 1
							overlay.CanCollide = false
							overlay.CanQuery = true
							overlay.Anchored = false
							overlay.Massless = true
							overlay.Parent = p.Character

							local weld = Instance.new("WeldConstraint")
							weld.Part0 = hrp
							weld.Part1 = overlay
							weld.Parent = overlay
							overlay.CFrame = hrp.CFrame

							dd.overlayPart = overlay
							dd.trackedChar = p.Character
							hrp.CanQuery = false
						else
							-- Update size
							dd.overlayPart.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
						end

						-- ESP
						if hitboxESPEnabled then
							local tp = dd.overlayPart
							if not dd.espVisual or not dd.espVisual.Parent then
								local box = Instance.new("BoxHandleAdornment")
								box.Adornee = tp box.Size = tp.Size box.Color3 = hitboxESPColor
								box.Transparency = 0.5 box.AlwaysOnTop = true box.ZIndex = 10 box.Parent = tp
								dd.espVisual = box
							else dd.espVisual.Adornee = tp dd.espVisual.Size = tp.Size dd.espVisual.Color3 = hitboxESPColor end
						elseif dd.espVisual then pcall(function() dd.espVisual:Destroy() end) dd.espVisual = nil end

					else
						-- Player is dead but keep overlay for when they respawn
						-- hitboxAutoRefresh will recreate on respawn automatically
						if dd.overlayPart and dd.overlayPart.Parent then
							pcall(function() dd.overlayPart:Destroy() end)
							dd.overlayPart = nil
						end
						if dd.espVisual and dd.espVisual.Parent then
							pcall(function() dd.espVisual:Destroy() end)
							dd.espVisual = nil
						end
						dd.trackedChar = nil -- Force refresh on respawn
					end
				end
			end
		end

		-- Cleanup left players
		for p, dd in pairs(hitboxData) do
			if not p.Parent or not p.Character then
				if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
				if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
				hitboxData[p] = nil
			end
		end
	end

	local function disableHitboxExpander()
		for p, dd in pairs(hitboxData) do
			if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
			if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
			if p.Character then
				local hrp = p.Character:FindFirstChild("HumanoidRootPart")
				if hrp then hrp.CanQuery = true end
			end
		end
		hitboxData = {}
	end

	-- ==========================================
	-- ANTI HITBOX (Self)
	-- ==========================================
	local function updateAntiHitbox()
		if not antiHitboxEnabled then return end
		local mc = player.Character
		if not mc or not mc:FindFirstChild("HumanoidRootPart") then return end
		local parts = {"Head","Torso","UpperTorso","LowerTorso","LeftArm","RightArm","LeftLeg","RightLeg","Left Arm","Right Arm","Left Leg","Right Leg"}
		for _, pn in ipairs(parts) do
			local part = mc:FindFirstChild(pn)
			if part and part:IsA("BasePart") then
				if not antiHitboxParts[pn] then antiHitboxParts[pn] = {} end
				local d = antiHitboxParts[pn]
				if not d.fakePart or not d.fakePart.Parent then
					local fp = Instance.new("Part") fp.Name="AH_"..pn fp.Size=Vector3.new(antiHitboxSize,antiHitboxSize,antiHitboxSize)
					fp.Transparency=1 fp.CanCollide=false fp.CanQuery=true fp.Anchored=false fp.Massless=true fp.Parent=mc
					local w = Instance.new("WeldConstraint") w.Part0=part w.Part1=fp w.Parent=fp fp.CFrame=part.CFrame d.fakePart=fp
				else d.fakePart.Size=Vector3.new(antiHitboxSize,antiHitboxSize,antiHitboxSize) end
				part.CanQuery = false
				if antiHitboxESPEnabled and d.fakePart then
					if not d.visual or not d.visual.Parent then
						local b = Instance.new("BoxHandleAdornment") b.Adornee=d.fakePart b.Size=d.fakePart.Size b.Color3=antiHitboxESPColor b.Transparency=0.3 b.AlwaysOnTop=true b.ZIndex=10 b.Parent=d.fakePart d.visual=b
					else d.visual.Size=d.fakePart.Size d.visual.Color3=antiHitboxESPColor end
				elseif d.visual then pcall(function() d.visual:Destroy() end) d.visual=nil end
			end
		end
	end

