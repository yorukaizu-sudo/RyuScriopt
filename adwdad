	local function applyNoclip()
		if not noclip then return end
		local char = player.Character
		if not char then return end

		if noclipMethod == "Default" or noclipMethod == "Ghost Bypass" or noclipMethod == "Phase Bypass" then
			for _, v in ipairs(char:GetDescendants()) do
				if v:IsA("BasePart") then v.CanCollide = false end
			end
			if noclipMethod == "Phase Bypass" then
				pcall(function()
					local hum = char:FindFirstChildOfClass("Humanoid")
					if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
				end)
			end
		elseif noclipMethod == "Stepped Bypass" then
			for _, v in ipairs(char:GetDescendants()) do
				if v:IsA("BasePart") then v.CanCollide = false end
			end
			task.defer(function()
				local hrp = char:FindFirstChild("HumanoidRootPart")
				if hrp then
					local vel = hrp.AssemblyLinearVelocity
					if vel.Magnitude > 100 then hrp.AssemblyLinearVelocity = vel.Unit * 50 end
				end
			end)
		elseif noclipMethod == "CFrame Bypass" then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			local hum = char:FindFirstChildOfClass("Humanoid")
			if not hrp or not hum then return end
			local moveDir = hum.MoveDirection
			if moveDir.Magnitude > 0 then
				local params = RaycastParams.new()
				params.FilterDescendantsInstances = {char}
				params.FilterType = Enum.RaycastFilterType.Exclude
				if workspace:Raycast(hrp.Position, moveDir * 3, params) then
					hrp.CFrame = hrp.CFrame + moveDir * 1.5
				end
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				hrp.CFrame = hrp.CFrame + Vector3.new(0, 1, 0)
			end
		elseif noclipMethod == "Velocity Bypass" then
			for _, v in ipairs(char:GetDescendants()) do
				if v:IsA("BasePart") then v.CanCollide = false end
			end
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then
				local vel = hrp.AssemblyLinearVelocity
				if vel.Magnitude > 60 then hrp.AssemblyLinearVelocity = vel.Unit * 60 end
			end
		end
	end

