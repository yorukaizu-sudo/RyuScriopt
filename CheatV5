local function getAATP(ch)
	local now=tick()
	if aaLCP and ch:FindFirstChild(aaLCP) and now-aaLPS<aaPSR then return ch:FindFirstChild(aaLCP) end
	aaLPS=now local pn="HumanoidRootPart"
	if aaTP=="Dynamic" then if math.random(1,100)<=aaHR then pn="Head" else for _,n in ipairs({"HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do if ch:FindFirstChild(n) then pn=n break end end end
	elseif aaTP=="Head" then pn="Head"
	elseif aaTP=="Body" then for _,n in ipairs({"HumanoidRootPart","UpperTorso","Torso"}) do if ch:FindFirstChild(n) then pn=n break end end end
	aaLCP=pn return ch:FindFirstChild(pn) or ch:FindFirstChild("HumanoidRootPart")
