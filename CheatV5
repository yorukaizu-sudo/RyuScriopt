local function getAAT()
	local mh=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") if not mh then return nil,math.huge end
	local cs=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2) local cl,cd=nil,math.huge
	for _,p in ipairs(Plrs:GetPlayers()) do if p~=plr and p.Character then
		local hum=p.Character:FindFirstChildOfClass("Humanoid") local hrp=p.Character:FindFirstChild("HumanoidRootPart")
		if hum and hrp and hum.Health>0 then
			if aaTC and isTm(p) then continue end if(mh.Position-hrp.Position).Magnitude>aaD then continue end
			local sp,os=cam:WorldToViewportPoint(hrp.Position)
			if os then local sd=(Vector2.new(sp.X,sp.Y)-cs).Magnitude if sd<=aaFOV and sd<cd then cd=sd cl=p end end
		end end end
	return cl,cd
end

local function isAATV(p)
	if not p or not p.Parent or not p.Character then return false end
	local hum=p.Character:FindFirstChildOfClass("Humanoid") local hrp=p.Character:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp or hum.Health<=0 then return false end
	local mh=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
	if not mh or(mh.Position-hrp.Position).Magnitude>aaD then return false end
	local _,os=cam:WorldToViewportPoint(hrp.Position) return os
end

local function apAA(dt)
	if not aaE then return end local mc=plr.Character if not mc or not mc:FindFirstChild("HumanoidRootPart") then return end
	if aaOWA then
		local isA=UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
		if not isA then aaST=nil aaCT=nil aaFL=false return end
	end
	local now=tick() local tgt=nil
	if aaSA and aaST then
		if isAATV(aaST) then local hrp=aaST.Character:FindFirstChild("HumanoidRootPart")
			if hrp then local sp,os=cam:WorldToViewportPoint(hrp.Position)
				if os and(Vector2.new(sp.X,sp.Y)-Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2)).Magnitude<=aaFOV*1.8 then tgt=aaST end end
		end if not tgt and now-lST<aaRD then return end
	end
	if not tgt then tgt=getAAT() if tgt then aaFL=true aaLTS=now end end
	if not tgt or not tgt.Character then aaCT=nil aaST=nil aaFL=false return end
	local isN=(aaST~=tgt) aaST=tgt aaCT=tgt lST=now
	local tp=getAATP(tgt.Character) if not tp then return end
	local tPos=tp.Position
	if aaPr then local hrp=tgt.Character:FindFirstChild("HumanoidRootPart")
		if hrp then tPos=tPos+Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z)*aaPrA end end
	local tsp,os=cam:WorldToViewportPoint(tPos) if not os then return end
	local cs=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2) local oM=(Vector2.new(tsp.X,tsp.Y)-cs).Magnitude
	if oM<=aaID then cam.CFrame=cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position,tPos),0.95) return end
	local ms
	if oM<=aaSDZ then local zf=1-(oM/aaSDZ) ms=aaStr*(0.6+zf*0.4)+aaMag*zf*0.5
	else local ff=1-math.clamp((oM-aaSDZ)/(aaFOV-aaSDZ),0,1) ms=aaStr*(0.2+ff*0.4) end
	if aaFL and isN then ms=math.min(ms+aaSnS*0.3,1) aaFL=false end
	local ts=aaTrS if aaSm and oM<30 then ts=ts*0.5 end ms=math.clamp(ms,0.01,0.95)
	local fl=math.clamp(ms*(1-ts)+ts,0.02,0.9)
	cam.CFrame=cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position,tPos),fl)
end

