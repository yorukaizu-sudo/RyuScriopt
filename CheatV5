	local w=Instance.new("WeldConstraint") w.Part0=h w.Part1=ov w.Parent=ov ov.CFrame=h.CFrame h.CanQuery=false
	d.op=ov d.tc=p.Character d.dc=hm.Died:Connect(function() task.wait(0.5) clHB(p) end)
end

local function upHBE()
	if not hbE then return end
	for _,p in ipairs(Plrs:GetPlayers()) do
		if p~=plr and p.Character then local h=p.Character:FindFirstChild("HumanoidRootPart") local hm=p.Character:FindFirstChildOfClass("Humanoid")
			if h and hm and hm.Health>0 then
				if not hbD[p] then hbD[p]={} end local d=hbD[p]
				if not d.op or not d.op.Parent or d.tc~=p.Character then if d.dc then pcall(function() d.dc:Disconnect() end) end crHBO(p)
				else d.op.Size=Vector3.new(hbSz,hbSz,hbSz) d.op.Transparency=hbTr d.op.Color=hbEspC if h.CanQuery then h.CanQuery=false end end
				if hbEspE and d.op and d.op.Parent then
					if not d.ev or not d.ev.Parent then local b=Instance.new("BoxHandleAdornment") b.Adornee=d.op b.Size=d.op.Size b.Color3=hbEspC b.Transparency=0.5 b.AlwaysOnTop=true b.ZIndex=10 b.Parent=d.op d.ev=b
					else d.ev.Size=d.op.Size d.ev.Color3=hbEspC end
				elseif d.ev then pcall(function() d.ev:Destroy() end) d.ev=nil end
			elseif hbD[p] and hbD[p].op then clHB(p) end
		end
	end
	for p in pairs(hbD) do if not p.Parent then clHB(p) hbD[p]=nil end end
