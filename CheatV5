-- ============ NO RECOIL ============
local function ovSV(o,iS)
	if not isVI(o) or not o:IsA("ValueBase") then return end
	local k=tostring(o) if nrOO[k] then return end
	local ok,v=pcall(function() return o.Value end) if not ok or typeof(v)~="number" then return end
	local rd=iS and(nsStr/100) or(nrStr/100) nrOO[k]={obj=o,originalValue=v,type="value"}
	pcall(function() o.Value=v*(1-rd) end)
end

local function ovSA(o,an,iS)
	if not isVI(o) then return end
	local k=tostring(o).."_a_"..an if nrOO[k] then return end
	local ok,v=pcall(function() return o:GetAttribute(an) end) if not ok or typeof(v)~="number" then return end
	local rd=iS and(nsStr/100) or(nrStr/100) nrOO[k]={obj=o,attrName=an,originalValue=v,type="attribute"}
	pcall(function() o:SetAttribute(an,v*(1-rd)) end)
end

local function ovTR(t,d)
	d=d or 0 if d>4 or typeof(t)~="table" then return end
	for k,v in pairs(t) do
		if typeof(k)=="string" then
			if nrE and typeof(v)=="number" then for _,kw in ipairs(rKW) do if k:lower():find(kw) then t[k]=v*(1-nrStr/100) break end end end
			if nsE and typeof(v)=="number" then for _,kw in ipairs(sKW) do if k:lower():find(kw) then t[k]=v*(1-nsStr/100) break end end end
			if typeof(v)=="table" then ovTR(v,d+1) end
		end
	end
end

local function scET(tool)
	if not tool or not isVI(tool) or not tool:IsA("Tool") then return end
	local c=plr.Character if not c or tool.Parent~=c then return end nrCT=tool
	for _,desc in ipairs(tool:GetDescendants()) do
		if not isVI(desc) then continue end
		if desc:IsA("ValueBase") then
			if nrE and cKW(desc.Name,rKW) then ovSV(desc,false) end
			if nsE and cKW(desc.Name,sKW) then ovSV(desc,true) end
		end
		if desc:IsA("Configuration") or desc:IsA("Folder") then
			for _,ch in ipairs(desc:GetChildren()) do
				if ch:IsA("ValueBase") then
					if nrE and cKW(ch.Name,rKW) then ovSV(ch,false) end
					if nsE and cKW(ch.Name,sKW) then ovSV(ch,true) end
				end
			end
		end
		pcall(function() for an,av in pairs(desc:GetAttributes()) do if typeof(av)=="number" then
			if nrE and cKW(an,rKW) then ovSA(desc,an,false) end
			if nsE and cKW(an,sKW) then ovSA(desc,an,true) end
		end end end)
	end
	pcall(function() for an,av in pairs(tool:GetAttributes()) do if typeof(av)=="number" then
		if nrE and cKW(an,rKW) then ovSA(tool,an,false) end
		if nsE and cKW(an,sKW) then ovSA(tool,an,true) end
	end end end)
	for _,desc in ipairs(tool:GetDescendants()) do
		if desc:IsA("ModuleScript") then local n=desc.Name:lower()
			if n:find("recoil") or n:find("spread") or n:find("config") or n:find("stat") or n:find("setting") or n:find("weapon") or n:find("gun") then
				pcall(function() local md=require(desc) if typeof(md)=="table" then ovTR(md) end end) end end end
end

local function rsNR()
	for _,d in pairs(nrOO) do pcall(function()
		if d.type=="value" and isVI(d.obj) then d.obj.Value=d.originalValue
		elseif d.type=="attribute" and isVI(d.obj) then d.obj:SetAttribute(d.attrName,d.originalValue) end
	end) end
	nrOO={} nrCT=nil nrIS=false nrLCF=nil
end

local function rfNR()
	if not(nrE or nsE) or not nrVO then return end
	for k,d in pairs(nrOO) do
		if not isVI(d.obj) then nrOO[k]=nil continue end
		pcall(function()
			if d.type=="value" then local cv=d.obj.Value if typeof(cv)=="number" then
				local iS=cKW(d.obj.Name,sKW) local rd=iS and(nsStr/100) or(nrStr/100) local tv=d.originalValue*(1-rd)
				if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj.Value=tv end end
			elseif d.type=="attribute" then local cv=d.obj:GetAttribute(d.attrName) if typeof(cv)=="number" then
				local iS=cKW(d.attrName,sKW) local rd=iS and(nsStr/100) or(nrStr/100) local tv=d.originalValue*(1-rd)
				if math.abs(cv-tv)>0.001 and math.abs(cv-d.originalValue)<0.001 then d.obj:SetAttribute(d.attrName,tv) end end end
		end)
	end
end

