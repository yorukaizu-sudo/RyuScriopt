local function isTV(t)
	if not t or not t.Character then return false end local hum=t.Character:FindFirstChildOfClass("Humanoid") if not hum or hum.Health<=0 then return false end
	local tp=t.Character:FindFirstChild(alP) or t.Character:FindFirstChild("HumanoidRootPart") if not tp then return false end
	local mh=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") return mh and(mh.Position-tp.Position).Magnitude<=alD
end

