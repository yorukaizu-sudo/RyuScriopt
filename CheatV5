local function apNC()
	if not nc then return end local c=plr.Character if not c then return end
	for _,v in ipairs(c:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide=false end end
	if ncM=="CFrame Bypass" then
		local h=c:FindFirstChild("HumanoidRootPart") local hm=c:FindFirstChildOfClass("Humanoid")
		if h and hm and hm.MoveDirection.Magnitude>0 then
			local p=RaycastParams.new() p.FilterDescendantsInstances={c} p.FilterType=Enum.RaycastFilterType.Exclude
			if workspace:Raycast(h.Position,hm.MoveDirection*3,p) then h.CFrame=h.CFrame+hm.MoveDirection*1.5 end
		end
		if UIS:IsKeyDown(Enum.KeyCode.Space) then local h=c:FindFirstChild("HumanoidRootPart") if h then h.CFrame=h.CFrame+Vector3.new(0,1,0) end end
	elseif ncM=="Phase Bypass" then pcall(function() c:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Running) end)
	elseif ncM=="Velocity Bypass" then local h=c:FindFirstChild("HumanoidRootPart") if h and h.AssemblyLinearVelocity.Magnitude>60 then h.AssemblyLinearVelocity=h.AssemblyLinearVelocity.Unit*60 end end
