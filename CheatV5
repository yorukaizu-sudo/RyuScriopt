	oL.Brightness=Light.Brightness oL.Ambient=Light.Ambient oL.OutdoorAmbient=Light.OutdoorAmbient
	oL.FogStart=Light.FogStart oL.FogEnd=Light.FogEnd oL.FogColor=Light.FogColor
	oL.ClockTime=Light.ClockTime oL.GlobalShadows=Light.GlobalShadows
	oL.EDS=Light.EnvironmentDiffuseScale oL.ESS=Light.EnvironmentSpecularScale
	local at=Light:FindFirstChildOfClass("Atmosphere")
	if at then oA.D=at.Density oA.O=at.Offset oA.C=at.Color oA.Dc=at.Decay oA.G=at.Glare oA.H=at.Haze end
	local cc=Light:FindFirstChildOfClass("ColorCorrectionEffect")
