local function tbCanSee(fp,tp)
	if not tbVC then return true end
	local p=RaycastParams.new() p.FilterDescendantsInstances={plr.Character} p.FilterType=Enum.RaycastFilterType.Exclude
	local r=workspace:Raycast(fp,(tp.Position-fp),p)
	if r then
		local hm=r.Instance:FindFirstAncestorOfClass("Model") local tm=tp:FindFirstAncestorOfClass("Model")
		if hm and tm and hm==tm then return true end
		if r.Instance:IsDescendantOf(tp.Parent) then return true end
	end
	return r==nil
end

local function getTBT()
	local mc=plr.Character local mh=mc and mc:FindFirstChild("HumanoidRootPart")
	if not mh then return nil end
	local cp=cam.CFrame.Position local cl=cam.CFrame.LookVector
	local p=RaycastParams.new() p.FilterDescendantsInstances={mc} p.FilterType=Enum.RaycastFilterType.Exclude
	local r=workspace:Raycast(cp,cl*tbMD,p)
	if r and r.Instance then
		local hm=r.Instance:FindFirstAncestorOfClass("Model")
		if hm then
			local hp=Plrs:GetPlayerFromCharacter(hm)
			if hp and hp~=plr then
				local hum=hm:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health>0 then
					if tbTC and isTm(hp) then return nil end
					if tbTP~="Any" then
						local hn=r.Instance.Name
						if tbTP=="Head" and hn~="Head" then
							local hd=hm:FindFirstChild("Head")
							if not hd then return nil end
							local sp,os=cam:WorldToViewportPoint(hd.Position)
							if not os then return nil end
							local cs=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2)
							if (Vector2.new(sp.X,sp.Y)-cs).Magnitude>tbRR*5 then return nil end
						elseif tbTP=="Body" then
							local pn=hn:lower()
							local ib=pn:find("torso") or pn:find("humanoidrootpart") or pn:find("upper") or pn:find("lower")
							if not ib and hn~="HumanoidRootPart" then return nil end
						end
					end
					return hp
				end
			end
		end
	end
	if tbRR>1 then
		local cs=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2)
		local cl2,cd=nil,math.huge
		for _,pp in ipairs(Plrs:GetPlayers()) do
			if pp~=plr and pp.Character then
				local hum=pp.Character:FindFirstChildOfClass("Humanoid")
				local hrp=pp.Character:FindFirstChild("HumanoidRootPart")
				if hum and hrp and hum.Health>0 then
					if tbTC and isTm(pp) then continue end
					if (mh.Position-hrp.Position).Magnitude>tbMD then continue end
					local pts={"Head","HumanoidRootPart","UpperTorso","Torso","LowerTorso"}
					if tbTP=="Head" then pts={"Head"} elseif tbTP=="Body" then pts={"HumanoidRootPart","UpperTorso","Torso","LowerTorso"} end
					for _,pn in ipairs(pts) do
						local pt=pp.Character:FindFirstChild(pn)
						if pt then
							local sp,os=cam:WorldToViewportPoint(pt.Position)
							if os then
								local sd=(Vector2.new(sp.X,sp.Y)-cs).Magnitude
								if sd<=tbRR*3 and sd<cd then
									if tbCanSee(cp,pt) then cd=sd cl2=pp end
								end
							end
						end
					end
				end
			end
		end
		return cl2
	end
	return nil
end

