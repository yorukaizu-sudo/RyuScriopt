local function crHBO(p)
	if not p.Character then return end local h=p.Character:FindFirstChild("HumanoidRootPart") local hm=p.Character:FindFirstChildOfClass("Humanoid")
	if not h or not hm or hm.Health<=0 then return end
	if not hbD[p] then hbD[p]={} end local d=hbD[p]
	if d.op and d.op.Parent then pcall(function() d.op:Destroy() end) end
