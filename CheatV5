local function canST(fp,tp)
	if not saVC then return true end
	local p=RaycastParams.new() p.FilterDescendantsInstances={plr.Character} p.FilterType=Enum.RaycastFilterType.Exclude
	local r=workspace:Raycast(fp,(tp.Position-fp),p)
	if r then local hm=r.Instance:FindFirstAncestorOfClass("Model") local tm=tp:FindFirstAncestorOfClass("Model")
		if hm and tm and hm==tm then return true end if r.Instance:IsDescendantOf(tp.Parent) then return true end end
	return r==nil
end

local function getSATP(ch)
	if saAH and math.random(1,100)<=saHC then local h=ch:FindFirstChild("Head") if h then return h end end
	if saP=="Head" then return ch:FindFirstChild("Head") or ch:FindFirstChild("HumanoidRootPart")
	elseif saP=="Body" then return ch:FindFirstChild("HumanoidRootPart") or ch:FindFirstChild("UpperTorso") or ch:FindFirstChild("Torso")
	elseif saP=="Random" then
		local v={} for _,pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do local p=ch:FindFirstChild(pn) if p then table.insert(v,p) end end
		if #v>0 then return v[math.random(1,#v)] end
	elseif saP=="Nearest to Cursor" then
		local cs=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y/2) local cp,cd=nil,math.huge
		for _,pn in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso"}) do local p=ch:FindFirstChild(pn) if p then
