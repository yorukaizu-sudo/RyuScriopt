local function stTL(c)
	if not c then return end
	if nrTC then pcall(function() nrTC:Disconnect() end) end
	nrTC=c.ChildAdded:Connect(function(ch)
		if ch:IsA("Tool") and(nrE or nsE) then task.wait(0.3) if isVI(ch) and ch.Parent==c then scET(ch) end end
	end)
	task.wait(0.5) if not isVI(c) then return end
	for _,ch in ipairs(c:GetChildren()) do if ch:IsA("Tool") and(nrE or nsE) then scET(ch) end end
end

local function dSM()
	if not(nrE or nsE) then return 0 end
	local pl={RepS} pcall(function() table.insert(pl,plr.PlayerScripts) end)
	local ct=0
	for _,p in ipairs(pl) do pcall(function()
		for _,d in ipairs(p:GetDescendants()) do if d:IsA("ModuleScript") then local n=d.Name:lower()
			if n:find("recoil") or n:find("spread") or n:find("weapon") or n:find("gun") or n:find("config") then
				pcall(function() local md=require(d) if typeof(md)=="table" then ovTR(md) ct=ct+1 end end) end end end
	end) end return ct
end

local function hkNRR()
	if nrH then return end nrH=true
	pcall(function() local hf=hookfunction or replaceclosure if not hf then return end
		local oFS oFS=hf(Instance.new("RemoteEvent").FireServer,newcclosure(function(s,...)
			if not(nrE or nsE) then return oFS(s,...) end
			local ok,nm=pcall(function() return s.Name:lower() end) if not ok then return oFS(s,...) end
			local args={...}
			if nrE and nrRI then if nm:find("recoil") or nm:find("kick") or nm:find("camerashake") or nm:find("shake") then if nrStr>=100 then return nil end end end
			if nsE and(nm:find("fire") or nm:find("shoot") or nm:find("attack") or nm:find("bullet")) then
				for i,a in ipairs(args) do
					if typeof(a)=="Vector3" then local ld=cam.CFrame.LookVector if a.Unit:Dot(ld)>0.8 then args[i]=ld:Lerp(a.Unit,1-nsStr/100)*a.Magnitude end
					elseif typeof(a)=="table" then for kk,vv in pairs(a) do if typeof(kk)=="string" and typeof(vv)=="number" then
						if cKW(kk,sKW) then a[kk]=vv*(1-nsStr/100) end if cKW(kk,rKW) then a[kk]=vv*(1-nrStr/100) end end end end
				end return oFS(s,unpack(args))
			end return oFS(s,...)
		end))
	end)
end

