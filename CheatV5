					d.hb.From=Vector2.new(bx,pos.Y+h/2) d.hb.To=Vector2.new(bx,pos.Y+h/2-h*hp) d.hb.Color=Color3.fromRGB(255*(1-hp),255*hp,0) d.hb.Visible=true
				else d.hb.Visible=false d.hg.Visible=false end
				if hd then local yO=(espN and 14 or 0)+(espD and 14 or 0) local np=cam:WorldToViewportPoint((hd.CFrame*CFrame.new(0,2,0)).Position)
					d.ht.Position=Vector2.new(np.X,np.Y+yO) d.ht.Text=math.floor(hum.Health).."/"..math.floor(hum.MaxHealth).." HP" d.ht.Color=Color3.fromRGB(255*(1-hp),255*hp,0) d.ht.Visible=true end
			else d.hb.Visible=false d.hg.Visible=false d.ht.Visible=false end
			if espHL then if not d.hl or not d.hl.Parent then d.hl=Instance.new("Highlight") d.hl.FillColor=col d.hl.OutlineColor=Color3.new(1,1,1) d.hl.FillTransparency=0.7 d.hl.OutlineTransparency=0.3 d.hl.Parent=ch else d.hl.FillColor=col end
			elseif d.hl then pcall(function() d.hl:Destroy() end) d.hl=nil end
		else d.bx.Visible=false d.ln.Visible=false d.nm.Visible=false d.dt.Visible=false d.ht.Visible=false d.hb.Visible=false d.hg.Visible=false d.sf=nil d.st=nil end
	end
end

local function clESP()
	for _,d in pairs(espO) do
		pcall(function() d.bx:Remove() end) pcall(function() d.ln:Remove() end) pcall(function() d.nm:Remove() end)
		pcall(function() d.dt:Remove() end) pcall(function() d.ht:Remove() end) pcall(function() d.hb:Remove() end) pcall(function() d.hg:Remove() end)
		if d.hl then pcall(function() d.hl:Destroy() end) end
	end espO={}
end

