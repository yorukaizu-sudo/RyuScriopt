UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Space and jumpMethod ~= "Default" then isJumping=true; task.delay(0.15,function() isJumping=false end) end
end)

UserInputService.JumpRequest:Connect(function()
	local hum=player.Character and player.Character:FindFirstChildOfClass("Humanoid"); if not hum then return end
	if _G.InfiniteJump then if jumpMethod=="Default" then hum:ChangeState(Enum.HumanoidStateType.Jumping) else isJumping=true; task.delay(0.1,function() isJumping=false end) end
	elseif hum.FloorMaterial~=Enum.Material.Air then isJumping=true; task.delay(0.1,function() isJumping=false end) end
end)

