local function applyNoFall()
	local char=player.Character; if not char then return end; local hrp=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid"); if not hrp or not hum then return end
	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false); hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
	local vel=hrp.AssemblyLinearVelocity
	if noFallMethod=="Default" then if vel.Y<-50 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-10,vel.Z) end
	elseif noFallMethod=="Velocity Brake" then if vel.Y<-50 and getGroundInfo()<20 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-10,vel.Z) end
	elseif noFallMethod=="Health Restore" then if vel.Y<-20 then wasInAir=true; lastHealth=hum.Health end; if wasInAir and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<lastHealth then hum.Health=lastHealth end; wasInAir=false end
	elseif noFallMethod=="Hybrid" then if vel.Y<-20 and not isFalling then isFalling=true; lastHealth=hum.Health end; if vel.Y<-80 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,-30,vel.Z) end; if isFalling and hum.FloorMaterial~=Enum.Material.Air then if hum.Health<lastHealth then hum.Health=lastHealth end; isFalling=false end end
end

