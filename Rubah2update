local function getGroundInfo() local hrp=player.Character and player.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return math.huge end; local p=RaycastParams.new(); p.FilterDescendantsInstances={player.Character}; p.FilterType=Enum.RaycastFilterType.Exclude; local r=workspace:Raycast(hrp.Position,Vector3.new(0,-500,0),p); return r and (hrp.Position-r.Position).Magnitude or math.huge end

local function applySpeed(dt)
	local char=player.Character; if not char then return end; local hrp=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChildOfClass("Humanoid"); if not hrp or not hum then return end
	if speedMethod=="Default" then hum.WalkSpeed=speed
	elseif speedMethod=="CFrame Bypass" then hum.WalkSpeed=16; local d=getMoveDirection(); if d.Magnitude>0 and speed>16 then hrp.CFrame=hrp.CFrame+(d*(speed-16)*dt) end
	elseif speedMethod=="Velocity Bypass" then hum.WalkSpeed=16; local d=getMoveDirection(); if d.Magnitude>0 then hrp.AssemblyLinearVelocity=Vector3.new(d.X*speed,hrp.AssemblyLinearVelocity.Y,d.Z*speed) end
	elseif speedMethod=="BodyVelocity Bypass" then hum.WalkSpeed=16; local bv=hrp:FindFirstChild("SpeedBV"); if not bv then bv=Instance.new("BodyVelocity"); bv.Name="SpeedBV"; bv.MaxForce=Vector3.new(100000,0,100000); bv.P=10000; bv.Parent=hrp end; local d=getMoveDirection(); if d.Magnitude>0 then bv.Velocity=d*speed; bv.MaxForce=Vector3.new(100000,0,100000) else bv.Velocity=Vector3.zero; bv.MaxForce=Vector3.zero end end
