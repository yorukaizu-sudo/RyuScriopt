				local fp = Instance.new("Part")
				fp.Name = "AH_" .. pn fp.Size = Vector3.new(antiHitboxSize, antiHitboxSize, antiHitboxSize)
				fp.Transparency = 1 fp.CanCollide = false fp.CanQuery = true
				fp.Anchored = false fp.Massless = true fp.Parent = mc
				local w = Instance.new("WeldConstraint") w.Part0 = part w.Part1 = fp w.Parent = fp
				fp.CFrame = part.CFrame d.fakePart = fp
			else d.fakePart.Size = Vector3.new(antiHitboxSize, antiHitboxSize, antiHitboxSize) end
