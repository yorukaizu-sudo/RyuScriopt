	local mc = player.Character
	if not mc or not mc:FindFirstChild("HumanoidRootPart") then return end
	local parts = {"Head", "Torso", "UpperTorso", "LowerTorso", "LeftArm", "RightArm", "LeftLeg", "RightLeg", "Left Arm", "Right Arm", "Left Leg", "Right Leg", "HumanoidRootPart"}
	for _, pn in ipairs(parts) do
