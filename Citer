-- ==========================================
local function getMoveDirection()
	local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not hum then return Vector3.zero end
	return hum.MoveDirection.Magnitude > 0 and hum.MoveDirection.Unit or Vector3.zero
end

local function getGroundInfo()
	local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return math.huge end
	local params = RaycastParams.new() params.FilterDescendantsInstances = {player.Character} params.FilterType = Enum.RaycastFilterType.Exclude
	local r = workspace:Raycast(hrp.Position, Vector3.new(0, -500, 0), params) return r and (hrp.Position - r.Position).Magnitude or math.huge
end

local function applySpeed(dt)
	local char = player.Character if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	if speedMethod == "Default" then hum.WalkSpeed = speed
	elseif speedMethod == "CFrame Bypass" then hum.WalkSpeed = 16 local d = getMoveDirection() if d.Magnitude > 0 and speed > 16 then hrp.CFrame = hrp.CFrame + (d * (speed - 16) * dt) end
	elseif speedMethod == "Velocity Bypass" then hum.WalkSpeed = 16 local d = getMoveDirection() if d.Magnitude > 0 then hrp.AssemblyLinearVelocity = Vector3.new(d.X * speed, hrp.AssemblyLinearVelocity.Y, d.Z * speed) end
	elseif speedMethod == "BodyVelocity Bypass" then
		hum.WalkSpeed = 16 local bv = hrp:FindFirstChild("SpeedBV")
		if not bv then bv = Instance.new("BodyVelocity") bv.Name = "SpeedBV" bv.MaxForce = Vector3.new(100000, 0, 100000) bv.P = 10000 bv.Parent = hrp end
		local d = getMoveDirection() bv.Velocity = d.Magnitude > 0 and d * speed or Vector3.zero bv.MaxForce = d.Magnitude > 0 and Vector3.new(100000, 0, 100000) or Vector3.zero
	end
end

local function applyJump()
	local char = player.Character if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	if jumpMethod == "Default" then hum.UseJumpPower = true hum.JumpPower = jumpPower
	else hum.JumpPower = 0 if isJumping and canJump then canJump = false
		if jumpMethod == "CFrame Bypass" then hrp.CFrame = hrp.CFrame + Vector3.new(0, jumpPower / 50, 0)
		elseif jumpMethod == "Velocity Bypass" then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, jumpPower, hrp.AssemblyLinearVelocity.Z)
		elseif jumpMethod == "BodyVelocity Bypass" then
			local bv = Instance.new("BodyVelocity") bv.MaxForce = Vector3.new(0, 100000, 0) bv.Velocity = Vector3.new(0, jumpPower, 0) bv.Parent = hrp
			task.delay(0.15, function() if bv.Parent then bv:Destroy() end end) end
		task.delay(0.3, function() canJump = true end) end end
end

local function applyNoFall()
	local char = player.Character if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
	local vel = hrp.AssemblyLinearVelocity
	if noFallMethod == "Default" then if vel.Y < -50 then hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -10, vel.Z) end
	elseif noFallMethod == "Velocity Brake" then if vel.Y < -50 and getGroundInfo() < 20 then hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -10, vel.Z) end
	elseif noFallMethod == "Health Restore" then
		if vel.Y < -20 then wasInAir = true lastHealth = hum.Health end
		if wasInAir and hum.FloorMaterial ~= Enum.Material.Air then if hum.Health < lastHealth then hum.Health = lastHealth end wasInAir = false end
	elseif noFallMethod == "Hybrid" then
		if vel.Y < -20 and not isFalling then isFalling = true lastHealth = hum.Health end
		if vel.Y < -80 then hrp.AssemblyLinearVelocity = Vector3.new(vel.X, -30, vel.Z) end
		if isFalling and hum.FloorMaterial ~= Enum.Material.Air then if hum.Health < lastHealth then hum.Health = lastHealth end isFalling = false end
	end
end

local function getClosestInFOV()
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart") if not myHrp then return nil end
	local closest, cd = nil, math.huge local sc = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			if aimlockTeamCheck and isTeammate(p) then continue end
			local tp = p.Character:FindFirstChild(aimlockPart) or p.Character:FindFirstChild("HumanoidRootPart")
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			if tp and hum and hum.Health > 0 and (myHrp.Position - tp.Position).Magnitude <= aimlockDistance then
				local sp, os = camera:WorldToScreenPoint(tp.Position)
				if os then local sd = (Vector2.new(sp.X, sp.Y) - sc).Magnitude if sd <= aimlockFOV and sd < cd then cd = sd closest = p end end
			end
		end
	end
	return closest
end

local function isTargetValid(t)
	if not t or not t.Character then return false end
	local hum = t.Character:FindFirstChildOfClass("Humanoid") if not hum or hum.Health <= 0 then return false end
	local tp = t.Character:FindFirstChild(aimlockPart) or t.Character:FindFirstChild("HumanoidRootPart") if not tp then return false end
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	return myHrp and (myHrp.Position - tp.Position).Magnitude <= aimlockDistance
end

local function updateVehicleESP()
	if not vehicleEspEnabled then return end
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart") if not myHrp then return end
	local vehs = getAllVehicles()
	for m, o in pairs(vehicleEspObjects) do
		if not m.Parent then
			if o.highlight then pcall(function() o.highlight:Destroy() end) end
			if o.billboard then pcall(function() o.billboard:Destroy() end) end
			vehicleEspObjects[m] = nil
		end
	end
	for _, v in ipairs(vehs) do
		local m = v.Model if not vehicleEspObjects[m] then vehicleEspObjects[m] = {} end local o = vehicleEspObjects[m]
		if not o.highlight or not o.highlight.Parent then
			local h = Instance.new("Highlight") h.FillColor = vehicleEspColor h.OutlineColor = vehicleEspColor h.FillTransparency = 0.7 h.Parent = m o.highlight = h
		else o.highlight.FillColor = vehicleEspColor end
		local dist = (myHrp.Position - v.Seat.Position).Magnitude
		if not o.billboard or not o.billboard.Parent then
			local bb = Instance.new("BillboardGui") bb.Size = UDim2.new(0, 150, 0, 40) bb.StudsOffset = Vector3.new(0, 5, 0) bb.AlwaysOnTop = true bb.Parent = v.Seat
			local l = Instance.new("TextLabel") l.Size = UDim2.new(1, 0, 1, 0) l.BackgroundTransparency = 1 l.TextColor3 = vehicleEspColor l.TextStrokeTransparency = 0 l.Font = Enum.Font.GothamBold l.TextSize = 12 l.Parent = bb
			o.billboard = bb o.label = l
		end
		if o.label then
			o.label.Text = v.Name .. " [" .. math.floor(dist) .. "m]" .. (v.Seat.Occupant and " [OCC]" or " [FREE]")
			o.label.TextColor3 = v.Seat.Occupant and Color3.fromRGB(255, 100, 100) or vehicleEspColor
		end
	end
end

local function applyVehicleSpeed()
	if not vehicleSpeedEnabled then return end
	local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid") if not hum or not hum.SeatPart then return end
	if hum.SeatPart:IsA("VehicleSeat") then pcall(function() hum.SeatPart.MaxSpeed = vehicleSpeed hum.SeatPart.Torque = vehicleSpeed * 2 end) end
end

local function updateNoCooldown()
	if not noCooldown then return end updatePromptCache()
	for _, v in ipairs(cachedPrompts) do if v.Parent then v.MaxActivationDistance = interactRange pcall(function() v.Cooldown = 0 v.HoldDuration = 0 v.RequiresLineOfSight = false end) end end
	for _, v in ipairs(cachedClickDetectors) do if v.Parent then v.MaxActivationDistance = interactRange end end
end

