-- Cek apakah nama mengandung keyword
local function containsKeyword(name, keywords)
	local nameLower = name:lower()
	for _, kw in ipairs(keywords) do
		if nameLower:find(kw:lower()) then
			return true
		end
	end
	return false
end

-- Override satu value/attribute
local function overrideRecoilValue(obj, propName, isSpread)
	local key = tostring(obj) .. "_" .. propName
	if not noRecoilOriginalValues[key] then
		pcall(function()
			noRecoilOriginalValues[key] = {
				obj = obj,
				prop = propName,
				value = obj[propName],
				isAttribute = false
			}
		end)
	end
	
	local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
	
	pcall(function()
		local val = obj[propName]
		if typeof(val) == "number" then
			obj[propName] = val * (1 - reduction)
		elseif typeof(val) == "Vector3" then
			obj[propName] = val * (1 - reduction)
		elseif typeof(val) == "Vector2" then
			obj[propName] = val * (1 - reduction)
		elseif typeof(val) == "CFrame" then
			obj[propName] = CFrame.new()
		elseif typeof(val) == "boolean" and (propName:lower():find("recoil") or propName:lower():find("spread")) then
			obj[propName] = false
		end
	end)
end

-- Override attribute
local function overrideRecoilAttribute(obj, attrName, isSpread)
	local key = tostring(obj) .. "_attr_" .. attrName
	if not noRecoilOriginalValues[key] then
		pcall(function()
			noRecoilOriginalValues[key] = {
				obj = obj,
				attr = attrName,
				value = obj:GetAttribute(attrName),
				isAttribute = true
			}
		end)
	end
	
	local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
	
	pcall(function()
		local val = obj:GetAttribute(attrName)
		if typeof(val) == "number" then
			obj:SetAttribute(attrName, val * (1 - reduction))
		elseif typeof(val) == "Vector3" then
			obj:SetAttribute(attrName, val * (1 - reduction))
		elseif typeof(val) == "Vector2" then
			obj:SetAttribute(attrName, val * (1 - reduction))
		end
	end)
end

-- Scan tool/weapon untuk recoil values
local function scanAndOverrideWeapon(tool)
	if not tool then return end
	local toolKey = tool:GetFullName()
	
	for _, descendant in ipairs(tool:GetDescendants()) do
		-- NumberValue, IntValue, dll
		if descendant:IsA("ValueBase") then
			local name = descendant.Name
			if containsKeyword(name, recoilKeywords) and noRecoilEnabled then
				pcall(function()
					local key = tostring(descendant) .. "_Value"
					if not noRecoilOriginalValues[key] then
						noRecoilOriginalValues[key] = {
							obj = descendant,
							prop = "Value",
							value = descendant.Value,
							isAttribute = false,
							isValueBase = true
						}
					end
					local reduction = noRecoilStrength / 100
					if typeof(descendant.Value) == "number" then
						descendant.Value = descendant.Value * (1 - reduction)
					end
				end)
			end
			if containsKeyword(name, spreadKeywords) and noSpreadEnabled then
				pcall(function()
					local key = tostring(descendant) .. "_Value"
					if not noRecoilOriginalValues[key] then
						noRecoilOriginalValues[key] = {
							obj = descendant,
							prop = "Value",
							value = descendant.Value,
							isAttribute = false,
							isValueBase = true
						}
					end
					local reduction = noSpreadStrength / 100
					if typeof(descendant.Value) == "number" then
						descendant.Value = descendant.Value * (1 - reduction)
					end
				end)
			end
		end
		
		-- Configuration / Folder dengan children yang bisa di-override
		if descendant:IsA("Configuration") or descendant:IsA("Folder") then
			local name = descendant.Name:lower()
			if name:find("recoil") or name:find("spread") or name:find("gun") or name:find("weapon") or name:find("stat") or name:find("config") or name:find("setting") then
				for _, child in ipairs(descendant:GetChildren()) do
					if child:IsA("ValueBase") then
						if containsKeyword(child.Name, recoilKeywords) and noRecoilEnabled then
							pcall(function()
								local key = tostring(child) .. "_Value"
								if not noRecoilOriginalValues[key] then
									noRecoilOriginalValues[key] = {obj = child, prop = "Value", value = child.Value, isAttribute = false, isValueBase = true}
								end
								if typeof(child.Value) == "number" then
									child.Value = child.Value * (1 - noRecoilStrength / 100)
								end
							end)
						end
						if containsKeyword(child.Name, spreadKeywords) and noSpreadEnabled then
							pcall(function()
								local key = tostring(child) .. "_Value"
								if not noRecoilOriginalValues[key] then
									noRecoilOriginalValues[key] = {obj = child, prop = "Value", value = child.Value, isAttribute = false, isValueBase = true}
								end
								if typeof(child.Value) == "number" then
									child.Value = child.Value * (1 - noSpreadStrength / 100)
								end
							end)
						end
					end
				end
			end
		end
		
		-- ModuleScript - coba override return values (limited)
		if descendant:IsA("ModuleScript") then
			local name = descendant.Name:lower()
			if name:find("recoil") or name:find("spread") or name:find("gun") or name:find("weapon") or name:find("config") then
				pcall(function()
					local moduleData = require(descendant)
					if typeof(moduleData) == "table" then
						overrideTableRecoil(moduleData)
					end
				end)
			end
		end
	end
	
	-- Scan attributes pada tool dan descendants
	pcall(function()
		local attrs = tool:GetAttributes()
		for attrName, attrVal in pairs(attrs) do
			if containsKeyword(attrName, recoilKeywords) and noRecoilEnabled then
				overrideRecoilAttribute(tool, attrName, false)
			end
			if containsKeyword(attrName, spreadKeywords) and noSpreadEnabled then
				overrideRecoilAttribute(tool, attrName, true)
			end
		end
		for _, desc in ipairs(tool:GetDescendants()) do
			pcall(function()
				local dAttrs = desc:GetAttributes()
				for attrName, attrVal in pairs(dAttrs) do
					if containsKeyword(attrName, recoilKeywords) and noRecoilEnabled then
						overrideRecoilAttribute(desc, attrName, false)
					end
					if containsKeyword(attrName, spreadKeywords) and noSpreadEnabled then
						overrideRecoilAttribute(desc, attrName, true)
					end
				end
			end)
		end
	end)
	
	noRecoilScannedTools[toolKey] = true
end

-- Override table dari ModuleScript
function overrideTableRecoil(tbl, depth)
	depth = depth or 0
	if depth > 5 then return end -- Prevent infinite recursion
	
	for key, val in pairs(tbl) do
		if typeof(key) == "string" then
			local keyLower = key:lower()
			
			-- Recoil values
			if noRecoilEnabled then
				for _, kw in ipairs(recoilKeywords) do
					if keyLower:find(kw:lower()) then
						if typeof(val) == "number" then
							tbl[key] = val * (1 - noRecoilStrength / 100)
						elseif typeof(val) == "Vector3" then
							tbl[key] = val * (1 - noRecoilStrength / 100)
						elseif typeof(val) == "Vector2" then
							tbl[key] = val * (1 - noRecoilStrength / 100)
						elseif typeof(val) == "table" then
							overrideTableRecoil(val, depth + 1)
						end
						break
					end
				end
			end
			
			-- Spread values
			if noSpreadEnabled then
				for _, kw in ipairs(spreadKeywords) do
					if keyLower:find(kw:lower()) then
						if typeof(val) == "number" then
							tbl[key] = val * (1 - noSpreadStrength / 100)
						elseif typeof(val) == "Vector3" then
							tbl[key] = val * (1 - noSpreadStrength / 100)
						elseif typeof(val) == "Vector2" then
							tbl[key] = val * (1 - noSpreadStrength / 100)
						elseif typeof(val) == "table" then
							overrideTableRecoil(val, depth + 1)
						end
						break
					end
				end
			end
			
			-- Recurse into sub-tables
			if typeof(val) == "table" then
				local hasRecoilKey = keyLower:find("config") or keyLower:find("stat") or keyLower:find("setting") or keyLower:find("weapon") or keyLower:find("gun") or keyLower:find("data")
				if hasRecoilKey then
					overrideTableRecoil(val, depth + 1)
				end
			end
		end
	end
end

-- Scan semua senjata di workspace, ReplicatedStorage, dan character
local function scanAllWeapons()
	local now = tick()
	if now - noRecoilLastScanTime < NO_RECOIL_SCAN_RATE then return end
	noRecoilLastScanTime = now
	
	-- Scan equipped tools
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") then
				local key = item:GetFullName()
				if not noRecoilScannedTools[key] then
					scanAndOverrideWeapon(item)
				end
			end
		end
	end
	
	-- Scan backpack
	local bp = player:FindFirstChild("Backpack")
	if bp then
		for _, item in ipairs(bp:GetChildren()) do
			if item:IsA("Tool") then
				local key = item:GetFullName()
				if not noRecoilScannedTools[key] then
					scanAndOverrideWeapon(item)
				end
			end
		end
	end
	
	-- Scan ReplicatedStorage (beberapa game simpan config di sini)
	pcall(function()
		for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
			if desc:IsA("ModuleScript") then
				local name = desc.Name:lower()
				if name:find("recoil") or name:find("spread") or name:find("weapon") or name:find("gun") or name:find("firearm") then
					local key = desc:GetFullName()
					if not noRecoilScannedTools[key] then
						pcall(function()
							local moduleData = require(desc)
							if typeof(moduleData) == "table" then
								overrideTableRecoil(moduleData)
								noRecoilScannedTools[key] = true
							end
						end)
					end
				end
			end
		end
	end)
	
	-- Scan StarterPack (template tools)
	pcall(function()
		local sp = game:GetService("StarterPack")
		for _, item in ipairs(sp:GetDescendants()) do
			if item:IsA("Tool") then
				local key = item:GetFullName()
				if not noRecoilScannedTools[key] then
					scanAndOverrideWeapon(item)
				end
			end
		end
	end)
end

-- Camera Lock: simpan CFrame saat mulai tembak, restore terus selama menembak
local function applyNoRecoilCameraLock()
	if not noRecoilCameraLock then return end
	
	local isShooting = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
	
	if isShooting then
		if not noRecoilIsShooting then
			-- Baru mulai menembak, simpan CFrame
			noRecoilIsShooting = true
			noRecoilLockedCFrame = camera.CFrame
		else
			-- Sedang menembak, lerp camera kembali ke posisi awal
			if noRecoilLockedCFrame then
				local strength = noRecoilStrength / 100
				-- Hanya lock rotasi, biarkan posisi mengikuti player
				local currentPos = camera.CFrame.Position
				local lockedLook = noRecoilLockedCFrame.LookVector
				local targetCF = CFrame.new(currentPos, currentPos + lockedLook)
				camera.CFrame = camera.CFrame:Lerp(targetCF, strength * 0.8)
			end
		end
	else
		if noRecoilIsShooting then
			noRecoilIsShooting = false
			noRecoilLockedCFrame = nil
		end
	end
end

-- Hook remote events untuk intercept recoil data
local function hookNoRecoilRemotes()
	if noRecoilHooked then return end
	noRecoilHooked = true
	
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		
		-- Hook FireServer untuk intercept recoil-related remotes
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (noRecoilEnabled or noSpreadEnabled) then
				return oldFS(self, ...)
			end
			
			local name = self.Name:lower()
			local args = {...}
			
			-- Intercept recoil remotes
			if noRecoilEnabled and noRecoilRemoteIntercept then
				if name:find("recoil") or name:find("kick") or name:find("camera") or name:find("shake") then
					-- Block atau reduce recoil remote
					if noRecoilStrength >= 100 then
						return nil -- Block entirely
					end
				end
			end
			
			-- Modify spread in fire/shoot remotes
			if noSpreadEnabled then
				if name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") or name:find("weapon") then
					for i, arg in ipairs(args) do
						if typeof(arg) == "Vector3" then
							-- Jika ini direction vector, buat lebih akurat
							-- Biasanya direction = camera.CFrame.LookVector + spread
							-- Kita ganti dengan pure look direction
							local lookDir = camera.CFrame.LookVector
							local dotProduct = arg.Unit:Dot(lookDir)
							if dotProduct > 0.8 then -- Hanya jika mirip look direction
								local reduction = noSpreadStrength / 100
								local corrected = lookDir:Lerp(arg.Unit, 1 - reduction)
								args[i] = corrected * arg.Magnitude
							end
						elseif typeof(arg) == "CFrame" then
							-- Jika CFrame, mungkin aim CFrame - straighten it
							local lookDir = camera.CFrame.LookVector
							local correctedCF = CFrame.new(arg.Position, arg.Position + lookDir)
							local reduction = noSpreadStrength / 100
							args[i] = arg:Lerp(correctedCF, reduction)
						elseif typeof(arg) == "table" then
							-- Override spread values dalam table
							for k, v in pairs(arg) do
								if typeof(k) == "string" then
									if containsKeyword(k, spreadKeywords) and typeof(v) == "number" then
										arg[k] = v * (1 - noSpreadStrength / 100)
									end
									if containsKeyword(k, recoilKeywords) and typeof(v) == "number" then
										arg[k] = v * (1 - noRecoilStrength / 100)
									end
								end
							end
						end
					end
					return oldFS(self, unpack(args))
				end
			end
			
			return oldFS(self, ...)
		end))
	end)
	
	-- Hook InvokeServer juga
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		
		local oldIS
		oldIS = hf(Instance.new("RemoteFunction").InvokeServer, newcclosure(function(self, ...)
			if not (noRecoilEnabled or noSpreadEnabled) then
				return oldIS(self, ...)
			end
			
			local name = self.Name:lower()
			if noRecoilEnabled and noRecoilRemoteIntercept then
				if name:find("recoil") or name:find("kick") then
					return nil
				end
			end
			
			return oldIS(self, ...)
		end))
	end)
end

-- Override BodyAngularVelocity dan BodyGyro yang dipakai untuk recoil visual
local function overrideRecoilPhysics()
	if not noRecoilEnabled then return end
	
	local char = player.Character
	if not char then return end
	
	-- Remove recoil-related BodyMovers
	for _, desc in ipairs(char:GetDescendants()) do
		if desc:IsA("BodyAngularVelocity") or desc:IsA("BodyGyro") then
			if desc.Name:lower():find("recoil") or desc.Name:lower():find("kick") or desc.Name:lower():find("shake") then
				pcall(function() desc:Destroy() end)
			end
		end
	end
	
	-- Override camera recoil springs/modules di PlayerScripts
	pcall(function()
		for _, desc in ipairs(player.PlayerScripts:GetDescendants()) do
			if desc:IsA("ModuleScript") then
				local name = desc.Name:lower()
				if name:find("recoil") or name:find("spring") or name:find("shake") or name:find("sway") then
					pcall(function()
						local moduleData = require(desc)
						if typeof(moduleData) == "table" then
							overrideTableRecoil(moduleData)
						end
					end)
				end
			end
		end
	end)
end

-- Continuously override recoil (untuk game yang reset values)
local function continuousRecoilOverride()
	if not (noRecoilEnabled or noSpreadEnabled) then return end
	
	local char = player.Character
	if not char then return end
	
	-- Re-scan equipped tool setiap cycle (game bisa reset values)
	for _, item in ipairs(char:GetChildren()) do
		if item:IsA("Tool") then
			-- Force re-scan setiap cycle
			for _, descendant in ipairs(item:GetDescendants()) do
				if descendant:IsA("ValueBase") then
					local name = descendant.Name
					if noRecoilEnabled and containsKeyword(name, recoilKeywords) then
						pcall(function()
							if typeof(descendant.Value) == "number" then
								local reduction = noRecoilStrength / 100
								if descendant.Value > 0.001 then
									descendant.Value = descendant.Value * (1 - reduction)
								end
							end
						end)
					end
					if noSpreadEnabled and containsKeyword(name, spreadKeywords) then
						pcall(function()
							if typeof(descendant.Value) == "number" then
								local reduction = noSpreadStrength / 100
								if descendant.Value > 0.001 then
									descendant.Value = descendant.Value * (1 - reduction)
								end
							end
						end)
					end
				end
			end
			
			-- Override attributes terus-menerus
			pcall(function()
				for _, desc in ipairs(item:GetDescendants()) do
					local attrs = desc:GetAttributes()
					for attrName, attrVal in pairs(attrs) do
						if typeof(attrVal) == "number" and attrVal > 0.001 then
							if noRecoilEnabled and containsKeyword(attrName, recoilKeywords) then
								desc:SetAttribute(attrName, attrVal * (1 - noRecoilStrength / 100))
							end
							if noSpreadEnabled and containsKeyword(attrName, spreadKeywords) then
								desc:SetAttribute(attrName, attrVal * (1 - noSpreadStrength / 100))
							end
						end
					end
				end
			end)
		end
	end
end

-- Restore semua original values
