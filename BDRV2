local function parseArgs(str)
	local args = {}
	if str == "" then return args end
	for _, arg in ipairs(string.split(str, ",")) do
		local t = arg:match("^%s*(.-)%s*$")
		if t == "player" then table.insert(args, player)
		elseif t == "player.Name" then table.insert(args, player.Name)
		elseif t == "player.UserId" then table.insert(args, player.UserId)
		elseif t == "true" then table.insert(args, true)
		elseif t == "false" then table.insert(args, false)
		elseif t == "nil" then table.insert(args, nil)
		elseif t == "inf" then table.insert(args, math.huge)
		elseif tonumber(t) then table.insert(args, tonumber(t))
		else table.insert(args, t) end
	end
	return args
end

local function findRemote(path)
	local parts = string.split(path, ".")
	local current = game
	for _, part in ipairs(parts) do
		local next = nil
		pcall(function() next = current:FindFirstChild(part) end)
		if not next then pcall(function() next = current[part] end) end
		if not next then return nil end
		current = next
	end
	return current
end

