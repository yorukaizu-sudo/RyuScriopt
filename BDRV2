-- ==========================================
-- FIRE REMOTE WITH TRACKING
-- ==========================================
local function fireRemoteTracked(remote, args, info, isEvent)
	if safeMode and info and info.isDangerous then
		return nil, "skipped_dangerous", nil
	end

	deepSnapshot()

	local success, result
	local attempts = autoRetry and retryCount or 1

	for attempt = 1, attempts do
		if isEvent then
			success, result = pcall(function()
				remote:FireServer(unpack(args))
			end)
		else
			success, result = pcall(function()
				return remote:InvokeServer(unpack(args))
			end)
		end
		if success then break end
		if attempt < attempts then task.wait(0.05) end
	end

	task.wait(0.15)

	local changes = deepCheckChanges(remote.Name)

	if not isEvent and success and result ~= nil then
		totalResponses = totalResponses + 1
		local responseStr = tostring(result)
		pcall(function()
			if typeof(result) == "table" then
				responseStr = HttpService:JSONEncode(result)
			end
		end)
		table.insert(responseLog, {
			remote = remote.Name, path = getRemotePath(remote),
			args = #args, response = (responseStr or ""):sub(1, 500),
			time = os.clock()
		})
	end

	if changes.hasChanges then
		if info then info.vulnerable = true end
		totalVulnerable = totalVulnerable + 1

		local changeMsg = ""
		if #changes.newItems > 0 then
			local names = {}
			for _, i in ipairs(changes.newItems) do table.insert(names, i.name) end
			changeMsg = "Items: " .. table.concat(names, ", ")
		end
		if #changes.statChanges > 0 then
			local stats = {}
			for _, s in ipairs(changes.statChanges) do
				table.insert(stats, s.name .. ":" .. tostring(s.diff))
			end
			if changeMsg ~= "" then changeMsg = changeMsg .. " | " end
			changeMsg = changeMsg .. "Stats: " .. table.concat(stats, ", ")
		end

		addLog(string.format("🔓 VULN: %s -> %s (args: %d)", remote.Name, changeMsg, #args), "vuln")

		local vulnEntry = {
			remote = remote, name = remote.Name,
			path = getRemotePath(remote), className = remote.ClassName,
			args = args, items = changes.newItems,
			charItems = changes.newCharItems, statChanges = changes.statChanges,
			response = result, time = os.clock(),
			category = info and info.category or "unknown",
			argTypes = (function()
				local types = {}
				for _, a in ipairs(args) do table.insert(types, typeof(a)) end
				return types
			end)()
		}
		table.insert(vulnerableRemotes, vulnEntry)

		-- Auto-classify for farming
		if info and (info.isCurrencyRelated or info.isFarmable or info.isGiveRelated) then
			table.insert(exploitableRemotes, vulnEntry)
			addLog("💰 Added to auto-farm list: " .. remote.Name, "farm")
		end
	end

	if success then
		totalScanned = totalScanned + 1
		return true, result, changes
	else
		totalErrors = totalErrors + 1
		return false, result, changes
	end
end

-- ==========================================
-- FULL SCAN ENGINE
-- ==========================================
local function runFullScan()
	if isScanning then
		addLog("Scan already running!", "warning")
		return
	end

	isScanning = true
	totalScanned = 0
	totalVulnerable = 0
	totalErrors = 0
	totalItems = 0
	totalResponses = 0
	scanResults = {}
	vulnerableRemotes = {}
	exploitableRemotes = {}
	responseLog = {}

	addLog("══════════ FULL SCAN + AUTO-DETECT ══════════", "info")

	fingerprintGame()
	collectAllRemotes()

	if obfuscationDetection then
		hiddenRemotes = {}
		for _, service in ipairs(game:GetChildren()) do
			pcall(function()
				local function deepSearch(parent, depth)
					if depth > 15 then return end
					pcall(function()
						for _, child in ipairs(parent:GetChildren()) do
							pcall(function()
								if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
									local isObf, obfType = isObfuscatedName(child.Name)
									if isObf then
										table.insert(hiddenRemotes, {
											instance = child, name = child.Name,
											path = getRemotePath(child), className = child.ClassName,
											obfuscationType = obfType, depth = depth
										})
									end
								end
								deepSearch(child, depth + 1)
							end)
						end
					end)
				end
				deepSearch(service, 0)
			end)
		end
		addLog(string.format("Found %d hidden remotes", #hiddenRemotes), "discovery")
	end

	-- Analyze and prioritize all remotes
	local allRemotes = {}
	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			local info = analyzeRemote(re)
			info.instance = re
			info.isEvent = true
			table.insert(allRemotes, info)
		end
	end
	for _, rf in ipairs(remoteFunctions) do
		if isValidInstance(rf) then
			local info = analyzeRemote(rf)
			info.instance = rf
			info.isEvent = false
			table.insert(allRemotes, info)
		end
	end

	table.sort(allRemotes, function(a, b) return a.priority > b.priority end)

	addLog(string.format("Scanning %d remotes (Game: %s | Security: %s)",
		#allRemotes, gameFingerprint.gameType, gameFingerprint.securityLevel), "info")

	local scanStartTime = os.clock()

	for idx, info in ipairs(allRemotes) do
		if not isScanning then
			addLog("Scan cancelled!", "warning")
			break
		end
		if not isValidInstance(info.instance) then continue end

		local labels = {}
		if info.isAdminRelated then table.insert(labels, "🔑ADMIN") end
		if info.isGiveRelated then table.insert(labels, "🎁GIVE") end
		if info.isCurrencyRelated then table.insert(labels, "💰MONEY") end
		if info.isFarmable then table.insert(labels, "🌾FARM") end
		if info.isTrollable then table.insert(labels, "🤡TROLL") end
		if info.isObfuscated then table.insert(labels, "🔒OBF") end
		if info.isDangerous then table.insert(labels, "⚠️DANGER") end
		local labelStr = #labels > 0 and (" " .. table.concat(labels, " ")) or ""

		addLog(string.format("[%d/%d] %s%s (p=%d)",
			idx, #allRemotes, info.path, labelStr, info.priority), "info")

		local testArgs = generateSmartArgs(info.name, info, bruteForceLevel)

		local maxArgs
		if info.priority >= 5 then maxArgs = #testArgs
		elseif info.priority >= 2 then maxArgs = math.min(maxArgCombinations * 2, #testArgs)
		else maxArgs = math.min(maxArgCombinations, #testArgs) end

		local foundVuln = false
		for argIdx = 1, maxArgs do
			if not isScanning then break end
			if foundVuln and not info.isAdminRelated then break end

			pcall(function()
				local ok, result, changes = fireRemoteTracked(info.instance, testArgs[argIdx], info, info.isEvent)
				if ok and changes and changes.hasChanges then foundVuln = true end
			end)
			task.wait(fireDelay)
		end

		table.insert(scanResults, info)
		task.wait(scanDelay)

		if idx % 10 == 0 then
			addLog(string.format("Progress: %d/%d | Vuln: %d | Items: %d | Farm: %d",
				idx, #allRemotes, totalVulnerable, totalItems, #exploitableRemotes), "info")
		end
	end

	local elapsed = os.clock() - scanStartTime
	addLog("══════════ SCAN COMPLETE ══════════", "success")
	addLog(string.format("Time: %.1fs | Scanned: %d | Vulnerable: %d | Farmable: %d | Items: %d",
		elapsed, totalScanned, totalVulnerable, #exploitableRemotes, totalItems), "success")

	if #vulnerableRemotes > 0 then
		addLog("══════════ VULNERABILITIES ══════════", "vuln")
		for i, v in ipairs(vulnerableRemotes) do
			local itemNames = {}
			for _, item in ipairs(v.items or {}) do table.insert(itemNames, item.name) end
			local statNames = {}
			for _, s in ipairs(v.statChanges or {}) do table.insert(statNames, s.name .. ":" .. tostring(s.diff)) end
			addLog(string.format("[%d] %s [%s] Items: %s | Stats: %s",
				i, v.name, v.category or "?",
				#itemNames > 0 and table.concat(itemNames, ", ") or "none",
				#statNames > 0 and table.concat(statNames, ", ") or "none"
			), "vuln")
		end
	end

	isScanning = false
end

