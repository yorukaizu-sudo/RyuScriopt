-- DEEP SNAPSHOT & CHANGE DETECTION
-- ==========================================
local backpackBefore = {}
local characterBefore = {}
local leaderstatsBeefore = {}

local function deepSnapshot()
	backpackBefore = {}
	characterBefore = {}
	leaderstatsBeefore = {}

	for _, item in ipairs(backpack:GetChildren()) do
		backpackBefore[item.Name .. "_" .. item.ClassName] = true
	end

	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") or item:IsA("Accessory") then
				characterBefore[item.Name .. "_" .. item.ClassName] = true
			end
		end
	end

	local ls = player:FindFirstChild("leaderstats")
	if ls then
		for _, stat in ipairs(ls:GetChildren()) do
			pcall(function() leaderstatsBeefore[stat.Name] = stat.Value end)
		end
	end

	for _, child in ipairs(player:GetChildren()) do
		pcall(function()
			if child:IsA("Folder") or child:IsA("Configuration") then
				for _, val in ipairs(child:GetChildren()) do
					if val:IsA("ValueBase") then
						leaderstatsBeefore[child.Name .. "." .. val.Name] = val.Value
					end
				end
			end
		end)
	end
end

local function deepCheckChanges(remoteName)
	local changes = {
		newItems = {},
		newCharItems = {},
		statChanges = {},
		hasChanges = false
	}

	for _, item in ipairs(backpack:GetChildren()) do
		local key = item.Name .. "_" .. item.ClassName
		if not backpackBefore[key] then
			table.insert(changes.newItems, {name = item.Name, class = item.ClassName})
			changes.hasChanges = true
			totalItems = totalItems + 1
			table.insert(itemsObtained, {
				name = item.Name, className = item.ClassName,
				remote = remoteName, time = os.clock(), source = "backpack"
			})
		end
	end

	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if (item:IsA("Tool") or item:IsA("Accessory")) then
				local key = item.Name .. "_" .. item.ClassName
				if not characterBefore[key] then
					table.insert(changes.newCharItems, {name = item.Name, class = item.ClassName})
					changes.hasChanges = true
					totalItems = totalItems + 1
					table.insert(itemsObtained, {
						name = item.Name, className = item.ClassName,
						remote = remoteName, time = os.clock(), source = "character"
					})
				end
			end
		end
	end

	local ls = player:FindFirstChild("leaderstats")
	if ls then
		for _, stat in ipairs(ls:GetChildren()) do
			pcall(function()
				local oldVal = leaderstatsBeefore[stat.Name]
				if oldVal ~= nil and stat.Value ~= oldVal then
					table.insert(changes.statChanges, {
						name = stat.Name, oldValue = oldVal, newValue = stat.Value,
						diff = (type(stat.Value) == "number" and type(oldVal) == "number") and (stat.Value - oldVal) or "changed"
					})
					changes.hasChanges = true
				end
			end)
		end
	end

	for _, child in ipairs(player:GetChildren()) do
		pcall(function()
			if child:IsA("Folder") or child:IsA("Configuration") then
				for _, val in ipairs(child:GetChildren()) do
					if val:IsA("ValueBase") then
						local key = child.Name .. "." .. val.Name
						local oldVal = leaderstatsBeefore[key]
						if oldVal ~= nil and val.Value ~= oldVal then
							table.insert(changes.statChanges, {
								name = key, oldValue = oldVal, newValue = val.Value,
								diff = (type(val.Value) == "number" and type(oldVal) == "number") and (val.Value - oldVal) or "changed"
							})
							changes.hasChanges = true
						end
					end
				end
			end
		end)
	end

	return changes
end

