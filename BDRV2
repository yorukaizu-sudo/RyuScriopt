local function addLog(msg, logType)
	local entry = {
		time = os.clock(),
		message = msg,
		type = logType or "info"
	}
	table.insert(scanLog, entry)
	if #scanLog > 3000 then table.remove(scanLog, 1) end

	if logType == "success" then
		print("[✓] " .. msg)
	elseif logType == "vuln" then
		warn("[🔓] VULNERABLE: " .. msg)
	elseif logType == "exploit" then
		warn("[💀] EXPLOIT: " .. msg)
	elseif logType == "troll" then
		print("[🤡] TROLL: " .. msg)
	elseif logType == "farm" then
		print("[🌾] FARM: " .. msg)
	elseif logType == "error" then
		warn("[✗] " .. msg)
	elseif logType == "warning" then
		warn("[⚠] " .. msg)
	elseif logType == "critical" then
		warn("[🔴] " .. msg)
	elseif logType == "discovery" then
		print("[🔍] " .. msg)
	else
		print("[i] " .. msg)
	end
end

local function isValidInstance(obj)
	local ok, r = pcall(function() return obj and obj.Parent ~= nil and obj.Name end)
	return ok and r ~= nil
end

local function containsAnyKeyword(name, keywords)
	local nl = name:lower()
	local matches = {}
	for _, kw in ipairs(keywords) do
		if nl:find(kw:lower()) then
			table.insert(matches, kw)
		end
	end
	return #matches > 0, matches
end

local function getRemotePath(remote)
	local path = {}
	local current = remote
	local depth = 0
	while current and current ~= game and depth < 20 do
		table.insert(path, 1, current.Name)
		current = current.Parent
		depth = depth + 1
	end
	return table.concat(path, ".")
end

local function getRemoteDepth(remote)
	local depth = 0
	local current = remote
	while current and current ~= game do
		depth = depth + 1
		current = current.Parent
	end
	return depth
end

local function isObfuscatedName(name)
	if name:match("^[A-Za-z0-9+/]+=*$") and #name > 8 then return true, "base64" end
	if name:match("^[0-9a-fA-F]+$") and #name >= 8 then return true, "hex" end
	local vowels = 0
	for c in name:gmatch(".") do
		if c:lower():match("[aeiou]") then vowels = vowels + 1 end
	end
	if #name > 5 and vowels == 0 then return true, "no_vowels" end
	if #name <= 2 then return true, "short" end
	if name:match("^%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x$") then
		return true, "uuid"
	end
	if name:match("^%d+$") then return true, "numeric" end
	return false, nil
end

