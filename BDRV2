-- ==========================================
function collectAllRemotes()
	remoteEvents = {}
	remoteFunctions = {}
	bindableEvents = {}
	bindableFunctions = {}

	local seen = {}

	local function addRemote(remote)
		local id = tostring(remote)
		if seen[id] then return end
		seen[id] = true
		if remote:IsA("RemoteEvent") then table.insert(remoteEvents, remote)
		elseif remote:IsA("RemoteFunction") then table.insert(remoteFunctions, remote)
		elseif remote:IsA("BindableEvent") then table.insert(bindableEvents, remote)
		elseif remote:IsA("BindableFunction") then table.insert(bindableFunctions, remote) end
	end

	local function searchLocation(location)
		pcall(function()
			for _, desc in ipairs(location:GetDescendants()) do
				pcall(function()
					if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") or
					   desc:IsA("BindableEvent") or desc:IsA("BindableFunction") then
						addRemote(desc)
					end
				end)
			end
		end)
	end

	searchLocation(ReplicatedStorage)
	searchLocation(Workspace)
	searchLocation(Lighting)
	searchLocation(StarterGui)
	searchLocation(StarterPack)
	pcall(function() searchLocation(player.PlayerGui) end)
	pcall(function() searchLocation(player.PlayerScripts) end)
	pcall(function() searchLocation(player.Backpack) end)
	if player.Character then searchLocation(player.Character) end
	pcall(function() searchLocation(ReplicatedFirst) end)
	pcall(function() searchLocation(StarterPlayer) end)
	pcall(function() searchLocation(Chat) end)
	pcall(function() searchLocation(Teams) end)
	pcall(function() searchLocation(SoundService) end)

	if deepScanEnabled then
		for _, service in ipairs(game:GetChildren()) do
			pcall(function() searchLocation(service) end)
		end
	end

	if ultraDeepScan then
		pcall(function()
			if getinstances then
				for _, inst in ipairs(getinstances()) do
					pcall(function()
						if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
							addRemote(inst)
						end
					end)
				end
			end
		end)
		pcall(function()
			if getnilinstances then
				for _, inst in ipairs(getnilinstances()) do
					pcall(function()
						if inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction") then
							addRemote(inst)
							addLog("NIL remote: " .. inst.Name, "discovery")
						end
					end)
				end
			end
		end)
	end

	addLog(string.format("Found: %d RE, %d RF, %d BE, %d BF",
		#remoteEvents, #remoteFunctions, #bindableEvents, #bindableFunctions), "info")
end

-- ==========================================
-- REMOTE ANALYSIS
-- ==========================================
local function analyzeRemote(remote)
	local info = {
		name = remote.Name,
		path = getRemotePath(remote),
		className = remote.ClassName,
		isGiveRelated = false,
		isItemRelated = false,
		isAdminRelated = false,
		isDangerous = false,
		isBackpackRelated = false,
		isCurrencyRelated = false,
		isFarmable = false,
		isTrollable = false,
		isObfuscated = false,
		obfuscationType = nil,
		priority = 0,
		keywords = {},
		vulnerable = false,
		depth = getRemoteDepth(remote),
		category = "unknown",
	}

	local name = remote.Name
	local pathStr = getRemotePath(remote):lower()

	local function checkAndSet(keywords, field, boost)
		local found, kws = containsAnyKeyword(name, keywords)
		if found then
			info[field] = true
			info.priority = info.priority + boost
			for _, kw in ipairs(kws) do table.insert(info.keywords, kw) end
		end
		-- Also check path
		local foundP, kwsP = containsAnyKeyword(pathStr, keywords)
		if foundP and not found then
			info[field] = true
			info.priority = info.priority + (boost - 1)
		end
	end

	checkAndSet(giveKeywords, "isGiveRelated", 3)
	checkAndSet(itemKeywords, "isItemRelated", 2)
	checkAndSet(adminKeywords, "isAdminRelated", 5)
	checkAndSet(dangerKeywords, "isDangerous", -10)
	checkAndSet(backpackKeywords, "isBackpackRelated", 2)
	checkAndSet(currencyKeywords, "isCurrencyRelated", 3)
	checkAndSet(farmKeywords, "isFarmable", 4)
	checkAndSet(trollKeywords, "isTrollable", 2)

	local isObf, obfType = isObfuscatedName(name)
	if isObf then
		info.isObfuscated = true
		info.obfuscationType = obfType
		info.priority = info.priority + 4
	end

	if info.depth > 5 then info.priority = info.priority + 2 end

	-- Categorize
	if info.isAdminRelated then info.category = "admin"
	elseif info.isCurrencyRelated then info.category = "currency"
	elseif info.isFarmable then info.category = "farmable"
	elseif info.isGiveRelated then info.category = "give"
	elseif info.isItemRelated then info.category = "item"
	elseif info.isTrollable then info.category = "troll"
	elseif info.isObfuscated then info.category = "hidden"
	end

	return info
end

