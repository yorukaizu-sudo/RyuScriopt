local gameFingerprint = {
	placeId = 0,
	gameName = "",
	gameType = "unknown",
	detectedPatterns = {},
	remoteNaming = "unknown",
	securityLevel = "unknown",
	hasAntiCheat = false,
	farmableRemotes = {},
	trollableRemotes = {},
	exploitablePoints = {},
}

local function fingerprintGame()
	gameFingerprint.placeId = game.PlaceId
	pcall(function()
		gameFingerprint.gameName = MarketplaceService:GetProductInfo(game.PlaceId).Name
	end)

	local allNames = {}
	pcall(function()
		for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
			table.insert(allNames, desc.Name:lower())
		end
		for _, desc in ipairs(Workspace:GetDescendants()) do
			table.insert(allNames, desc.Name:lower())
		end
	end)

	local allNamesStr = table.concat(allNames, " ")

	for gameType, keywords in pairs(gamePatterns) do
		local matchCount = 0
		for _, kw in ipairs(keywords) do
			if allNamesStr:find(kw) then matchCount = matchCount + 1 end
		end
		if matchCount >= 3 then
			table.insert(gameFingerprint.detectedPatterns, {type = gameType, matches = matchCount})
		end
	end

	table.sort(gameFingerprint.detectedPatterns, function(a, b) return a.matches > b.matches end)
	if #gameFingerprint.detectedPatterns > 0 then
		gameFingerprint.gameType = gameFingerprint.detectedPatterns[1].type
	end

	collectAllRemotes()
	local obfCount, normalCount = 0, 0
	for _, re in ipairs(remoteEvents) do
		if isValidInstance(re) then
			if isObfuscatedName(re.Name) then obfCount = obfCount + 1
			else normalCount = normalCount + 1 end
		end
	end

	if obfCount > normalCount then gameFingerprint.remoteNaming = "obfuscated"
	elseif obfCount > 0 then gameFingerprint.remoteNaming = "mixed"
	else gameFingerprint.remoteNaming = "standard" end

	local acKeywords = {"anticheat","anti_cheat","ac_","security","validation","integrity","protection","guardian","sentinel","watchdog","shield"}
	for _, name in ipairs(allNames) do
		for _, kw in ipairs(acKeywords) do
			if name:find(kw) then
				gameFingerprint.hasAntiCheat = true
				break
			end
		end
		if gameFingerprint.hasAntiCheat then break end
	end

	if gameFingerprint.hasAntiCheat and gameFingerprint.remoteNaming == "obfuscated" then
		gameFingerprint.securityLevel = "high"
	elseif gameFingerprint.hasAntiCheat or gameFingerprint.remoteNaming == "obfuscated" then
		gameFingerprint.securityLevel = "medium"
	else
		gameFingerprint.securityLevel = "low"
	end

	addLog(string.format("🎮 Game: %s | Type: %s | Security: %s | AntiCheat: %s",
		gameFingerprint.gameName, gameFingerprint.gameType,
		gameFingerprint.securityLevel, tostring(gameFingerprint.hasAntiCheat)), "info")

	return gameFingerprint
end

