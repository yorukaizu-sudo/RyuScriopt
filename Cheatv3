-- ==========================================
local function cleanHitboxForPlayer(p)
	local dd = hitboxData[p]
	if not dd then return end
	if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
	if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
	if dd.deathConnection then pcall(function() dd.deathConnection:Disconnect() end) end
	if p.Character then
		local hrp = p.Character:FindFirstChild("HumanoidRootPart")
		if hrp then hrp.CanQuery = true end
	end
	dd.overlayPart = nil dd.espVisual = nil dd.trackedChar = nil dd.deathConnection = nil
end

local function createHitboxOverlay(p)
	if not p.Character then return end
	local hrp = p.Character:FindFirstChild("HumanoidRootPart")
	local hum = p.Character:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum or hum.Health <= 0 then return end
	if not hitboxData[p] then hitboxData[p] = {} end
	local dd = hitboxData[p]
	if dd.overlayPart and dd.overlayPart.Parent then pcall(function() dd.overlayPart:Destroy() end) end
	if dd.espVisual and dd.espVisual.Parent then pcall(function() dd.espVisual:Destroy() end) end
	local overlay = Instance.new("Part")
	overlay.Name = "HitboxOverlay"
	overlay.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
	overlay.Transparency = hitboxTransparency
	overlay.CanCollide = false overlay.CanQuery = true overlay.Anchored = false
	overlay.Massless = true overlay.Material = Enum.Material.ForceField
	overlay.Color = hitboxESPColor overlay.Parent = p.Character
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = hrp weld.Part1 = overlay weld.Parent = overlay
	overlay.CFrame = hrp.CFrame
	hrp.CanQuery = false
	dd.overlayPart = overlay dd.trackedChar = p.Character
	dd.deathConnection = hum.Died:Connect(function() task.wait(0.5) cleanHitboxForPlayer(p) end)
end

local function updateHitboxExpander()
	if not hitboxEnabled then return end
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.Health > 0 then
				if not hitboxData[p] then hitboxData[p] = {} end
				local dd = hitboxData[p]
				local needsCreate = not dd.overlayPart or not dd.overlayPart.Parent or dd.trackedChar ~= p.Character
				if needsCreate then
					if dd.deathConnection then pcall(function() dd.deathConnection:Disconnect() end) end
					createHitboxOverlay(p)
				else
					dd.overlayPart.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
					dd.overlayPart.Transparency = hitboxTransparency
					dd.overlayPart.Color = hitboxESPColor
					if hrp.CanQuery then hrp.CanQuery = false end
				end
				if hitboxESPEnabled and dd.overlayPart and dd.overlayPart.Parent then
					if not dd.espVisual or not dd.espVisual.Parent then
						local box = Instance.new("BoxHandleAdornment")
						box.Adornee = dd.overlayPart box.Size = dd.overlayPart.Size
						box.Color3 = hitboxESPColor box.Transparency = 0.5
						box.AlwaysOnTop = true box.ZIndex = 10 box.Parent = dd.overlayPart
						dd.espVisual = box
					else dd.espVisual.Size = dd.overlayPart.Size dd.espVisual.Color3 = hitboxESPColor end
				elseif dd.espVisual then pcall(function() dd.espVisual:Destroy() end) dd.espVisual = nil end
			else
				if hitboxData[p] and hitboxData[p].overlayPart then cleanHitboxForPlayer(p) end
			end
		end
	end
	for p, dd in pairs(hitboxData) do
		if not p.Parent then cleanHitboxForPlayer(p) hitboxData[p] = nil end
	end
end

local function disableHitboxExpander()
	for p, dd in pairs(hitboxData) do
		if dd.deathConnection then pcall(function() dd.deathConnection:Disconnect() end) end
		cleanHitboxForPlayer(p)
	end
	hitboxData = {}
end

