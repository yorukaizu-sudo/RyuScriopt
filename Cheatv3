local function updateAntiHitbox()
	if not antiHitboxEnabled then return end
	local mc = player.Character
	if not mc or not mc:FindFirstChild("HumanoidRootPart") then return end
	local parts = {"Head", "Torso", "UpperTorso", "LowerTorso", "LeftArm", "RightArm", "LeftLeg", "RightLeg", "Left Arm", "Right Arm", "Left Leg", "Right Leg", "HumanoidRootPart"}
	for _, pn in ipairs(parts) do
		local part = mc:FindFirstChild(pn)
		if part and part:IsA("BasePart") then
			if not antiHitboxParts[pn] then antiHitboxParts[pn] = {} end
			local d = antiHitboxParts[pn]
			if not d.fakePart or not d.fakePart.Parent then
				local fp = Instance.new("Part")
				fp.Name = "AH_" .. pn fp.Size = Vector3.new(antiHitboxSize, antiHitboxSize, antiHitboxSize)
				fp.Transparency = 1 fp.CanCollide = false fp.CanQuery = true
				fp.Anchored = false fp.Massless = true fp.Parent = mc
				local w = Instance.new("WeldConstraint") w.Part0 = part w.Part1 = fp w.Parent = fp
				fp.CFrame = part.CFrame d.fakePart = fp
			else d.fakePart.Size = Vector3.new(antiHitboxSize, antiHitboxSize, antiHitboxSize) end
			part.CanQuery = false
			if antiHitboxESPEnabled and d.fakePart then
				if not d.visual or not d.visual.Parent then
					local b = Instance.new("BoxHandleAdornment")
					b.Adornee = d.fakePart b.Size = d.fakePart.Size b.Color3 = antiHitboxESPColor
					b.Transparency = 0.3 b.AlwaysOnTop = true b.ZIndex = 10 b.Parent = d.fakePart
					d.visual = b
				else d.visual.Size = d.fakePart.Size d.visual.Color3 = antiHitboxESPColor end
			elseif d.visual then pcall(function() d.visual:Destroy() end) d.visual = nil end
		end
	end
end

