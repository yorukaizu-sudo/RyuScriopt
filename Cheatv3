local function isTeammate(p)
	if not p then return false end
	if p.Team and player.Team and p.Team == player.Team then return true end
	return false
end

local function getEquippedTool()
	local char = player.Character
	if not char then return nil end
	for _, i in ipairs(char:GetChildren()) do if i:IsA("Tool") then return i end end
	return nil
end

local function canSeeTarget(fromPos, targetPart)
	if not silentAimVisibleCheck then return true end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local direction = (targetPart.Position - fromPos).Unit * (targetPart.Position - fromPos).Magnitude
	local result = workspace:Raycast(fromPos, direction, params)
	if result then
		local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
		local targetModel = targetPart:FindFirstAncestorOfClass("Model")
		if hitModel and targetModel and hitModel == targetModel then return true end
		if result.Instance:IsDescendantOf(targetPart.Parent) then return true end
	end
	return result == nil
end

local function getSilentAimTargetPart(char)
	if silentAimAutoHeadshot then
		local chance = math.random(1, 100)
		if chance <= silentAimHeadshotChance then
			local head = char:FindFirstChild("Head")
			if head then return head end
		end
	end
	
	if silentAimPart == "Head" then
		return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	elseif silentAimPart == "Body" then
		return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
	elseif silentAimPart == "Random" then
		local parts = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso", "LeftArm", "RightArm", "Left Arm", "Right Arm"}
		local valid = {}
		for _, pn in ipairs(parts) do
			local p = char:FindFirstChild(pn)
			if p then table.insert(valid, p) end
		end
		if #valid > 0 then return valid[math.random(1, #valid)] end
	elseif silentAimPart == "Nearest to Cursor" then
		local vpSize = camera.ViewportSize
		local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
		local closestPart, closestDist = nil, math.huge
		local parts = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso"}
		for _, pn in ipairs(parts) do
			local p = char:FindFirstChild(pn)
			if p then
				local sp, onScreen = camera:WorldToViewportPoint(p.Position)
				if onScreen then
					local sd = (Vector2.new(sp.X, sp.Y) - centerScreen).Magnitude
					if sd < closestDist then closestDist = sd closestPart = p end
				end
			end
		end
		return closestPart or char:FindFirstChild("HumanoidRootPart")
	elseif silentAimPart == "Aim Assist Sync" then
		-- Sync dengan aim assist target
		if aimAssistCurrentTarget and aimAssistCurrentTarget.Character == char then
			if aimAssistLastChosenPart then
				local p = char:FindFirstChild(aimAssistLastChosenPart)
				if p then return p end
			end
		end
		return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
	end
	
	return char:FindFirstChild(silentAimPart) or char:FindFirstChild("HumanoidRootPart")
end

local function getSilentAimTarget()
	local myChar = player.Character
	local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHrp then return nil, nil end
	
	local vpSize = camera.ViewportSize
	local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
	local closest, closestDist, closestPart = nil, math.huge, nil
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				if silentAimTeamCheck and isTeammate(p) then continue end
				local dist3D = (myHrp.Position - hrp.Position).Magnitude
				if dist3D > silentAimDistance then continue end
				
				local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local sd = (Vector2.new(sp.X, sp.Y) - centerScreen).Magnitude
					if sd <= silentAimFOV and sd < closestDist then
						-- Visibility check
						if canSeeTarget(myHrp.Position, hrp) then
							closestDist = sd
							closest = p
						end
					end
				end
			end
		end
	end
	
	if closest and closest.Character then
		local targetPart = getSilentAimTargetPart(closest.Character)
		return closest, targetPart
	end
	
	return nil, nil
end

local function getPredictedPosition(targetPart, char)
	if not silentAimPrediction then return targetPart.Position end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return targetPart.Position end
	local vel = hrp.AssemblyLinearVelocity
	return targetPart.Position + Vector3.new(vel.X, 0, vel.Z) * silentAimPredictionAmount
end

-- Hook untuk Silent Aim - Redirect peluru ke target
local function hookSilentAim()
	if silentAimHooked then return end
	silentAimHooked = true
	
	-- Method 1: Hook mouse.Hit dan mouse.Target
	pcall(function()
		local mt = getrawmetatable(game)
		if not mt then return end
		local oldIdx = mt.__index
		local oldNewIdx = mt.__newindex
		setreadonly(mt, false)
		
		mt.__index = newcclosure(function(self, key)
			if silentAimEnabled and silentAimCurrentTarget then
				-- Hook mouse.Hit
				if self == mouse and (key == "Hit" or key == "hit") then
					local target, targetPart = getSilentAimTarget()
					if target and targetPart then
						silentAimCurrentTarget = target
						local pos = getPredictedPosition(targetPart, target.Character)
						return CFrame.new(pos)
					end
				end
				
				-- Hook mouse.Target
				if self == mouse and (key == "Target" or key == "target") then
					local target, targetPart = getSilentAimTarget()
					if target and targetPart then
						return targetPart
					end
				end
				
				-- Hook mouse.UnitRay
				if self == mouse and (key == "UnitRay" or key == "unitray") then
					local target, targetPart = getSilentAimTarget()
					if target and targetPart then
						local pos = getPredictedPosition(targetPart, target.Character)
						local origin = camera.CFrame.Position
						return Ray.new(origin, (pos - origin).Unit)
					end
				end
			end
			
			-- Hitbox size masking
			if key == "Size" and typeof(self) == "Instance" and self:IsA("BasePart") and self.Name == "HitboxOverlay" then
				return Vector3.new(2, 2, 1)
			end
			
			return oldIdx(self, key)
		end)
		
		setreadonly(mt, true)
	end)
	
	-- Method 2: Hook Raycast untuk bullet trajectory
	pcall(function()
		local oldRaycast = workspace.Raycast
		local hf = hookfunction or replaceclosure
		if not hf then return end
		
		hf(workspace.Raycast, newcclosure(function(self, origin, direction, rayParams, ...)
			if not silentAimEnabled then return oldRaycast(self, origin, direction, rayParams, ...) end
			
			-- Check if this is a bullet raycast (from our character's position area)
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if myHrp then
				local distFromPlayer = (origin - myHrp.Position).Magnitude
				if distFromPlayer < 15 then -- Raycast from near player = likely a bullet
					local target, targetPart = getSilentAimTarget()
					if target and targetPart then
						-- Hit chance check
						if math.random(1, 100) <= silentAimHitChance then
							local targetPos = getPredictedPosition(targetPart, target.Character)
							local newDirection = (targetPos - origin).Unit * direction.Magnitude
							return oldRaycast(self, origin, newDirection, rayParams, ...)
						end
					end
				end
			end
			
			return oldRaycast(self, origin, direction, rayParams, ...)
		end))
	end)
	
	-- Method 3: Hook FindPartOnRay (deprecated but some games still use)
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFindPart = workspace.FindPartOnRay
		hf(workspace.FindPartOnRay, newcclosure(function(self, ray, ignoreList, ...)
			if not silentAimEnabled then return oldFindPart(self, ray, ignoreList, ...) end
			
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if myHrp then
				local distFromPlayer = (ray.Origin - myHrp.Position).Magnitude
				if distFromPlayer < 15 then
					local target, targetPart = getSilentAimTarget()
					if target and targetPart then
						if math.random(1, 100) <= silentAimHitChance then
							local targetPos = getPredictedPosition(targetPart, target.Character)
							local newRay = Ray.new(ray.Origin, (targetPos - ray.Origin).Unit * ray.Direction.Magnitude)
							return oldFindPart(self, newRay, ignoreList, ...)
						end
					end
				end
			end
			
			return oldFindPart(self, ray, ignoreList, ...)
		end))
	end)
	
	-- Method 4: Hook FindPartOnRayWithIgnoreList
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFindPart2 = workspace.FindPartOnRayWithIgnoreList
		if oldFindPart2 then
			hf(workspace.FindPartOnRayWithIgnoreList, newcclosure(function(self, ray, ignoreList, ...)
				if not silentAimEnabled then return oldFindPart2(self, ray, ignoreList, ...) end
				
				local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
				if myHrp then
					local distFromPlayer = (ray.Origin - myHrp.Position).Magnitude
					if distFromPlayer < 15 then
						local target, targetPart = getSilentAimTarget()
						if target and targetPart then
							if math.random(1, 100) <= silentAimHitChance then
								local targetPos = getPredictedPosition(targetPart, target.Character)
								local newRay = Ray.new(ray.Origin, (targetPos - ray.Origin).Unit * ray.Direction.Magnitude)
								return oldFindPart2(self, newRay, ignoreList, ...)
							end
						end
					end
				end
				
				return oldFindPart2(self, ray, ignoreList, ...)
			end))
		end
	end)
end

-- Hook Bullet Redirect via Remotes
local function hookBulletRedirect()
	if bulletRedirectHooked then return end
	bulletRedirectHooked = true
	
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (silentAimEnabled or bulletRedirectEnabled) then return oldFS(self, ...) end
			
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			
			-- Check if this is a shooting/firing remote
			local isShootRemote = name:find("fire") or name:find("shoot") or name:find("attack") or 
				name:find("bullet") or name:find("weapon") or name:find("gun") or 
				name:find("hit") or name:find("damage") or name:find("ray") or
				name:find("cast") or name:find("projectile")
			
			if not isShootRemote then return oldFS(self, ...) end
			
			local target, targetPart = getSilentAimTarget()
			if not target or not targetPart then return oldFS(self, ...) end
			
			-- Hit chance
			if math.random(1, 100) > silentAimHitChance then return oldFS(self, ...) end
			
			local targetPos = getPredictedPosition(targetPart, target.Character)
			local args = {...}
			
			-- Replace position/direction arguments
			for i, arg in ipairs(args) do
				if typeof(arg) == "Vector3" then
					-- Could be position or direction
					local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
					if myHrp then
						local distToPlayer = (arg - myHrp.Position).Magnitude
						if distToPlayer < 5 then
							-- This is likely the origin position, keep it
						else
							-- This is likely direction or target position
							local camLook = camera.CFrame.LookVector
							local dotProduct = arg.Unit:Dot(camLook)
							if dotProduct > 0.5 then
								-- Direction vector - redirect to target
								args[i] = (targetPos - camera.CFrame.Position).Unit * arg.Magnitude
							else
								-- Position vector - replace with target position
								args[i] = targetPos
							end
						end
					end
				elseif typeof(arg) == "CFrame" then
					args[i] = CFrame.new(arg.Position, targetPos)
				elseif typeof(arg) == "Ray" then
					args[i] = Ray.new(arg.Origin, (targetPos - arg.Origin).Unit * arg.Direction.Magnitude)
				elseif typeof(arg) == "Instance" and arg:IsA("BasePart") then
					-- Replace hit part with target part
					args[i] = targetPart
				elseif typeof(arg) == "table" then
					-- Deep scan table for position/direction data
					for k, v in pairs(arg) do
						if typeof(v) == "Vector3" then
							local kl = typeof(k) == "string" and k:lower() or ""
							if kl:find("pos") or kl:find("hit") or kl:find("target") or kl:find("point") or kl:find("end") then
								arg[k] = targetPos
							elseif kl:find("dir") or kl:find("look") or kl:find("aim") then
								arg[k] = (targetPos - camera.CFrame.Position).Unit
							end
						elseif typeof(v) == "CFrame" then
							local kl = typeof(k) == "string" and k:lower() or ""
							if kl:find("aim") or kl:find("look") or kl:find("camera") then
								arg[k] = CFrame.new(v.Position, targetPos)
							end
						elseif typeof(v) == "Instance" and v:IsA("BasePart") then
							local kl = typeof(k) == "string" and k:lower() or ""
							if kl:find("hit") or kl:find("target") or kl:find("part") then
								arg[k] = targetPart
							end
						end
					end
				end
			end
			
			return oldFS(self, unpack(args))
		end))
	end)
	
	-- Hook RemoteFunction:InvokeServer
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		
		local oldIS
		oldIS = hf(Instance.new("RemoteFunction").InvokeServer, newcclosure(function(self, ...)
			if not (silentAimEnabled or bulletRedirectEnabled) then return oldIS(self, ...) end
			
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldIS(self, ...) end
			
			local isShootRemote = name:find("fire") or name:find("shoot") or name:find("attack") or 
				name:find("bullet") or name:find("hit") or name:find("damage") or name:find("ray")
			
			if not isShootRemote then return oldIS(self, ...) end
			
			local target, targetPart = getSilentAimTarget()
			if not target or not targetPart then return oldIS(self, ...) end
			if math.random(1, 100) > silentAimHitChance then return oldIS(self, ...) end
			
			local targetPos = getPredictedPosition(targetPart, target.Character)
			local args = {...}
			
			for i, arg in ipairs(args) do
				if typeof(arg) == "Vector3" then
					local camLook = camera.CFrame.LookVector
					if arg.Unit:Dot(camLook) > 0.5 then
						args[i] = (targetPos - camera.CFrame.Position).Unit * arg.Magnitude
					end
				elseif typeof(arg) == "CFrame" then
					args[i] = CFrame.new(arg.Position, targetPos)
				elseif typeof(arg) == "Instance" and arg:IsA("BasePart") then
					args[i] = targetPart
				end
			end
			
			return oldIS(self, unpack(args))
		end))
	end)
end

