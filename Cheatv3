local function updateVehicleCache()
	local now = tick()
	if now - lastVehicleCacheUpdate < VEHICLE_CACHE_RATE then return cachedVehicles end
	lastVehicleCacheUpdate = now
	cachedVehicles = {}
	local added = {}
	for _, v in ipairs(workspace:GetDescendants()) do
		if v:IsA("VehicleSeat") then
			local m = v:FindFirstAncestorOfClass("Model")
			if m and not added[m] then added[m] = true table.insert(cachedVehicles, {Name = m.Name, Model = m, Seat = v}) end
		end
	end
	return cachedVehicles
end
