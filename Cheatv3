local function fixAllNoRecoil()
	-- 1. Clear old overrides
	noRecoilOverriddenObjects = {}
	
	-- 2. Re-scan equipped tool
	local tool = getEquippedTool()
	if tool then scanEquippedTool(tool) end
	
	-- 3. Deep scan modules
	deepScanModules()
	
	-- 4. Override physics
	overrideRecoilPhysics()
	
	-- 5. Re-hook remotes if needed
	if noRecoilRemoteIntercept and not noRecoilHooked then hookNoRecoilRemotes() end
	
	-- 6. Scan all tools in backpack too (for pre-load)
	local bp = player:FindFirstChild("Backpack")
	if bp then
		for _, item in ipairs(bp:GetChildren()) do
			if item:IsA("Tool") then
				for _, desc in ipairs(item:GetDescendants()) do
					if desc:IsA("ModuleScript") then
						local n = desc.Name:lower()
						if n:find("recoil") or n:find("spread") or n:find("weapon") or n:find("config") then
							pcall(function()
								local data = require(desc)
								if typeof(data) == "table" then overrideTableRecoil(data) end
							end)
						end
					end
				end
			end
		end
	end
	
	-- 7. Scan workspace for any recoil-related scripts
	pcall(function()
		for _, desc in ipairs(workspace:GetDescendants()) do
			if desc:IsA("ModuleScript") then
				local n = desc.Name:lower()
				if n:find("recoil") or n:find("spread") then
					pcall(function()
						local data = require(desc)
						if typeof(data) == "table" then overrideTableRecoil(data) end
					end)
				end
			end
		end
	end)
end

