-- AIM ASSIST
-- ==========================================
local function getAimAssistTargetPart(char)
	local now = tick()
	if aimAssistLastChosenPart and char:FindFirstChild(aimAssistLastChosenPart) then
		if now - aimAssistLastPartSwitch < aimAssistPartSwitchRate then
			return char:FindFirstChild(aimAssistLastChosenPart)
		end
	end
	aimAssistLastPartSwitch = now
	local partName = "HumanoidRootPart"
	if aimAssistTargetPart == "Dynamic" then
		if math.random(1, 100) <= aimAssistHeadshotRate then partName = "Head"
		else for _, name in ipairs({"HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso"}) do
			if char:FindFirstChild(name) then partName = name break end end end
	elseif aimAssistTargetPart == "Head" then partName = "Head"
	elseif aimAssistTargetPart == "Body" then
		for _, name in ipairs({"HumanoidRootPart", "UpperTorso", "Torso"}) do
			if char:FindFirstChild(name) then partName = name break end end
	end
	aimAssistLastChosenPart = partName
	return char:FindFirstChild(partName) or char:FindFirstChild("HumanoidRootPart")
end

local function getAimAssistTarget()
	local myChar = player.Character
	local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myHrp then return nil, math.huge end
	local vpSize = camera.ViewportSize
	local centerScreen = Vector2.new(vpSize.X / 2, vpSize.Y / 2)
	local closest, closestDist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hum = p.Character:FindFirstChildOfClass("Humanoid")
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			if hum and hrp and hum.Health > 0 then
				if aimAssistTeamCheck and isTeammate(p) then continue end
				if (myHrp.Position - hrp.Position).Magnitude > aimAssistDistance then continue end
				local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local sd = (Vector2.new(sp.X, sp.Y) - centerScreen).Magnitude
					if sd <= aimAssistFOV and sd < closestDist then closestDist = sd closest = p end
				end
			end
		end
	end
	return closest, closestDist
end

local function isAimAssistTargetValid(p)
	if not p or not p.Parent or not p.Character then return false end
	local hum = p.Character:FindFirstChildOfClass("Humanoid")
	local hrp = p.Character:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp or hum.Health <= 0 then return false end
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myHrp then return false end
	if (myHrp.Position - hrp.Position).Magnitude > aimAssistDistance then return false end
	local _, onScreen = camera:WorldToViewportPoint(hrp.Position)
	return onScreen
end

local function applyAimAssist(dt)
	if not aimAssistEnabled then return end
	local myChar = player.Character
	if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
	if aimAssistOnlyWhileAiming then
		local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
		if not isAiming then
			aimAssistStickyTarget = nil aimAssistCurrentTarget = nil aimAssistFirstLock = false return
		end
	end
	local now = tick()
	local target = nil
	if aimAssistStickyAim and aimAssistStickyTarget then
		if isAimAssistTargetValid(aimAssistStickyTarget) then
			local hrp = aimAssistStickyTarget.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
				if onScreen then
					local sd = (Vector2.new(sp.X, sp.Y) - Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)).Magnitude
					if sd <= aimAssistFOV * 1.8 then target = aimAssistStickyTarget end
				end
			end
		end
		if not target and now - lastStickyTime < aimAssistReattachDelay then return end
	end
	if not target then
		target = getAimAssistTarget()
		if target then aimAssistFirstLock = true aimAssistLastTargetSwitch = now end
	end
	if not target or not target.Character then
		aimAssistCurrentTarget = nil aimAssistStickyTarget = nil aimAssistFirstLock = false return
	end
	local isNewTarget = (aimAssistStickyTarget ~= target)
	aimAssistStickyTarget = target aimAssistCurrentTarget = target lastStickyTime = now
	local targetPart = getAimAssistTargetPart(target.Character)
	if not targetPart then return end
	local targetPos = targetPart.Position
	if aimAssistPrediction then
		local hrp = target.Character:FindFirstChild("HumanoidRootPart")
		if hrp then local vel = hrp.AssemblyLinearVelocity targetPos = targetPos + Vector3.new(vel.X, 0, vel.Z) * aimAssistPredictionAmount end
	end
	local tsp, onScreen = camera:WorldToViewportPoint(targetPos)
	if not onScreen then return end
	local centerScreen = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
	local offset = Vector2.new(tsp.X, tsp.Y) - centerScreen
	local offsetMag = offset.Magnitude
	if offsetMag <= aimAssistInnerDeadzone then
		camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetPos), 0.95) return
	end
	local magnetStrength
	if offsetMag <= aimAssistSlowdownZone then
		local zf = 1 - (offsetMag / aimAssistSlowdownZone)
		magnetStrength = aimAssistStrength * (0.6 + zf * 0.4) + aimAssistMagnetism * zf * 0.5
	else
		local ff = 1 - math.clamp((offsetMag - aimAssistSlowdownZone) / (aimAssistFOV - aimAssistSlowdownZone), 0, 1)
		magnetStrength = aimAssistStrength * (0.2 + ff * 0.4)
	end
	if aimAssistFirstLock and isNewTarget then magnetStrength = math.min(magnetStrength + aimAssistSnapStrength * 0.3, 1) aimAssistFirstLock = false end
	local trackSpeed = aimAssistTrackingSmooth
	if aimAssistSmoothing and offsetMag < 30 then trackSpeed = trackSpeed * 0.5 end
	magnetStrength = math.clamp(magnetStrength, 0.01, 0.95)
	local finalLerp = math.clamp(magnetStrength * (1 - trackSpeed) + trackSpeed, 0.02, 0.9)
	camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetPos), finalLerp)
end

