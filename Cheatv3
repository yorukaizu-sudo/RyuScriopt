local function updateSilentAimVisuals()
	if not silentAimEnabled then
		if silentAimVisualLineObj then silentAimVisualLineObj.Visible = false end
		return
	end
	
	-- Update target for display
	local target, targetPart = getSilentAimTarget()
	silentAimCurrentTarget = target
	
	-- Visual line
	if silentAimVisualLine and target and targetPart then
		local sp, onScreen = camera:WorldToViewportPoint(targetPart.Position)
		if onScreen then
			local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
			silentAimVisualLineObj.From = center
			silentAimVisualLineObj.To = Vector2.new(sp.X, sp.Y)
			silentAimVisualLineObj.Visible = true
			
			-- Change color based on headshot
			if targetPart.Name == "Head" then
				silentAimVisualLineObj.Color = Color3.fromRGB(255, 50, 50) -- Red = headshot
			else
				silentAimVisualLineObj.Color = Color3.fromRGB(255, 0, 255) -- Purple = body
			end
		else
			silentAimVisualLineObj.Visible = false
		end
	elseif silentAimVisualLineObj then
		silentAimVisualLineObj.Visible = false
	end
	
	-- Notify target change
	if silentAimNotifyTarget and target then
		-- Only notify on new target
	end
end

