local function containsKeyword(name, keywords)
	local nameLower = name:lower()
	for _, kw in ipairs(keywords) do
		if nameLower:find(kw:lower()) then return true end
	end
	return false
end

local function isValidInstance(obj)
	local ok, result = pcall(function() return obj and obj.Parent ~= nil end)
	return ok and result
end

local function overrideSingleValue(obj, isSpread)
	if not isValidInstance(obj) then return end
	if not obj:IsA("ValueBase") then return end
	local key = tostring(obj)
	if noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj.Value end)
	if not ok then return end
	if typeof(val) ~= "number" then return end
	local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
	local newVal = val * (1 - reduction)
	noRecoilOverriddenObjects[key] = {obj = obj, originalValue = val, type = "value"}
	pcall(function() obj.Value = newVal end)
end

local function overrideSingleAttribute(obj, attrName, isSpread)
	if not isValidInstance(obj) then return end
	local key = tostring(obj) .. "_attr_" .. attrName
	if noRecoilOverriddenObjects[key] then return end
	local ok, val = pcall(function() return obj:GetAttribute(attrName) end)
	if not ok or typeof(val) ~= "number" then return end
	local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
	noRecoilOverriddenObjects[key] = {obj = obj, attrName = attrName, originalValue = val, type = "attribute"}
	pcall(function() obj:SetAttribute(attrName, val * (1 - reduction)) end)
end

local function overrideTableRecoil(tbl, depth)
	depth = depth or 0
	if depth > 4 then return end
	if typeof(tbl) ~= "table" then return end
	for key, val in pairs(tbl) do
		if typeof(key) == "string" then
			local keyLower = key:lower()
			if noRecoilEnabled and typeof(val) == "number" then
				for _, kw in ipairs(recoilKeywords) do
					if keyLower:find(kw) then tbl[key] = val * (1 - noRecoilStrength / 100) break end
				end
			end
			if noSpreadEnabled and typeof(val) == "number" then
				for _, kw in ipairs(spreadKeywords) do
					if keyLower:find(kw) then tbl[key] = val * (1 - noSpreadStrength / 100) break end
				end
			end
			if typeof(val) == "table" then overrideTableRecoil(val, depth + 1) end
		end
	end
end

local function scanEquippedTool(tool)
	if not tool or not isValidInstance(tool) then return end
	if not tool:IsA("Tool") then return end
	local char = player.Character
	if not char then return end
	if tool.Parent ~= char then return end
	noRecoilCurrentTool = tool
	for _, descendant in ipairs(tool:GetDescendants()) do
		if not isValidInstance(descendant) then continue end
		if descendant:IsA("ValueBase") then
			local name = descendant.Name
			if noRecoilEnabled and containsKeyword(name, recoilKeywords) then overrideSingleValue(descendant, false) end
			if noSpreadEnabled and containsKeyword(name, spreadKeywords) then overrideSingleValue(descendant, true) end
		end
		if descendant:IsA("Configuration") or descendant:IsA("Folder") then
			for _, child in ipairs(descendant:GetChildren()) do
				if child:IsA("ValueBase") then
					if noRecoilEnabled and containsKeyword(child.Name, recoilKeywords) then overrideSingleValue(child, false) end
					if noSpreadEnabled and containsKeyword(child.Name, spreadKeywords) then overrideSingleValue(child, true) end
				end
			end
		end
		pcall(function()
			local attrs = descendant:GetAttributes()
			for attrName, attrVal in pairs(attrs) do
				if typeof(attrVal) == "number" then
					if noRecoilEnabled and containsKeyword(attrName, recoilKeywords) then overrideSingleAttribute(descendant, attrName, false) end
					if noSpreadEnabled and containsKeyword(attrName, spreadKeywords) then overrideSingleAttribute(descendant, attrName, true) end
				end
			end
		end)
	end
	pcall(function()
		local attrs = tool:GetAttributes()
		for attrName, attrVal in pairs(attrs) do
			if typeof(attrVal) == "number" then
				if noRecoilEnabled and containsKeyword(attrName, recoilKeywords) then overrideSingleAttribute(tool, attrName, false) end
				if noSpreadEnabled and containsKeyword(attrName, spreadKeywords) then overrideSingleAttribute(tool, attrName, true) end
			end
		end
	end)
	for _, desc in ipairs(tool:GetDescendants()) do
		if desc:IsA("ModuleScript") then
			local name = desc.Name:lower()
			if name:find("recoil") or name:find("spread") or name:find("config") or name:find("stat") or name:find("setting") or name:find("weapon") or name:find("gun") then
				pcall(function()
					local moduleData = require(desc)
					if typeof(moduleData) == "table" then overrideTableRecoil(moduleData) end
				end)
			end
		end
	end
end

local function restoreAllRecoilValues()
	for key, data in pairs(noRecoilOverriddenObjects) do
		pcall(function()
			if data.type == "value" and isValidInstance(data.obj) then data.obj.Value = data.originalValue
			elseif data.type == "attribute" and isValidInstance(data.obj) then data.obj:SetAttribute(data.attrName, data.originalValue) end
		end)
	end
	noRecoilOverriddenObjects = {}
	noRecoilCurrentTool = nil
	noRecoilIsShooting = false
	noRecoilLockedCFrame = nil
end

local function refreshRecoilOverrides()
	if not (noRecoilEnabled or noSpreadEnabled) then return end
	if not noRecoilValueOverride then return end
	for key, data in pairs(noRecoilOverriddenObjects) do
		if not isValidInstance(data.obj) then noRecoilOverriddenObjects[key] = nil continue end
		pcall(function()
			if data.type == "value" then
				local currentVal = data.obj.Value
				if typeof(currentVal) == "number" then
					local isSpread = containsKeyword(data.obj.Name, spreadKeywords)
					local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
					local targetVal = data.originalValue * (1 - reduction)
					if math.abs(currentVal - targetVal) > 0.001 and math.abs(currentVal - data.originalValue) < 0.001 then
						data.obj.Value = targetVal
					end
				end
			elseif data.type == "attribute" then
				local currentVal = data.obj:GetAttribute(data.attrName)
				if typeof(currentVal) == "number" then
					local isSpread = containsKeyword(data.attrName, spreadKeywords)
					local reduction = isSpread and (noSpreadStrength / 100) or (noRecoilStrength / 100)
					local targetVal = data.originalValue * (1 - reduction)
					if math.abs(currentVal - targetVal) > 0.001 and math.abs(currentVal - data.originalValue) < 0.001 then
						data.obj:SetAttribute(data.attrName, targetVal)
					end
				end
			end
		end)
	end
end

local function applyNoRecoilCameraLock()
	if not noRecoilCameraLock then return end
	if not (noRecoilEnabled or noSpreadEnabled) then return end
	local isShooting = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
	if isShooting then
		if not noRecoilIsShooting then
			noRecoilIsShooting = true
			noRecoilLockedCFrame = camera.CFrame
		else
			if noRecoilLockedCFrame then
				local strength = noRecoilStrength / 100
				local currentPos = camera.CFrame.Position
				local lockedLook = noRecoilLockedCFrame.LookVector
				local targetCF = CFrame.new(currentPos, currentPos + lockedLook)
				camera.CFrame = camera.CFrame:Lerp(targetCF, strength * 0.8)
			end
		end
	else
		if noRecoilIsShooting then noRecoilIsShooting = false noRecoilLockedCFrame = nil end
	end
end

local function overrideRecoilPhysics()
	if not noRecoilEnabled then return end
	local char = player.Character
	if not char then return end
	for _, desc in ipairs(char:GetDescendants()) do
		if (desc:IsA("BodyAngularVelocity") or desc:IsA("BodyGyro")) then
			local n = desc.Name:lower()
			if n:find("recoil") or n:find("kick") or n:find("shake") then pcall(function() desc:Destroy() end) end
		end
	end
end

local function setupToolListener(char)
	if not char then return end
	if noRecoilToolConnection then pcall(function() noRecoilToolConnection:Disconnect() end) end
	noRecoilToolConnection = char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") and (noRecoilEnabled or noSpreadEnabled) then
			task.wait(0.3)
			if isValidInstance(child) and child.Parent == char then scanEquippedTool(child) end
		end
	end)
	task.wait(0.5)
	if not isValidInstance(char) then return end
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Tool") and (noRecoilEnabled or noSpreadEnabled) then scanEquippedTool(child) end
	end
end

local function deepScanModules()
	if not (noRecoilEnabled or noSpreadEnabled) then return 0 end
	local places = {ReplicatedStorage}
	pcall(function() table.insert(places, player.PlayerScripts) end)
	pcall(function() table.insert(places, game:GetService("StarterPlayer")) end)
	local count = 0
	for _, place in ipairs(places) do
		pcall(function()
			for _, desc in ipairs(place:GetDescendants()) do
				if desc:IsA("ModuleScript") then
					local name = desc.Name:lower()
					if name:find("recoil") or name:find("spread") or name:find("weapon") or name:find("gun") or name:find("firearm") or name:find("config") then
						pcall(function()
							local moduleData = require(desc)
							if typeof(moduleData) == "table" then overrideTableRecoil(moduleData) count = count + 1 end
						end)
					end
				end
			end
		end)
	end
	return count
end

local function hookNoRecoilRemotes()
	if noRecoilHooked then return end
	noRecoilHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not (noRecoilEnabled or noSpreadEnabled) then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local args = {...}
			if noRecoilEnabled and noRecoilRemoteIntercept then
				if name:find("recoil") or name:find("kick") or name:find("camerashake") or name:find("shake") then
					if noRecoilStrength >= 100 then return nil end
				end
			end
			if noSpreadEnabled then
				if name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") then
					for i, arg in ipairs(args) do
						if typeof(arg) == "Vector3" then
							local lookDir = camera.CFrame.LookVector
							local dotProduct = arg.Unit:Dot(lookDir)
							if dotProduct > 0.8 then
								local reduction = noSpreadStrength / 100
								local corrected = lookDir:Lerp(arg.Unit, 1 - reduction)
								args[i] = corrected * arg.Magnitude
							end
						elseif typeof(arg) == "table" then
							for k, v in pairs(arg) do
								if typeof(k) == "string" and typeof(v) == "number" then
									if containsKeyword(k, spreadKeywords) then arg[k] = v * (1 - noSpreadStrength / 100) end
									if containsKeyword(k, recoilKeywords) then arg[k] = v * (1 - noRecoilStrength / 100) end
								end
							end
						end
					end
					return oldFS(self, unpack(args))
				end
			end
			return oldFS(self, ...)
		end))
	end)
end

