-- ==================== ESP SYSTEM ====================
local function CreateDrawingESP(player)
	if player == LocalPlayer or ESPDrawings[player] then return end
	local d = {}
	for _, k in pairs({"CornerTL1","CornerTL2","CornerTR1","CornerTR2","CornerBL1","CornerBL2","CornerBR1","CornerBR2","OutCornerTL1","OutCornerTL2","OutCornerTR1","OutCornerTR2","OutCornerBL1","OutCornerBL2","OutCornerBR1","OutCornerBR2","Tracer","TracerOutline","HealthBarBG","HealthBarOutline","HealthBar"}) do
		d[k] = Drawing.new("Line"); d[k].Visible = false; d[k].Transparency = 1
	end
	for _, k in pairs({"Name","Distance","HealthText"}) do
		d[k] = Drawing.new("Text"); d[k].Visible = false; d[k].Outline = true; d[k].OutlineColor = Color3.new(0,0,0); d[k].Font = 2
	end
	for _, k in pairs({"CornerTL1","CornerTL2","CornerTR1","CornerTR2","CornerBL1","CornerBL2","CornerBR1","CornerBR2"}) do d[k].Color = ESPColor; d[k].Thickness = BoxThickness end
	for _, k in pairs({"OutCornerTL1","OutCornerTL2","OutCornerTR1","OutCornerTR2","OutCornerBL1","OutCornerBL2","OutCornerBR1","OutCornerBR2"}) do d[k].Color = Color3.new(0,0,0); d[k].Thickness = BoxThickness+2 end
	d.Name.Center=true;d.Name.Color=Color3.new(1,1,1);d.Name.Size=14
	d.Distance.Center=true;d.Distance.Color=Color3.fromRGB(200,200,200);d.Distance.Size=12
	d.HealthText.Center=false;d.HealthText.Color=Color3.fromRGB(0,255,0);d.HealthText.Size=11
	d.HealthBarBG.Color=Color3.fromRGB(30,30,30);d.HealthBarBG.Thickness=5
	d.HealthBarOutline.Color=Color3.new(0,0,0);d.HealthBarOutline.Thickness=7
	d.HealthBar.Color=Color3.fromRGB(0,255,0);d.HealthBar.Thickness=3
	d.Tracer.Color=ESPColor;d.Tracer.Thickness=TracerThickness
	d.TracerOutline.Color=Color3.new(0,0,0);d.TracerOutline.Thickness=TracerThickness+2;d.TracerOutline.Transparency=0.6
	ESPDrawings[player] = d
end

local function RemoveDrawingESP(player)
	if not ESPDrawings[player] then return end
	for _, obj in pairs(ESPDrawings[player]) do pcall(function() if obj.Remove then obj:Remove() elseif obj.Destroy then obj:Destroy() end end) end
	if player.Character then local hl=player.Character:FindFirstChild("ESP_HL");if hl then hl:Destroy() end end
	ESPDrawings[player] = nil
end

local function RemoveAllESP() for p in pairs(ESPDrawings) do RemoveDrawingESP(p) end end
local function RefreshAllESP() RemoveAllESP();if ESPEnabled then for _,p in pairs(Players:GetPlayers()) do if p~=LocalPlayer then CreateDrawingESP(p) end end end end

local function GetBoxBounds(char)
	local hrp,hum=char:FindFirstChild("HumanoidRootPart"),char:FindFirstChild("Humanoid")
	if not hrp or not hum then return nil end
	local tS,tO=Camera:WorldToViewportPoint(hrp.Position+Vector3.new(0,3,0))
	local bS,bO=Camera:WorldToViewportPoint(hrp.Position-Vector3.new(0,3,0))
	if not tO and not bO then return nil end
	local t2,b2=Vector2.new(tS.X,tS.Y),Vector2.new(bS.X,bS.Y)
	local h=math.abs(b2.Y-t2.Y);local w=h*0.55;local cx=(t2.X+b2.X)/2
	return{TL=Vector2.new(cx-w/2,t2.Y),TR=Vector2.new(cx+w/2,t2.Y),BL=Vector2.new(cx-w/2,b2.Y),BR=Vector2.new(cx+w/2,b2.Y),W=w,H=h,CX=cx,TY=t2.Y,BY=b2.Y}
end

local function UpdateDrawingESP()
	for player,d in pairs(ESPDrawings) do
		if not player or not player.Parent then RemoveDrawingESP(player) continue end
		local char=player.Character
		if not char then for _,o in pairs(d) do pcall(function() if o.Visible~=nil then o.Visible=false end end) end continue end
		local hum,hrp,head=char:FindFirstChild("Humanoid"),char:FindFirstChild("HumanoidRootPart"),char:FindFirstChild("Head")
		if not hum or not hrp or not head or hum.Health<=0 then for _,o in pairs(d) do pcall(function() if o.Visible~=nil then o.Visible=false end end) end continue end
		local lc=LocalPlayer.Character;local lh=lc and lc:FindFirstChild("HumanoidRootPart")
		local dist=lh and(hrp.Position-lh.Position).Magnitude or 0
		if(ESPTeamCheck and player.Team and LocalPlayer.Team and player.Team==LocalPlayer.Team)or dist>ESPMaxDistance then for _,o in pairs(d) do pcall(function() if o.Visible~=nil then o.Visible=false end end) end continue end
		local b=GetBoxBounds(char)
		if not b then for _,o in pairs(d) do pcall(function() if o.Visible~=nil then o.Visible=false end end) end continue end
		local cl=b.W*0.25
		if ESPBoxEnabled then
			local corners={{d.OutCornerTL1,d.OutCornerTL2,d.CornerTL1,d.CornerTL2,b.TL,Vector2.new(cl,0),Vector2.new(0,cl)},{d.OutCornerTR1,d.OutCornerTR2,d.CornerTR1,d.CornerTR2,b.TR,Vector2.new(-cl,0),Vector2.new(0,cl)},{d.OutCornerBL1,d.OutCornerBL2,d.CornerBL1,d.CornerBL2,b.BL,Vector2.new(cl,0),Vector2.new(0,-cl)},{d.OutCornerBR1,d.OutCornerBR2,d.CornerBR1,d.CornerBR2,b.BR,Vector2.new(-cl,0),Vector2.new(0,-cl)}}
			for _,c in pairs(corners) do
				c[1].From=c[5];c[1].To=c[5]+c[6];c[1].Visible=true;c[1].Thickness=BoxThickness+2
				c[2].From=c[5];c[2].To=c[5]+c[7];c[2].Visible=true;c[2].Thickness=BoxThickness+2
				c[3].From=c[5];c[3].To=c[5]+c[6];c[3].Visible=true;c[3].Color=ESPColor;c[3].Thickness=BoxThickness
				c[4].From=c[5];c[4].To=c[5]+c[7];c[4].Visible=true;c[4].Color=ESPColor;c[4].Thickness=BoxThickness
			end
		else for _,k in pairs({"CornerTL1","CornerTL2","CornerTR1","CornerTR2","CornerBL1","CornerBL2","CornerBR1","CornerBR2","OutCornerTL1","OutCornerTL2","OutCornerTR1","OutCornerTR2","OutCornerBL1","OutCornerBL2","OutCornerBR1","OutCornerBR2"}) do d[k].Visible=false end end
		if ESPNameEnabled then d.Name.Visible=true;d.Name.Text=player.DisplayName.." [@"..player.Name.."]";d.Name.Position=Vector2.new(b.CX,b.TY-18);d.Name.Color=ESPColor else d.Name.Visible=false end
		if ESPDistanceEnabled then d.Distance.Visible=true;d.Distance.Text="["..math.floor(dist).."m]";d.Distance.Position=Vector2.new(b.CX,b.BY+3) else d.Distance.Visible=false end
		if ESPHealthEnabled then
			local r=math.clamp(hum.Health/hum.MaxHealth,0,1);local bx=b.TL.X-6;local fy=b.BL.Y-((b.BL.Y-b.TL.Y)*r)
			d.HealthBarOutline.From=Vector2.new(bx,b.TL.Y-1);d.HealthBarOutline.To=Vector2.new(bx,b.BL.Y+1);d.HealthBarOutline.Visible=true
			d.HealthBarBG.From=Vector2.new(bx,b.TL.Y);d.HealthBarBG.To=Vector2.new(bx,b.BL.Y);d.HealthBarBG.Visible=true
			d.HealthBar.From=Vector2.new(bx,fy);d.HealthBar.To=Vector2.new(bx,b.BL.Y);d.HealthBar.Visible=true
			d.HealthBar.Color=r>0.6 and Color3.fromRGB(0,255,80)or r>0.3 and Color3.fromRGB(255,200,0)or Color3.fromRGB(255,30,30)
			if r<1 then d.HealthText.Visible=true;d.HealthText.Text=tostring(math.floor(hum.Health));d.HealthText.Position=Vector2.new(bx-5,fy-7);d.HealthText.Color=d.HealthBar.Color else d.HealthText.Visible=false end
		else d.HealthBarOutline.Visible=false;d.HealthBarBG.Visible=false;d.HealthBar.Visible=false;d.HealthText.Visible=false end
		if ESPTracerEnabled then
			local ss=Camera.ViewportSize;local bc=Vector2.new(ss.X/2,ss.Y);local ts=Vector2.new(b.CX,b.BY)
			d.TracerOutline.From=bc;d.TracerOutline.To=ts;d.TracerOutline.Visible=true;d.TracerOutline.Thickness=TracerThickness+2;d.TracerOutline.Transparency=0.5
			d.Tracer.From=bc;d.Tracer.To=ts;d.Tracer.Visible=true;d.Tracer.Thickness=TracerThickness;d.Tracer.Color=ESPColor
		else d.Tracer.Visible=false;d.TracerOutline.Visible=false end
		if ESPHighlightEnabled then
			local hl=char:FindFirstChild("ESP_HL")
			if not hl then hl=Instance.new("Highlight");hl.Name="ESP_HL";hl.FillTransparency=0.65;hl.OutlineTransparency=0;hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop;hl.Parent=char end
			hl.FillColor=ESPColor;hl.OutlineColor=ESPColor;hl.Enabled=true
		else local hl=char:FindFirstChild("ESP_HL");if hl then hl.Enabled=false end end
	end
end

