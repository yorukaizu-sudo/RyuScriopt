-- ==================== OIL FARM SPAM LOOP (AUTO TP + NO ANCHOR) ====================
local function OilFarmCycle()
	if not AutoFarmOilEnabled then return end

	pcall(function()
		-- STEP 1: TP ke Oil Pump + SPAM
		FarmCurrentStep = "⚡ Step 1: Pump"
		TeleportCFrame(CFrame1)
		task.wait(0.3)

		for i = 1, OilSpamCount do
			if not AutoFarmOilEnabled then break end
			pcall(function()
				local oilArea = workspace:FindFirstChild("OilArea")
				if oilArea then
					local children = oilArea:GetChildren()
					if children[2] then
						local p = children[2]:FindFirstChild("Prompt")
						if p then
							local prox = p:FindFirstChildOfClass("ProximityPrompt")
							if prox and MinigameEvent then
								MinigameEvent:FireServer(prox)
								OilTotalCalls = OilTotalCalls + 1
							end
						end
					end
				end
			end)
			task.wait(OilFarmSpeed)
		end

		if not AutoFarmOilEnabled then return end

		-- STEP 2: TP ke Refinery 1 + SPAM
		FarmCurrentStep = "⚡ Step 2: Refinery 1"
		TeleportCFrame(CFrame2)
		task.wait(0.3)

		for i = 1, OilSpamCount do
			if not AutoFarmOilEnabled then break end
			pcall(function()
				local oilArea = workspace:FindFirstChild("OilArea")
				if oilArea then
					local children = oilArea:GetChildren()
					if children[13] then
						local p = children[13]:FindFirstChild("Part")
						if p then
							local prox = p:FindFirstChildOfClass("ProximityPrompt")
							if prox and MinigameEvent then
								MinigameEvent:FireServer(prox)
								OilTotalCalls = OilTotalCalls + 1
							end
						end
					end
				end
			end)
			task.wait(OilFarmSpeed)
		end

		if not AutoFarmOilEnabled then return end

		-- STEP 3: TP ke Refinery 2 + SPAM
		FarmCurrentStep = "⚡ Step 3: Refinery 2"
		TeleportCFrame(CFrame3)
		task.wait(0.3)

		for i = 1, OilSpamCount do
			if not AutoFarmOilEnabled then break end
			pcall(function()
				local oilArea = workspace:FindFirstChild("OilArea")
				if oilArea then
					local children = oilArea:GetChildren()
					if children[14] then
						local p = children[14]:FindFirstChild("Part")
						if p then
							local prox = p:FindFirstChildOfClass("ProximityPrompt")
							if prox and MinigameEvent then
								MinigameEvent:FireServer(prox)
								OilTotalCalls = OilTotalCalls + 1
							end
						end
					end
				end
			end)
			task.wait(OilFarmSpeed)
		end

		if not AutoFarmOilEnabled then return end

		-- STEP 4: TP ke Sell + Sell 1x
		FarmCurrentStep = "💰 Step 4: Selling"
		TeleportCFrame(CFrameSell)
		task.wait(0.3)

		pcall(function()
			if SellEvent then
				SellEvent:FireServer("Oil", 3)
				OilTotalCalls = OilTotalCalls + 1
			end
		end)

		task.wait(0.5)
		OilCycleCount = OilCycleCount + 1
		FarmCurrentStep = "✅ Cycle #" .. OilCycleCount .. " Done!"
	end)
end

