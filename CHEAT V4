local function isPlayerPart(part)
	if not part then return false end
	local model = part:FindFirstAncestorOfClass("Model")
	if not model then return false end
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character and p.Character == model then return true end
	end
	return false
end

local function isWallbangIgnorable(part)
	if not part or not isValidInstance(part) then return false end
	local model = part:FindFirstAncestorOfClass("Model")
	if model then
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Character and p.Character == model then return false end
		end
	end
	if part.Name == "HitboxOverlay" or part.Name:sub(1,3) == "AH_" then return false end
	if part:FindFirstAncestorOfClass("Tool") or part:FindFirstAncestorOfClass("Accessory") then return false end
	if CFG.wallbangIgnoreTerrain and part:IsA("Terrain") then return true end
	if CFG.wallbangIgnoreParts and part:IsA("Part") then return true end
	if CFG.wallbangIgnoreMeshParts and part:IsA("MeshPart") then return true end
	if part:IsA("UnionOperation") or part:IsA("TrussPart") or part:IsA("WedgePart") or part:IsA("CornerWedgePart") then return true end
	return false
end

local function findPlayerThroughWalls(origin, targetPos)
	if not CFG.wallbangEnabled then return false end
	local dir = (targetPos - origin)
	local dist = dir.Magnitude
	if dist > CFG.wallbangDistance then return false end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	local currentOrigin = origin
	local remainingDir = dir
	local penetrations = 0
	local totalDist = 0
	while penetrations < CFG.wallbangMaxPenetration and totalDist < dist do
		local result = workspace:Raycast(currentOrigin, remainingDir, params)
		if not result then return true end
		if isPlayerPart(result.Instance) then return true end
		if isWallbangIgnorable(result.Instance) then
			penetrations = penetrations + 1
			totalDist = totalDist + (result.Position - currentOrigin).Magnitude + 0.5
			currentOrigin = result.Position + remainingDir.Unit * 0.5
			remainingDir = dir.Unit * (dist - totalDist)
			if remainingDir.Magnitude <= 0.1 then break end
		else return false end
	end
	return totalDist >= dist
end

local function hookWallbang()
	if CFG.wallbangHooked then return end
	CFG.wallbangHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldRaycast = workspace.Raycast
		hf(workspace.Raycast, newcclosure(function(self, origin, direction, rayParams, ...)
			if not CFG.wallbangEnabled then return oldRaycast(self, origin, direction, rayParams, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if not myHrp then return oldRaycast(self, origin, direction, rayParams, ...) end
			if (origin - myHrp.Position).Magnitude > 20 and (origin - camera.CFrame.Position).Magnitude > 5 then
				return oldRaycast(self, origin, direction, rayParams, ...)
			end
			local currentOrigin, remainingDir = origin, direction
			local penetrations, totalDist, maxDist = 0, 0, direction.Magnitude
			while penetrations < CFG.wallbangMaxPenetration and totalDist < maxDist do
				local result = oldRaycast(self, currentOrigin, remainingDir, rayParams, ...)
				if not result then return nil end
				if isPlayerPart(result.Instance) or result.Instance.Name == "HitboxOverlay" then return result end
				if isWallbangIgnorable(result.Instance) then
					penetrations = penetrations + 1
					totalDist = totalDist + (result.Position - currentOrigin).Magnitude + 0.1
					currentOrigin = result.Position + remainingDir.Unit * 0.5
					remainingDir = remainingDir.Unit * math.max(maxDist - totalDist, 0.1)
					if remainingDir.Magnitude <= 0.1 then return result end
				else return result end
			end
			return oldRaycast(self, origin, direction, rayParams, ...)
		end))
	end)
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFPR = workspace.FindPartOnRay
		hf(workspace.FindPartOnRay, newcclosure(function(self, ray, ignoreList, ...)
			if not CFG.wallbangEnabled then return oldFPR(self, ray, ignoreList, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if not myHrp or (ray.Origin - myHrp.Position).Magnitude > 20 then return oldFPR(self, ray, ignoreList, ...) end
			local currentIgnore = typeof(ignoreList) == "table" and table.clone(ignoreList) or {ignoreList}
			local currentOrigin, dir = ray.Origin, ray.Direction
			local penetrations, totalDist, maxDist = 0, 0, dir.Magnitude
			while penetrations < CFG.wallbangMaxPenetration and totalDist < maxDist do
				local newRay = Ray.new(currentOrigin, dir.Unit * math.max(maxDist - totalDist, 0.1))
				local hitPart, hitPos, hitNormal, hitMaterial = oldFPR(self, newRay, currentIgnore, ...)
				if not hitPart then return nil, currentOrigin + dir, Vector3.new(0,1,0), Enum.Material.Air end
				if isPlayerPart(hitPart) or hitPart.Name == "HitboxOverlay" then return hitPart, hitPos, hitNormal, hitMaterial end
				if isWallbangIgnorable(hitPart) then
					penetrations = penetrations + 1
					totalDist = totalDist + (hitPos - currentOrigin).Magnitude + 0.1
					currentOrigin = hitPos + dir.Unit * 0.5
					table.insert(currentIgnore, hitPart)
				else return hitPart, hitPos, hitNormal, hitMaterial end
			end
			return oldFPR(self, ray, ignoreList, ...)
		end))
	end)
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFPR2 = workspace.FindPartOnRayWithIgnoreList
		if not oldFPR2 then return end
		hf(workspace.FindPartOnRayWithIgnoreList, newcclosure(function(self, ray, ignoreList, ...)
			if not CFG.wallbangEnabled then return oldFPR2(self, ray, ignoreList, ...) end
			local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if not myHrp or (ray.Origin - myHrp.Position).Magnitude > 20 then return oldFPR2(self, ray, ignoreList, ...) end
			local currentIgnore = {}
			if typeof(ignoreList) == "table" then for _, v in ipairs(ignoreList) do table.insert(currentIgnore, v) end
			elseif ignoreList then table.insert(currentIgnore, ignoreList) end
			local currentOrigin, dir = ray.Origin, ray.Direction
			local penetrations, totalDist, maxDist = 0, 0, dir.Magnitude
			while penetrations < CFG.wallbangMaxPenetration and totalDist < maxDist do
				local newRay = Ray.new(currentOrigin, dir.Unit * math.max(maxDist - totalDist, 0.1))
				local hitPart, hitPos, hitNormal, hitMaterial = oldFPR2(self, newRay, currentIgnore, ...)
				if not hitPart then return nil end
				if isPlayerPart(hitPart) or hitPart.Name == "HitboxOverlay" then return hitPart, hitPos, hitNormal, hitMaterial end
				if isWallbangIgnorable(hitPart) then
					penetrations = penetrations + 1
					totalDist = totalDist + (hitPos - currentOrigin).Magnitude + 0.1
					currentOrigin = hitPos + dir.Unit * 0.5
					table.insert(currentIgnore, hitPart)
				else return hitPart, hitPos, hitNormal, hitMaterial end
			end
			return oldFPR2(self, ray, ignoreList, ...)
		end))
	end)
end

local function hookWallbangRemotes()
	if CFG.wallbangRemoteHooked then return end
	CFG.wallbangRemoteHooked = true
	pcall(function()
		local hf = hookfunction or replaceclosure
		if not hf then return end
		local oldFS
		oldFS = hf(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not CFG.wallbangEnabled or not CFG.wallbangRemoteHook then return oldFS(self, ...) end
			local ok, name = pcall(function() return self.Name:lower() end)
			if not ok then return oldFS(self, ...) end
			local isShoot = name:find("fire") or name:find("shoot") or name:find("attack") or name:find("bullet") or name:find("weapon") or name:find("hit") or name:find("damage") or name:find("ray") or name:find("cast")
			if not isShoot then return oldFS(self, ...) end
			local args = {...}
			for i, arg in ipairs(args) do
				if typeof(arg) == "table" then
					for k, v in pairs(arg) do
						if typeof(k) == "string" then
							local kl = k:lower()
							if kl:find("blocked") or kl:find("wallhit") or kl:find("wall_hit") or kl:find("penetrat") or kl:find("obstruct") then
								if typeof(v) == "boolean" then arg[k] = false
								elseif typeof(v) == "number" then arg[k] = 0 end
							end
						end
					end
				end
			end
			return oldFS(self, unpack(args))
		end))
	end)
end

local function applyWallbangVisual()
	if not CFG.wallbangVisual then
		for part, origData in pairs(CFG.wallbangVisualParts) do
			pcall(function() if isValidInstance(part) then part.LocalTransparencyModifier = origData.transparency or 0 end end)
		end
		CFG.wallbangVisualParts = {}
		return
	end
	local myHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not myHrp then return end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {player.Character}
	params.FilterType = Enum.RaycastFilterType.Exclude
	for part, origData in pairs(CFG.wallbangVisualParts) do
		if not isValidInstance(part) then CFG.wallbangVisualParts[part] = nil continue end
		if (myHrp.Position - part.Position).Magnitude > 50 then
			pcall(function() part.LocalTransparencyModifier = origData.transparency or 0 end)
			CFG.wallbangVisualParts[part] = nil
		end
	end
	for i = 1, 8 do
		local spreadAngle = (i - 1) * (math.pi * 2 / 8)
		local spreadOffset = Vector3.new(math.cos(spreadAngle) * 2, 0, math.sin(spreadAngle) * 2)
		local result = workspace:Raycast(camera.CFrame.Position, camera.CFrame.LookVector * 100 + spreadOffset, params)
		if result and result.Instance and isWallbangIgnorable(result.Instance) and not isPlayerPart(result.Instance) then
			if not CFG.wallbangVisualParts[result.Instance] then
				CFG.wallbangVisualParts[result.Instance] = { transparency = result.Instance.LocalTransparencyModifier }
			end
			pcall(function() result.Instance.LocalTransparencyModifier = CFG.wallbangVisualTransparency end)
		end
	end
end

local function cleanWallbangVisuals()
	for part, origData in pairs(CFG.wallbangVisualParts) do
		pcall(function() if isValidInstance(part) then part.LocalTransparencyModifier = origData.transparency or 0 end end)
	end
	CFG.wallbangVisualParts = {}
end

