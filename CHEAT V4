-- NOCLIP
-- ==========================================
local function applyNoclip()
	if not CFG.noclip then return end
	local char = player.Character if not char then return end
	for _, v in ipairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
	if CFG.noclipMethod == "CFrame Bypass" then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hrp and hum and hum.MoveDirection.Magnitude > 0 then
			local params = RaycastParams.new()
			params.FilterDescendantsInstances = {char}
			params.FilterType = Enum.RaycastFilterType.Exclude
			if workspace:Raycast(hrp.Position, hum.MoveDirection*3, params) then hrp.CFrame = hrp.CFrame + hum.MoveDirection*1.5 end
		end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
			local hrp2 = char:FindFirstChild("HumanoidRootPart")
			if hrp2 then hrp2.CFrame = hrp2.CFrame + Vector3.new(0,1,0) end
		end
	elseif CFG.noclipMethod == "Phase Bypass" then
		pcall(function() char:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Running) end)
	elseif CFG.noclipMethod == "Velocity Bypass" then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if hrp and hrp.AssemblyLinearVelocity.Magnitude > 60 then hrp.AssemblyLinearVelocity = hrp.AssemblyLinearVelocity.Unit*60 end
	end
end

